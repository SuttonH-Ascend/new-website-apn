function openArticle(id) {
  var a = ARTICLES[id];
  if (!a) return;
  document.getElementById('modal-badge').textContent = a.badge;
  document.getElementById('modal-title').textContent = a.title;
  document.getElementById('res-modal-body').innerHTML = a.body;
  document.getElementById('res-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
  document.getElementById('res-modal-close').focus();
}

function closeArticle() {
  document.getElementById('res-modal').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeArticle();
});

window.handleRSub = function(e) {
  e.preventDefault();
  var form = e.target;
  var input = form.querySelector('input[type="email"]');
  var btn = form.querySelector('button[type="submit"]');
  if (!input || !input.value.includes('@')) {
    if (input) { input.style.borderColor = '#EF4444'; input.focus(); }
    return;
  }
  var email = input.value.trim();
  var orig = btn.textContent;
  btn.textContent = 'Subscribing...';
  btn.disabled = true;
  input.disabled = true;

  fetch('https://a.klaviyo.com/client/subscriptions/?company_id=R5eNpH', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/vnd.api+json',
      'revision': '2024-10-15'
    },
    body: JSON.stringify({
      data: {
        type: 'subscription',
        attributes: {
          list_id: 'RSeqfi',
          custom_source: 'Resources Page',
          profiles: {
            data: [{
              type: 'profile',
              attributes: { email: email }
            }]
          }
        }
      }
    })
  })
  .then(function() {
    btn.textContent = "You're In!";
    btn.style.background = 'linear-gradient(135deg,#22C55E,#16A34A)';
    input.value = '';
    input.placeholder = 'Welcome to the community!';
    setTimeout(function() {
      btn.textContent = orig;
      btn.style.background = '';
      btn.disabled = false;
      input.disabled = false;
      input.placeholder = 'Your email address';
    }, 4000);
  })
  .catch(function() {
    btn.textContent = orig;
    btn.disabled = false;
    input.disabled = false;
  });
};
</script>
