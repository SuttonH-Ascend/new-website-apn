<script>
(function() {
  // URL Param Parser
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  // Inject name, score, tier
  var nameEl = document.getElementById('apn-rec-name');
  var scoreEl = document.getElementById('apn-rec-score');
  var scoreDiagEl = document.getElementById('apn-rec-score-display');
  var badgeEl = document.getElementById('apn-rec-tier-badge');

  if (nameEl) nameEl.textContent = nameParam;
  if (scoreEl) scoreEl.textContent = scoreParam;
  if (scoreDiagEl) scoreDiagEl.textContent = scoreParam;
  if (badgeEl) {
    var color = tierColors[tierParam] || '#06A5C5';
    var name = tierNames[tierParam] || 'Athlete';
    badgeEl.textContent = name;
    badgeEl.style.background = color;
    badgeEl.style.color = '#FFFFFF';
  }

  // Score context injection
  var scoreContextEl = document.getElementById('apn-rec-score-context');
  if (scoreContextEl) {
    var contextHTML = '';
    if (scoreParam <= 30) {
      contextHTML = '<div style="background:#FEF2F2; border-left:4px solid #EF4444; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' indicates a significant recovery deficit. Your training stimulus is almost certainly exceeding your recovery capacity. You are accumulating fatigue faster than you are building fitness. The most important change: post-training protein timing and immediate reduction of any training sessions that are adding volume without adding recovery time. Fix the foundation before adding intensity.</p></div>';
    } else if (scoreParam <= 50) {
      contextHTML = '<div style="background:#FFFBEB; border-left:4px solid #F59E0B; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' means your recovery system is operating but incomplete. You are likely hitting your post-training window inconsistently, your inflammatory load is elevated, and your HRV is probably not trending in the right direction. Each training session is partially absorbed. Closing this gap will meaningfully improve your training-to-adaptation conversion rate.</p></div>';
    } else if (scoreParam <= 70) {
      contextHTML = '<div style="background:#F0FBFF; border-left:4px solid #06A5C5; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' puts you in the moderate recovery zone. Your basics are in place but precision variables are limiting your ceiling. Protein timing consistency, HRV-guided training load, and an anti-inflammatory protocol are the three gaps most likely sitting at this score level. Close them and your training adaptation rate increases measurably.</p></div>';
    } else if (scoreParam <= 85) {
      contextHTML = '<div style="background:#F5F3FF; border-left:4px solid #8B5CF6; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' reflects strong recovery fundamentals. Your protein timing and active recovery are likely consistent. The remaining gains are in precision: leucine threshold accuracy, HRV trend management, and joint inflammation protocols that keep you training without accumulated damage. These are the variables that define your ceiling at this level.</p></div>';
    } else {
      contextHTML = '<div style="background:#F0FDF4; border-left:4px solid #22C55E; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' indicates excellent recovery architecture. Your task is maintenance, protection, and refinement. Use this MasterClass as your quarterly review protocol to ensure no variables are drifting. At this score level, small drifts in protein timing or supplement consistency can compound into meaningful performance degradation over a training block.</p></div>';
    }
    scoreContextEl.innerHTML = contextHTML;
  }

  // Show tier blocks
  document.querySelectorAll('.apn-r-tier-block').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // Secondary gap callout
  if (gap2Param) {
    var gap2El = document.getElementById('apn-rec-gap2-callout');
    var gap2TextEl = document.getElementById('apn-rec-gap2-text');
    if (gap2El && gap2TextEl) {
      var gap2Name = gap2Param.charAt(0).toUpperCase() + gap2Param.slice(1);
      var overlap = '';
      if (gap2Param === 'sleep') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Fortify (Colostrum) addresses both: IGF-1 for satellite cell activation in your recovery gap, and reduced systemic inflammation (via gut repair) that directly improves slow-wave sleep quality in your sleep gap. One product, two mechanisms across both gaps.';
      } else if (gap2Param === 'nutrition') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Resilience (Whey Protein Isolate) directly addresses both: it fills your post-training MPS window for recovery, and corrects protein distribution gaps for your nutrition gap. A single product doing the most important work on both fronts.';
      } else if (gap2Param === 'stress') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Balance (Turmeric) addresses both: NF-kB inhibition reduces chronic training inflammation for your recovery gap, and the same pathway reduction lowers the baseline inflammatory burden that amplifies HPA axis stress reactivity. Reducing inflammation reduces cortisol sensitivity.';
      } else {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Fortify (Colostrum) addresses both: gut lining repair reduces the systemic inflammatory load relevant to your recovery gap, and the IGF-1 content supports the tissue-level repair processes that overlap with your ' + gap2Name.toLowerCase() + ' gap.';
      }
      gap2TextEl.innerHTML = overlap;
      gap2El.style.display = 'block';
    }
  }

  // Checkbox severity logic
  var checkboxes = document.querySelectorAll('.apn-rec-symptom');
  var severityEl = document.getElementById('apn-rec-severity');

  function updateSeverity() {
    var count = 0;
    checkboxes.forEach(function(cb) { if (cb.checked) count++; });
    if (count === 0) {
      severityEl.style.display = 'none';
      return;
    }
    severityEl.style.display = 'block';
    if (count <= 2) {
      severityEl.style.background = '#F0FDF4';
      severityEl.style.color = '#166534';
      severityEl.style.borderLeft = '4px solid #22C55E';
      severityEl.textContent = count + ' of 7 checked. Mild optimization gap. You are recovering but not fully. The protocol ahead will close the remaining gap and improve your training-to-adaptation conversion rate.';
    } else if (count <= 5) {
      severityEl.style.background = '#FFFBEB';
      severityEl.style.color = '#92400E';
      severityEl.style.borderLeft = '4px solid #F59E0B';
      severityEl.textContent = count + ' of 7 checked. Moderate gap. Your recovery system is actively limiting your training ceiling. You are likely accumulating a small debt with each training week that is compounding into the symptoms you checked above. The 30-day protocol is exactly what is needed.';
    } else {
      severityEl.style.background = '#FEF2F2';
      severityEl.style.color = '#991B1B';
      severityEl.style.borderLeft = '4px solid #EF4444';
      severityEl.textContent = count + ' of 7 checked. Severe gap. This is your primary performance constraint. Your training is creating demand that your recovery system cannot meet. Until this closes, adding training volume or intensity will deepen the deficit, not close it. Work through this protocol completely before making any other training or nutrition changes.';
    }
  }
  checkboxes.forEach(function(cb) { cb.addEventListener('change', updateSeverity); });

  // IntersectionObserver for progress bar and sidebar
  var modules = ['apn-rec-m0','apn-rec-m1','apn-rec-m2','apn-rec-m3','apn-rec-m4','apn-rec-m5','apn-rec-m6'];
  var dots = document.querySelectorAll('#apn-rec-progress .apn-r-progress-dot');
  var sideItems = document.querySelectorAll('#apn-rec-sidebar .apn-r-sidebar__item');

  var observerOptions = { root: null, rootMargin: '0px', threshold: 0.3 };
  var moduleObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var idx = modules.indexOf(entry.target.id);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i <= idx); });
          sideItems.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
        }
      }
    });
  }, observerOptions);

  modules.forEach(function(id) {
    var el = document.getElementById(id);
    if (el) moduleObserver.observe(el);
  });

  // FAB TOC
  var fab = document.getElementById('apn-rec-fab');
  if (fab) {
    fab.addEventListener('click', function() {
      var moduleEl = document.getElementById('apn-rec-m0');
      if (moduleEl) moduleEl.scrollIntoView({ behavior: 'smooth' });
    });
  }
})();

function apnRecSelectSubgap(btn) {
  document.querySelectorAll('#apn-rec-subgaps .apn-r-subgap-btn').forEach(function(b) {
    b.classList.remove('selected');
  });
  btn.classList.add('selected');
  var subgap = btn.dataset.subgap;
  var targetEl = document.getElementById('apn-rec-primary-target');
  if (targetEl) {
    var labels = {
      acute: 'PRIMARY TARGET: Acute Soreness (DOMS). Your mTOR activation is the priority. Week 1 protein timing is your highest-leverage change. Colostrum in Week 3 will further accelerate satellite cell repair. Measure DOMS duration daily.',
      chronic: 'PRIMARY TARGET: Chronic Fatigue (Accumulated Training Debt). Reduce training volume by 15 to 20% this week while building your recovery architecture. Your body needs to pay down the debt before you can add more load. HRV tracking starts immediately.',
      joint: 'PRIMARY TARGET: Joint Inflammation. Turmeric with piperine in Week 3 is your most important supplement addition. Anti-inflammatory protocol and Recover cream for site-specific application. Evaluate whether training load on affected joints needs temporary reduction.',
      hrv: 'PRIMARY TARGET: Low HRV (Systemic Overtraining). Active recovery replaces one hard session this week. HRV-guided training adjustments are mandatory, not optional. No hard sessions when HRV is more than 10% below your 7-day average. Your nervous system needs priority attention.'
    };
    targetEl.textContent = labels[subgap] || '';
    targetEl.style.display = 'block';
  }
}
</script>