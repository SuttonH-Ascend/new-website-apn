<script>
(function() {
  // ========== URL PARAMS ==========
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  // ========== INJECT PERSONALIZATION ==========
  const tierColor = tierColors[tierParam] || '#06A5C5';
  const tierName = tierNames[tierParam] || 'Athlete';

  document.getElementById('apn-s-name-display').textContent = nameParam;
  document.getElementById('apn-s-score-display').textContent = scoreParam;

  const badge = document.getElementById('apn-s-tier-badge');
  badge.textContent = tierName;
  badge.style.background = tierColor;
  badge.style.color = tierParam === 'rookie' || tierParam === 'competitor' ? '#0D0D0D' : '#FFFFFF';

  document.getElementById('apn-s-m3-score').textContent = scoreParam;
  document.getElementById('apn-s-m3-tier').textContent = tierName;

  // ========== SCORE CONTEXT ==========
  const scoreCtx = document.getElementById('apn-s-score-context');
  let scoreText = '';
  if (scoreParam < 30) {
    scoreText = 'A score of ' + scoreParam + ' places you in the severe HPA axis dysregulation range. Your cortisol-testosterone ratio is likely suppressed enough that your anabolic hormone output is significantly blunted. Training is producing a stress stimulus. The hormonal environment required to rebuild from that stimulus is compromised. You are in a chronic catabolic state between sessions.';
  } else if (scoreParam < 50) {
    scoreText = 'A score of ' + scoreParam + ' indicates moderate HPA axis load. Your cortisol output is elevated above the optimal range for athletic recovery. Testosterone synthesis is partially suppressed via the HPG axis. Growth hormone pulse amplitude during slow-wave sleep is reduced. You are recovering at 60 to 70% of your potential output. The training is there. The hormonal response is not.';
  } else if (scoreParam < 70) {
    scoreText = 'A score of ' + scoreParam + ' means your stress management is functional but not optimal. You recover well from individual sessions but likely accumulate debt during high-volume training weeks or high life-stress periods. Your cortisol-testosterone ratio dips below optimal 2 to 3 times per month, costing you meaningful adaptation during those windows.';
  } else if (scoreParam < 85) {
    scoreText = 'A score of ' + scoreParam + ' is solid. You have the core architecture in place. The remaining gap lives in precision: HRV-guided training load management, supplement timing optimization, and protecting your sleep-stress feedback loop from seasonal or life-event disruption.';
  } else {
    scoreText = 'A score of ' + scoreParam + ' is elite-level stress management. Your HPA axis is well-regulated. This page is about protecting and maintaining what you have built. One unmanaged high-stress period can compress two months of anabolic work in three weeks. Vigilance is the discipline at this level.';
  }
  scoreCtx.innerHTML = '<p class="apn-s-body">' + scoreText + '</p>';

  // ========== TIER SHOW/HIDE ==========
  document.querySelectorAll('.apn-tier-block').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // ========== GAP2 CALLOUT ==========
  if (gap2Param) {
    const gap2Block = document.getElementById('apn-s-gap2-callout');
    const gap2Text = document.getElementById('apn-s-gap2-text');
    gap2Block.style.display = 'block';

    const gap2Messages = {
      sleep: 'Your secondary gap is Sleep. The good news: Adapt and Function directly address both. Ashwagandha lowers evening cortisol, accelerating sleep onset. Magnesium Glycinate improves sleep onset latency and slow-wave sleep depth via GABA modulation. One stack. Two gaps addressed simultaneously.',
      recovery: 'Your secondary gap is Recovery. Balance (Turmeric) and Omega-3 address both stress and recovery. NF-kB inhibition from curcumin reduces both the inflammation from training and the downstream inflammation from chronic cortisol. Your recovery speed is tied to how fast you can resolve this inflammatory environment.',
      focus: 'Your secondary gap is Focus. Chronically elevated cortisol degrades prefrontal cortex function, the brain region responsible for sustained attention and executive control. Closing the stress gap first will produce a measurable improvement in cognitive focus without adding any focus-specific supplements.',
      nutrition: 'Your secondary gap is Nutrition. Elevated cortisol drives preferential visceral fat storage and dysregulates appetite signaling, creating stronger cravings for high-sugar foods. Closing the stress gap will make your nutrition interventions significantly more effective.',
      hydration: 'Your secondary gap is Hydration. Cortisol promotes aldosterone-driven sodium retention and can mask dehydration signals. Addressing HPA axis dysregulation will improve your thirst response accuracy and electrolyte regulation.',
      training: 'Your secondary gap is Training. Chronic cortisol suppression of testosterone and growth hormone is the most common reason athletes plateau despite consistent training effort. Your training gap may resolve significantly once the stress gap is closed and the anabolic hormonal environment is restored.',
      supplementation: 'Your secondary gap is Supplementation. The Adapt and Function products are also priority Tier 2 supplements in the overall hierarchy. By closing your stress gap, you are simultaneously building the foundational supplement protocol.'
    };

    gap2Text.textContent = gap2Messages[gap2Param.toLowerCase()] || 'Your secondary gap is ' + gap2Param + '. Function (Magnesium Glycinate) from the stress stack also supports recovery and sleep, making it the highest-overlap product for your secondary gap.';
  }

  // ========== PROGRESS BAR ==========
  window.addEventListener('scroll', function() {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    document.getElementById('apn-s-progress-fill').style.width = pct + '%';
  });

  // ========== MODULE DOT TRACKING ==========
  const moduleIds = ['apn-s-m0','apn-s-m1','apn-s-m2','apn-s-m3','apn-s-m4','apn-s-m5','apn-s-m6'];
  const dots = document.querySelectorAll('.apn-s-dot');
  const sidebarItems = document.querySelectorAll('.apn-s-sidebar-item');

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        const idx = moduleIds.indexOf(entry.target.id);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
          sidebarItems.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
        }
      }
    });
  }, { threshold: 0.3 });

  moduleIds.forEach(function(id) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
})();

// ========== CHECKBOX DIAGNOSIS ==========
function apnSToggleCheck(item) {
  const box = item.querySelector('.apn-s-checkbox-box');
  const check = box.querySelector('svg');
  const isChecked = box.classList.contains('checked');

  if (isChecked) {
    box.classList.remove('checked');
    check.style.display = 'none';
  } else {
    box.classList.add('checked');
    check.style.display = 'block';
  }

  // Count checked
  const total = document.querySelectorAll('#apn-s-checkbox-list .apn-s-checkbox-box.checked').length;
  const display = document.getElementById('apn-s-severity-display');
  const label = document.getElementById('apn-s-severity-label');
  const text = document.getElementById('apn-s-severity-text');

  display.style.display = 'block';

  if (total <= 2) {
    display.style.background = '#DCFCE7';
    display.style.color = '#166534';
    label.textContent = total + ' of 7 symptoms: Mild Optimization Gap';
    text.textContent = 'You are maintaining stress management but leaving performance on the table. The protocol in Module 4 will close the remaining gap and optimize your cortisol-testosterone ratio.';
  } else if (total <= 5) {
    display.style.background = '#FEF3C7';
    display.style.color = '#92400E';
    label.textContent = total + ' of 7 symptoms: Moderate Gap';
    text.textContent = 'This gap is actively limiting your training ceiling. Chronic cortisol elevation is suppressing anabolic hormone output. The protocol and supplement stack will produce measurable change within 2 to 3 weeks of consistent execution.';
  } else {
    display.style.background = '#FEE2E2';
    display.style.color = '#991B1B';
    label.textContent = total + ' of 7 symptoms: Severe Gap';
    text.textContent = 'This is your primary performance constraint right now. Everything else is secondary until this is resolved. Your HPA axis is dysregulated. The anabolic hormonal environment required for adaptation is severely compromised. Start the protocol today.';
  }
}

// ========== SUB-GAP SELECTION ==========
function apnSSelectSubgap(el, name) {
  document.querySelectorAll('.apn-s-subgap-option').forEach(function(opt) {
    opt.classList.remove('selected');
  });
  el.classList.add('selected');

  const targetDisplay = document.getElementById('apn-s-primary-target-display');
  const targetText = document.getElementById('apn-s-primary-target-text');
  targetDisplay.style.display = 'block';
  targetText.textContent = 'Your primary target is: ' + name + '. Module 4 addresses this directly. Every week of the protocol is designed to close this specific sub-gap.';
}
</script>

