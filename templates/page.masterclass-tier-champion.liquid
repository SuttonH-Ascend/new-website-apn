    training:       { name: 'Recharge', ingredient: 'Creatine Monohydrate', price: '$39.99', reason: 'Your training pillar is your current gap. Phosphocreatine availability directly determines power output capacity in the 1-10 second range. If progressive overload has stalled, the PCr buffer needs to be maximally saturated before load prescription changes are made.' },
    recovery:       { name: 'Adapt', ingredient: 'Ashwagandha KSM-66', price: '$14.99', reason: 'Your recovery pillar is the optimization target. Recovery insufficiency at Champion level is often driven by unmanaged allostatic load rather than under-sleeping. KSM-66 addresses the cortisol component of recovery that sleep alone cannot fully resolve.' },
    supplementation:{ name: 'Balance', ingredient: 'Turmeric + Black Pepper', price: '$19.99', reason: 'Your supplementation pillar is incomplete. Balance addresses the NF-kB inflammatory pathway that no other product in the stack targets. At your training volume and age, curcumin with piperine is the missing longevity compound.' },
    hydration:      { name: 'Recharge', ingredient: 'Creatine Monohydrate', price: '$39.99', reason: 'Your hydration pillar is flagged as the current gap. Note that creatine monohydrate increases intramuscular water retention, which supports cellular hydration status. This does not replace fluid intake protocol, but it supports the intracellular side of hydration that electrolytes alone do not address.' },
    mindset:        { name: 'Adapt', ingredient: 'Ashwagandha KSM-66', price: '$14.99', reason: 'Your mindset pillar is the current optimization target. Cortisol dysregulation is one of the most common neurological contributors to inconsistent mental performance under stress. KSM-66 at 600mg daily has shown improvements in perceived stress, reaction time, and sustained attention in athletic populations.' }
  };

  function getGapProduct(gapKey) {
    return gapProductMap[gapKey] || gapProductMap['stress'];
  }

  var gapProd = getGapProduct(gap1Param);
  var gapProductEl = document.getElementById('champGapProduct');
  if (gapProductEl) {
    var meta1 = getGapMeta(gap1Param);
    gapProductEl.innerHTML = ''
      + '<div style="border:2px solid #EF4444;padding:28px;margin-bottom:20px;">'
        + '<div style="font-family:\'Barlow\',sans-serif;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:4px;color:#EF4444;margin-bottom:12px;">Gap-Targeted Recommendation: ' + meta1.label + '</div>'
        + '<div class="champ-product-card__header">'
          + '<div>'
            + '<div class="champ-product-card__name">' + gapProd.name + '</div>'
            + '<div class="champ-product-card__ingredient">' + gapProd.ingredient + '</div>'
          + '</div>'
          + '<div class="champ-product-card__price">' + gapProd.price + '</div>'
        + '</div>'
        + '<p class="champ-product-card__mechanism">' + gapProd.reason + '</p>'
        + '<div class="champ-product-card__timing">Targeted at: <span>' + meta1.label + ' pillar. Your primary optimization focus based on your quiz score distribution.</span></div>'
      + '</div>';
  }

  // ---- PROGRESS BAR ----
  var fillEl = document.getElementById('champProgressFill');
  function updateProgress() {
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var docH = document.documentElement.scrollHeight - window.innerHeight;
    var pct = docH > 0 ? Math.min(100, (scrollTop / docH) * 100) : 0;
    if (fillEl) fillEl.style.width = pct.toFixed(1) + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // ---- SIDEBAR NAVIGATION ACTIVE STATE (IntersectionObserver) ----
  var modules = document.querySelectorAll('[id^="champ-mod-"]');
  var navLinks = document.querySelectorAll('.champ-sidebar-nav [data-module]');

  if (modules.length && navLinks.length) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var id = entry.target.getAttribute('id');
          var modNum = id.replace('champ-mod-', '');
          navLinks.forEach(function(link) {
            if (link.getAttribute('data-module') === modNum) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });

    modules.forEach(function(mod) { observer.observe(mod); });
  }

  // ---- SMOOTH SCROLL ----
  document.querySelectorAll('a[href^="#champ-"]').forEach(function(anchor) {
    anchor.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

})();
</script>

</section>

