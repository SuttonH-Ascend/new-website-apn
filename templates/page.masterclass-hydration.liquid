<script>
(function() {
  // URL PARAM PARSER
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  const tierColor = tierColors[tierParam] || '#06A5C5';
  const tierName  = tierNames[tierParam]  || 'Athlete';

  // INJECT PERSONALIZATION
  const nameEl    = document.getElementById('apn-hydr-name-display');
  const scoreEl   = document.getElementById('apn-hydr-score-display');
  const badgeEl   = document.getElementById('apn-hydr-tier-badge');
  const m1ScoreEl = document.getElementById('apn-hydr-m1-score');
  const m3ScoreEl = document.getElementById('apn-hydr-m3-score');

  if (nameEl) nameEl.textContent = nameParam;
  if (scoreEl) scoreEl.textContent = scoreParam;
  if (m1ScoreEl) m1ScoreEl.textContent = scoreParam;
  if (m3ScoreEl) m3ScoreEl.textContent = scoreParam;

  if (badgeEl) {
    badgeEl.textContent = tierName;
    badgeEl.style.background = tierColor;
    badgeEl.style.color = '#fff';
  }

  // SCORE CONTEXT BLOCK
  const scoreCtxEl = document.getElementById('apn-hydr-score-context');
  if (scoreCtxEl) {
    let ctxHTML = '';
    if (scoreParam <= 39) {
      ctxHTML = '<div style="background:#FEF2F2;border-left:4px solid #EF4444;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#EF4444;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Significant Gap</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' means you are likely starting most training sessions 1 to 2% dehydrated. Your plasma volume is chronically below optimal. The 4 to 8% aerobic output penalty and 2 to 3% strength reduction from 2% dehydration are almost certainly active in your current training. Your urine is probably dark yellow most mornings and you feel the early-session fog consistently. This protocol closes that gap in 30 days if you execute it.</p></div>';
    } else if (scoreParam <= 59) {
      ctxHTML = '<div style="background:#FFFBEB;border-left:4px solid #F59E0B;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#F59E0B;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Moderate Gap</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' indicates your baseline water intake is inconsistent and your electrolyte protocol is likely absent or reactive rather than proactive. You are probably noticing performance drop-offs in longer sessions and in heat. The pre-training hydration window is almost certainly not being executed consistently. The protocol in Module 4 addresses all three of those specific gaps.</p></div>';
    } else if (scoreParam <= 74) {
      ctxHTML = '<div style="background:#F0FBFD;border-left:4px solid #06A5C5;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#06A5C5;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Optimization Zone</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' tells us you have the basics in place. Your gap shows up in precision: the pre-training window timing, intra-workout volume on high-intensity days, and the post-training replenishment speed. These three refinements are where your remaining performance gains live. The protocol gives you the exact targets for each window.</p></div>';
    } else if (scoreParam <= 89) {
      ctxHTML = '<div style="background:#F5F3FF;border-left:4px solid #8B5CF6;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#8B5CF6;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Advanced Precision Required</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' reflects strong baseline hydration habits. The remaining gap is at the precision level: sodium personalization based on sweat rate, differentiating intra-workout volume by session intensity, and the cellular hydration layer from creatine. These are the details that separate consistent high performance from peak performance on the days that matter most.</p></div>';
    } else {
      ctxHTML = '<div style="background:#F0FDF4;border-left:4px solid #22C55E;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#22C55E;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Maintenance and Protection</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' reflects an elite hydration system. Protect it. Verify it quarterly. The task is building disruption-proof protocols for travel, competition, and high-stress periods when your default system gets interrupted. The gap between 90 and 100 lives in consistency under adversity, not in the ideal-conditions protocol you have already built.</p></div>';
    }
    scoreCtxEl.innerHTML = ctxHTML;
  }

  // TIER-CONDITIONAL SHOW/HIDE
  document.querySelectorAll('.apn-tier-block-h').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // GAP2 CALLOUT
  if (gap2Param) {
    const gap2El = document.getElementById('apn-hydr-gap2-callout');
    const gap2TextEl = document.getElementById('apn-hydr-gap2-text');
    if (gap2El && gap2TextEl) {
      gap2El.style.display = 'block';
      const gap2Name = gap2Param.charAt(0).toUpperCase() + gap2Param.slice(1);
      let gap2Msg = 'Your secondary gap is ' + gap2Name + '. ';
      if (gap2Param.toLowerCase() === 'nutrition') {
        gap2Msg += 'Recharge (Creatine Monohydrate) addresses both gaps simultaneously: it increases intramuscular water retention for cellular hydration (Hydration gap) and increases phosphocreatine availability for high-intensity training output that demands greater protein synthesis (Nutrition gap). 5g daily serves both functions.';
      } else if (gap2Param.toLowerCase() === 'recovery') {
        gap2Msg += 'Replenish (Hydration Powder) directly bridges both gaps: plasma volume from electrolytes reduces cardiac workload and accelerates nutrient delivery to recovering muscle tissue (Recovery gap), while replacing sweat losses that impair neuromuscular function (Hydration gap). One product, two mechanisms.';
      } else if (gap2Param.toLowerCase() === 'stress') {
        gap2Msg += 'Chronic dehydration elevates cortisol output as a physiological stress response. Replenish (Hydration Powder) reduces that cortisol-elevating signal by restoring plasma volume and reducing the adrenal burden of fluid deficit. Addressing your Hydration gap directly supports your ' + gap2Name + ' gap through the cortisol pathway.';
      } else {
        gap2Msg += 'Replenish (Hydration Powder) supports both your Hydration gap (plasma volume, electrolytes, neuromuscular function) and your ' + gap2Name + ' gap through the downstream effects of improved cardiovascular efficiency, reduced cortisol, and better nutrient delivery to working tissues. One serving daily serves both functions.';
      }
      gap2TextEl.textContent = gap2Msg;
    }
  }

  // STICKY PROGRESS BAR + INTERSECTION OBSERVER
  const modules = ['apn-hydr-m0','apn-hydr-m1','apn-hydr-m2','apn-hydr-m3','apn-hydr-m4','apn-hydr-m5','apn-hydr-m6','apn-hydr-m7'];
  const dots = document.querySelectorAll('.apn-hydr-prog-dot');
  const navLinks = document.querySelectorAll('.apn-hydr-nav-link');

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        const idx = modules.indexOf(entry.target.id);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i <= idx); });
          navLinks.forEach(function(l, i) { l.classList.toggle('active', i === idx); });
          const sidebarFill = document.getElementById('apn-hydr-sidebar-fill');
          if (sidebarFill) {
            sidebarFill.style.height = ((idx / (modules.length - 1)) * 100) + '%';
          }
        }
      }
    });
  }, { threshold: 0.3 });

  modules.forEach(function(id) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

})();

// CHECKBOX SEVERITY
function apnHydrUpdateSeverity() {
  const checked = document.querySelectorAll('.apn-hydr-symptom:checked').length;
  const severityEl = document.getElementById('apn-hydr-severity');
  if (!severityEl) return;
  severityEl.style.display = 'block';
  if (checked <= 2) {
    severityEl.style.background = '#F0FDF4';
    severityEl.style.color = '#166534';
    severityEl.style.border = '1px solid #22C55E';
    severityEl.innerHTML = '<strong>Mild optimization gap (' + checked + '/7 symptoms).</strong> You are maintaining adequate hydration under baseline conditions. The gap shows up in high-demand scenarios: consecutive training days, heat, and long sessions. The protocol refines your existing habits rather than rebuilding from scratch.';
  } else if (checked <= 5) {
    severityEl.style.background = '#FFFBEB';
    severityEl.style.color = '#92400E';
    severityEl.style.border = '1px solid #F59E0B';
    severityEl.innerHTML = '<strong>Moderate gap (' + checked + '/7 symptoms).</strong> Your hydration is actively limiting your training ceiling. Multiple sub-gaps are compounding: low baseline, no electrolytes, and inadequate pre-training protocols are likely all present simultaneously. The 4-week protocol addresses each in sequence.';
  } else {
    severityEl.style.background = '#FEF2F2';
    severityEl.style.color = '#991B1B';
    severityEl.style.border = '1px solid #EF4444';
    severityEl.innerHTML = '<strong>Severe gap (' + checked + '/7 symptoms).</strong> Hydration is your primary performance constraint. You are training in a chronically dehydrated state that is penalizing your aerobic output, neuromuscular function, and recovery simultaneously. The performance you have been attributing to fitness limitations is partially a hydration problem. This is the most immediately correctable gap in your profile.';
  }
}

// SUB-GAP SELECTION
function apnHydrSelectSubgap(btn, subgapName) {
  document.querySelectorAll('.apn-hydr-subgap-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  const targetEl = document.getElementById('apn-hydr-primary-target');
  const targetTextEl = document.getElementById('apn-hydr-target-text');
  if (targetEl && targetTextEl) {
    targetEl.style.display = 'block';
    targetTextEl.textContent = 'Primary Target: ' + subgapName;
  }
}
</script>

