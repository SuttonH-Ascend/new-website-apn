      <div class="value-card">
        <div style="font-size:2rem;margin-bottom:1.25rem;line-height:1;">&#10013;&#65039;</div>
        <h3 style="font-family:Georgia,serif;font-size:1.25rem;font-weight:700;letter-spacing:-0.01em;color:#f0ede8;margin-bottom:0.75rem;">Faith</h3>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.45);line-height:1.7;margin-bottom:1.25rem;">Christ-centered ideology drives everything we create.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.8125rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:8px;"><span style="color:#06A5C5;font-size:0.625rem;">&#9679;</span>Character</li>
          <li style="font-size:0.8125rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:8px;"><span style="color:#06A5C5;font-size:0.625rem;">&#9679;</span>Discipline</li>
          <li style="font-size:0.8125rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:8px;"><span style="color:#06A5C5;font-size:0.625rem;">&#9679;</span>Courage</li>
          <li style="font-size:0.8125rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:8px;"><span style="color:#06A5C5;font-size:0.625rem;">&#9679;</span>Humility</li>
        </ul>
      </div>

