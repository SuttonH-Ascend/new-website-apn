<script>
(function() {
  // URL Param Parser
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  // Inject name, score, tier
  const nameEl = document.getElementById('apn-sleep-name');
  const scoreEl = document.getElementById('apn-sleep-score');
  const scoreDiagEl = document.getElementById('apn-sleep-score-display');
  const badgeEl = document.getElementById('apn-sleep-tier-badge');

  if (nameEl) nameEl.textContent = nameParam;
  if (scoreEl) scoreEl.textContent = scoreParam;
  if (scoreDiagEl) scoreDiagEl.textContent = scoreParam;
  if (badgeEl) {
    const color = tierColors[tierParam] || '#06A5C5';
    const name = tierNames[tierParam] || 'Athlete';
    badgeEl.textContent = name;
    badgeEl.style.background = color;
    badgeEl.style.color = '#FFFFFF';
  }

  // Score context injection
  const scoreContextEl = document.getElementById('apn-sleep-score-context');
  if (scoreContextEl) {
    let contextHTML = '';
    if (scoreParam <= 30) {
      contextHTML = '<div style="background:#FEF2F2; border-left:4px solid #EF4444; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' indicates significant sleep disruption affecting your recovery architecture. Your growth hormone pulse during slow-wave sleep is likely reduced by 30 to 40% based on this score profile, meaning your overnight muscle repair is operating at roughly 60 to 70% capacity regardless of what you train or eat. This is your primary performance constraint right now.</p></div>';
    } else if (scoreParam <= 50) {
      contextHTML = '<div style="background:#FFFBEB; border-left:4px solid #F59E0B; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' means your sleep system is functioning but not fully optimized. You are likely getting adequate hours but losing quality: insufficient slow-wave depth, inconsistent wake time, or elevated evening cortisol is compressing your GH pulse window. You are leaving 15 to 25% of your recovery potential on the table each night.</p></div>';
    } else if (scoreParam <= 70) {
      contextHTML = '<div style="background:#F0FBFF; border-left:4px solid #06A5C5; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' puts you in the moderate optimization zone. Your sleep basics are in place but one or two precision variables are holding back the ceiling. Likely candidates: your room temperature is 2 to 3 degrees too warm, your caffeine cutoff is too late, or your cortisol nadir timing is slightly off. These are small gaps with measurable impact when closed.</p></div>';
    } else if (scoreParam <= 85) {
      contextHTML = '<div style="background:#F5F3FF; border-left:4px solid #8B5CF6; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' is a strong baseline. Your sleep architecture is largely sound. What remains is precision: HRV trending consistently, N3 deep sleep duration above 90 minutes per night, and cortisol reaching nadir by 10:30pm. The gains here are real but require data to identify and close.</p></div>';
    } else {
      contextHTML = '<div style="background:#F0FDF4; border-left:4px solid #22C55E; padding:20px 24px; margin-bottom:24px; border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif; font-size:15px; color:#333333; line-height:1.65; margin:0;">A score of ' + scoreParam + ' indicates excellent sleep architecture. Your job now is maintenance and protection. Any sustained disruption cascades fast. This MasterClass is your maintenance protocol. Review it when life gets busy and your sleep habits start drifting.</p></div>';
    }
    scoreContextEl.innerHTML = contextHTML;
  }

  // Show tier blocks
  document.querySelectorAll('.apn-s-tier-block').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // Secondary gap callout
  if (gap2Param) {
    const gap2El = document.getElementById('apn-sleep-gap2-callout');
    const gap2TextEl = document.getElementById('apn-sleep-gap2-text');
    if (gap2El && gap2TextEl) {
      const gap2Name = gap2Param.charAt(0).toUpperCase() + gap2Param.slice(1);
      let overlap = '';
      if (gap2Param === 'stress') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Adapt (Ashwagandha) directly addresses both: it reduces sleep-disrupting evening cortisol for your sleep gap, and it modulates HPA axis reactivity for your stress gap. One product, two mechanisms.';
      } else if (gap2Param === 'recovery') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Function (Magnesium Glycinate) addresses both: GABA-A modulation for sleep onset, and magnesium is also a cofactor in over 300 enzymatic reactions including those involved in muscle repair and protein synthesis. Your recovery gap benefits from the same product.';
      } else if (gap2Param === 'focus') {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. The connection is direct: inadequate slow-wave sleep reduces brain-derived neurotrophic factor (BDNF) and dopamine receptor sensitivity, the two systems that drive focus and motivation. Closing your sleep gap is the most direct intervention for your focus gap. No additional product needed.';
      } else {
        overlap = 'Your secondary gap is <strong>' + gap2Name + '</strong>. Adapt (Ashwagandha) addresses cortisol management relevant to both your sleep quality and your ' + gap2Name.toLowerCase() + ' gap. It is the most efficient cross-gap product in your current stack.';
      }
      gap2TextEl.innerHTML = overlap;
      gap2El.style.display = 'block';
    }
  }

  // Checkbox severity logic
  var checkboxes = document.querySelectorAll('.apn-sleep-symptom');
  var severityEl = document.getElementById('apn-sleep-severity');

  function updateSeverity() {
    var count = 0;
    checkboxes.forEach(function(cb) { if (cb.checked) count++; });
    if (count === 0) {
      severityEl.style.display = 'none';
      return;
    }
    severityEl.style.display = 'block';
    if (count <= 2) {
      severityEl.style.background = '#F0FDF4';
      severityEl.style.color = '#166534';
      severityEl.style.borderLeft = '4px solid #22C55E';
      severityEl.textContent = count + ' of 7 checked. Mild optimization gap. You are maintaining but leaving sleep quality and performance on the table. The protocol ahead will close the remaining gap.';
    } else if (count <= 5) {
      severityEl.style.background = '#FFFBEB';
      severityEl.style.color = '#92400E';
      severityEl.style.borderLeft = '4px solid #F59E0B';
      severityEl.textContent = count + ' of 7 checked. Moderate gap. This is actively limiting your training ceiling. Your GH pulse, testosterone synthesis, and recovery architecture are all partially compromised. The 30-day protocol is exactly what you need.';
    } else {
      severityEl.style.background = '#FEF2F2';
      severityEl.style.color = '#991B1B';
      severityEl.style.borderLeft = '4px solid #EF4444';
      severityEl.textContent = count + ' of 7 checked. Severe gap. This is your primary performance constraint. Everything else you are doing for training, nutrition, and supplementation is running at reduced effectiveness until this closes. Work through this protocol without skipping anything.';
    }
  }
  checkboxes.forEach(function(cb) { cb.addEventListener('change', updateSeverity); });

  // IntersectionObserver for progress bar and sidebar
  var modules = ['apn-sleep-m0','apn-sleep-m1','apn-sleep-m2','apn-sleep-m3','apn-sleep-m4','apn-sleep-m5','apn-sleep-m6'];
  var dots = document.querySelectorAll('#apn-sleep-progress .apn-s-progress-dot');
  var sideItems = document.querySelectorAll('#apn-sleep-sidebar .apn-s-sidebar__item');

  var observerOptions = { root: null, rootMargin: '0px', threshold: 0.3 };
  var moduleObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var idx = modules.indexOf(entry.target.id);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i <= idx); });
          sideItems.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
        }
      }
    });
  }, observerOptions);

  modules.forEach(function(id) {
    var el = document.getElementById(id);
    if (el) moduleObserver.observe(el);
  });

  // FAB TOC
  var fab = document.getElementById('apn-sleep-fab');
  if (fab) {
    fab.addEventListener('click', function() {
      var moduleEl = document.getElementById('apn-sleep-m0');
      if (moduleEl) moduleEl.scrollIntoView({ behavior: 'smooth' });
    });
  }
})();

function apnSleepSelectSubgap(btn) {
  document.querySelectorAll('#apn-sleep-subgaps .apn-s-subgap-btn').forEach(function(b) {
    b.classList.remove('selected');
  });
  btn.classList.add('selected');
  var subgap = btn.dataset.subgap;
  var targetEl = document.getElementById('apn-sleep-primary-target');
  if (targetEl) {
    var labels = {
      onset: 'PRIMARY TARGET: Sleep Onset. Focus Weeks 1 and 2 on temperature, blue light elimination, and cortisol timing. Ashwagandha in Week 3 is your highest-leverage supplement.',
      maintenance: 'PRIMARY TARGET: Sleep Maintenance. Your cortisol rebound is waking you. Focus on eliminating alcohol, timing dinner 3 hours before bed, and ashwagandha in Week 3.',
      quality: 'PRIMARY TARGET: Sleep Quality. Your SWS depth is insufficient. Temperature is the highest leverage change. Alcohol elimination in Week 3 and magnesium glycinate will directly improve your N3 duration.',
      duration: 'PRIMARY TARGET: Sleep Duration. Your window is too short. Fixed wake time and bedtime alignment are Week 1 and 2 priorities. The protocol cannot work in 5 to 6 hour windows.'
    };
    targetEl.textContent = labels[subgap] || '';
    targetEl.style.display = 'block';
  }
}
</script>