<script>
(function() {
  const params = new URLSearchParams(window.location.search);
  const tier   = (params.get('tier')  || 'athlete').toLowerCase();
  const score  = parseInt(params.get('score') || '0', 10) || null;
  const name   = params.get('name') || '';

  const tierConfig = {
    rookie:     { label: 'Rookie',     cls: 'mc-tier-badge--rookie',     headline: 'Your Sleep Foundation Needs Work',       sub: 'The fundamentals are not locked in yet. Fix them first. Everything else follows.' },
    competitor: { label: 'Competitor', cls: 'mc-tier-badge--competitor', headline: 'Your Sleep Is the Gap Holding You Back',  sub: 'You are working too hard to leave recovery on the table. Close this gap in 30 days.' },
    athlete:    { label: 'Athlete',    cls: 'mc-tier-badge--athlete',    headline: 'Your Sleep Is Limiting Your Ceiling',     sub: 'You have the work ethic. Now build the recovery system that matches it.' },
    elite:      { label: 'Elite',      cls: 'mc-tier-badge--elite',      headline: 'Precision Sleep at the Elite Level',      sub: 'You are close to optimal. The variables that remain are small but they compound.' },
    champion:   { label: 'Champion',   cls: 'mc-tier-badge--champion',   headline: 'Champion-Level Sleep Maintenance',        sub: 'Protect what you have built. Compound at the margins. Mentor what you know.' }
  };

  const cfg = tierConfig[tier] || tierConfig.athlete;

  // Score
  var scoreEl = document.getElementById('mcScoreNum');
  if (scoreEl) scoreEl.textContent = score !== null ? score : '--';

  // Tier badge
  var badgeEl = document.getElementById('mcTierBadge');
  if (badgeEl) {
    badgeEl.textContent = cfg.label + ' Tier';
    badgeEl.className   = 'mc-tier-badge ' + cfg.cls;
  }

  // Headline + sub
  var hlEl = document.getElementById('mcHeadline');
  if (hlEl) hlEl.textContent = name ? name + ': ' + cfg.headline : cfg.headline;

  var subEl = document.getElementById('mcSubline');
  if (subEl) subEl.textContent = cfg.sub;

  // Cost intro (score-aware)
  var costEl = document.getElementById('mcCostIntro');
  if (costEl && score) {
    var gap = 100 - score;
    costEl.textContent = 'Your sleep score is ' + score + '/100. That is a ' + gap + '-point gap from optimal. Here is what that gap is costing you in the training room and everywhere else.';
  }

  // Protocol - show only this tier
  selectTier(tier);

  // Progress bar
  window.addEventListener('scroll', function() {
    var el = document.getElementById('apn-mc-sleep');
    if (!el) return;
    var rect = el.getBoundingClientRect();
    var total = el.offsetHeight - window.innerHeight;
    if (total <= 0) return;
    var scrolled = Math.max(0, -rect.top);
    var pct = Math.min(100, (scrolled / total) * 100);
    var bar = document.getElementById('mcProgressBar');
    if (bar) bar.style.width = pct + '%';
  }, { passive: true });
})();

function selectTier(t) {
  // Show/hide week cards
  var cards = document.querySelectorAll('#mcProtocol .mc-week-card');
  cards.forEach(function(c) {
    c.classList.toggle('visible', c.getAttribute('data-tier') === t);
  });
  // Update selector buttons
  var btns = document.querySelectorAll('#mcTierSelector .mc-tier-btn');
  btns.forEach(function(b) {
    b.classList.toggle('active', b.getAttribute('data-tier') === t);
  });
}
</script>
