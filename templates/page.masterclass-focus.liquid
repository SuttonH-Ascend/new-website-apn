<script>
(function() {
  // ========== URL PARAMS ==========
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  // ========== INJECT PERSONALIZATION ==========
  const tierColor = tierColors[tierParam] || '#06A5C5';
  const tierName = tierNames[tierParam] || 'Athlete';

  document.getElementById('apn-f-name-display').textContent = nameParam;
  document.getElementById('apn-f-score-display').textContent = scoreParam;

  const badge = document.getElementById('apn-f-tier-badge');
  badge.textContent = tierName;
  badge.style.background = tierColor;
  badge.style.color = tierParam === 'rookie' || tierParam === 'competitor' ? '#0D0D0D' : '#FFFFFF';

  document.getElementById('apn-f-m3-score').textContent = scoreParam;
  document.getElementById('apn-f-m3-tier').textContent = tierName;

  // ========== SCORE CONTEXT ==========
  const scoreCtx = document.getElementById('apn-f-score-context');
  let scoreText = '';
  if (scoreParam < 30) {
    scoreText = 'A score of ' + scoreParam + ' indicates severe cognitive performance impairment in a training context. Your dopaminergic system is likely blunted, producing low anticipatory drive. Adenosine accumulation is outpacing clearance, producing mental fatigue that precedes physical fatigue in sessions. Mitochondrial efficiency in neural tissue is low. The training is happening. The cognitive engagement required for skill acquisition and technique retention is significantly compromised.';
  } else if (scoreParam < 50) {
    scoreText = 'A score of ' + scoreParam + ' means your focus gap is actively limiting skill acquisition and training quality. Sessions start reasonably well and degrade. The second half of every session is your weakest cognitive window. Motivation requires external stimulants to feel adequate. The dopaminergic and adenosinergic systems are both under-optimized.';
  } else if (scoreParam < 70) {
    scoreText = 'A score of ' + scoreParam + ' places you in the functional but sub-optimal range. You can train with adequate focus but the second-half degradation is real and measurable. Motivation is inconsistent week to week. Skill acquisition is slower than your training volume would suggest it should be. The gap is in the precision of your neurochemical management, not the effort you are putting in.';
  } else if (scoreParam < 85) {
    scoreText = 'A score of ' + scoreParam + ' is solid cognitive performance. The remaining gap lives in the fine precision variables: caffeine timing, mitochondrial support, and the consistency of your pre-training focus ritual. Closing this gap will produce measurable improvements in skill acquisition rate and session focus duration.';
  } else {
    scoreText = 'A score of ' + scoreParam + ' is elite cognitive performance. The protocol in this page is maintenance and protection architecture. Protecting this level of focus performance across a full training season and competitive year is the target. One unmanaged period of adenosine debt or dopaminergic blunting can compress weeks of cognitive quality gains.';
  }
  scoreCtx.innerHTML = '<p class="apn-f-body">' + scoreText + '</p>';

  // ========== TIER SHOW/HIDE ==========
  document.querySelectorAll('.apn-tier-f-block').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // ========== GAP2 CALLOUT ==========
  if (gap2Param) {
    const gap2Block = document.getElementById('apn-f-gap2-callout');
    const gap2Text = document.getElementById('apn-f-gap2-text');
    gap2Block.style.display = 'block';

    const gap2Messages = {
      stress: 'Your secondary gap is Stress Management. Chronically elevated cortisol from HPA axis dysregulation directly impairs prefrontal cortex function, which governs sustained attention and cognitive control. Closing the focus gap and the stress gap together is significantly more effective than addressing either independently. Omega-3 is the highest-overlap product: DHA supports hippocampal negative feedback on the HPA axis (stress) and synaptic membrane integrity for cholinergic signaling (focus). One product, two mechanisms.',
      sleep: 'Your secondary gap is Sleep. Adenosine clears from neural tissue during slow-wave sleep. Poor sleep means you begin every day and every training session with a higher adenosine baseline than optimal. The caffeine timing protocol in Module 4 will improve your sleep quality, which in turn improves your baseline cognitive performance before any stimulant intervention.',
      recovery: 'Your secondary gap is Recovery. Omega-3 from the focus stack also addresses the downstream inflammation from training. DHA reduces neuroinflammation via neuroprotectin D1 synthesis. The same supplement that improves your synaptic membrane quality also reduces the inflammatory burden on neural tissue from hard training blocks.',
      nutrition: 'Your secondary gap is Nutrition. Choline, found in eggs and beef liver, is the dietary precursor to acetylcholine. If your nutrition is inconsistent, your acetylcholine availability for working memory and skill acquisition is inconsistent. Closing the nutrition gap directly improves the cholinergic substrate that your focus protocol depends on.',
      hydration: 'Your secondary gap is Hydration. A 2% dehydration state reduces cognitive performance and reaction time measurably, independent of physical fatigue. Ensuring proper hydration before training sessions is a zero-cost focus intervention. The pre-training ritual in Module 4 should include 16 to 20oz of water as step zero.',
      training: 'Your secondary gap is Training structure. Deliberate practice requires focus quality to encode effectively. Closing the focus gap first makes your training structure changes significantly more effective. Every technically demanding session produces more skill adaptation when executed with high attentional quality.',
      supplementation: 'Your secondary gap is Supplementation hierarchy. Clarity and Ignite are Tier 2 and Tier 3 supplements respectively. Before adding the focus stack, ensure your Tier 1 foundation is complete: creatine, protein, electrolytes. Foundation supplements create the physical substrate that cognitive performance runs on.'
    };

    gap2Text.textContent = gap2Messages[gap2Param.toLowerCase()] || 'Your secondary gap is ' + gap2Param + '. Omega-3 from the focus stack supports multiple performance gaps simultaneously through DHA-driven synaptic membrane optimization and EPA-driven anti-inflammatory action. It is the highest-overlap product for your secondary gap.';
  }

  // ========== PROGRESS BAR ==========
  window.addEventListener('scroll', function() {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    document.getElementById('apn-f-progress-fill').style.width = pct + '%';
  });

  // ========== MODULE DOT TRACKING ==========
  const moduleIds = ['apn-f-m0','apn-f-m1','apn-f-m2','apn-f-m3','apn-f-m4','apn-f-m5','apn-f-m6'];
  const dots = document.querySelectorAll('.apn-f-dot');
  const sidebarItems = document.querySelectorAll('.apn-f-sidebar-item');

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        const idx = moduleIds.indexOf(entry.target.id);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
          sidebarItems.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
        }
      }
    });
  }, { threshold: 0.3 });

  moduleIds.forEach(function(id) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
})();

// ========== CHECKBOX DIAGNOSIS ==========
function apnFToggleCheck(item) {
  const box = item.querySelector('.apn-f-checkbox-box');
  const check = box.querySelector('svg');
  const isChecked = box.classList.contains('checked');

  if (isChecked) {
    box.classList.remove('checked');
    check.style.display = 'none';
  } else {
    box.classList.add('checked');
    check.style.display = 'block';
  }

  const total = document.querySelectorAll('#apn-f-checkbox-list .apn-f-checkbox-box.checked').length;
  const display = document.getElementById('apn-f-severity-display');
  const label = document.getElementById('apn-f-severity-label');
  const text = document.getElementById('apn-f-severity-text');

  display.style.display = 'block';

  if (total <= 2) {
    display.style.background = '#DCFCE7';
    display.style.color = '#166534';
    label.textContent = total + ' of 7 symptoms: Mild Optimization Gap';
    text.textContent = 'You are maintaining cognitive performance but leaving precision on the table. The pre-training ritual and caffeine timing optimization from Module 4 will close the remaining gap and improve focus consistency.';
  } else if (total <= 5) {
    display.style.background = '#FEF3C7';
    display.style.color = '#92400E';
    label.textContent = total + ' of 7 symptoms: Moderate Gap';
    text.textContent = 'This gap is actively limiting your skill acquisition rate and training quality. Dopaminergic and adenosinergic system dysfunction is measurable in your session performance. The protocol will produce noticeable change within 2 weeks of consistent execution.';
  } else {
    display.style.background = '#FEE2E2';
    display.style.color = '#991B1B';
    label.textContent = total + ' of 7 symptoms: Severe Gap';
    text.textContent = 'This is your primary performance constraint. Cognitive energy, motivation, and attention quality are all significantly compromised. The training is going in. The neural adaptation is not coming out at the rate it should. Start the protocol today.';
  }
}

// ========== SUB-GAP SELECTION ==========
function apnFSelectSubgap(el, name) {
  document.querySelectorAll('.apn-f-subgap-option').forEach(function(opt) {
    opt.classList.remove('selected');
  });
  el.classList.add('selected');

  const targetDisplay = document.getElementById('apn-f-primary-target-display');
  const targetText = document.getElementById('apn-f-primary-target-text');
  targetDisplay.style.display = 'block';
  targetText.textContent = 'Your primary target is: ' + name + '. Module 4 addresses this sub-gap directly. The protocol and stack are designed to close it within 30 days of consistent execution.';
}
</script>

