<script>
(function() {
  'use strict';

  var params = new URLSearchParams(window.location.search);
  var scoreParam = parseInt(params.get('score') || '25');
  var nameParam = params.get('name') || 'Athlete';
  var gap1Param = params.get('gap1') || 'sleep';
  var gap2Param = params.get('gap2') || 'recovery';
  var gap3Param = params.get('gap3') || 'nutrition';

  /* ---- Welcome line ---- */
  var welcomeEl = document.getElementById('apn-r-welcome-line');
  if (welcomeEl) {
    welcomeEl.innerHTML = 'Welcome back, <strong>' + nameParam + '</strong>. Your overall score: <strong>' + scoreParam + '/100</strong>.';
  }

  /* ---- Score display ---- */
  var scoreEl = document.getElementById('apn-r-score-display');
  if (scoreEl) {
    scoreEl.textContent = scoreParam + '/100';
  }

  /* ---- Gap data map ---- */
  var gapData = {
    sleep: {
      label: 'Sleep',
      urgency: 'critical',
      cost: 'Inadequate sleep (below 7 hours) elevates cortisol chronically, reduces testosterone, impairs protein synthesis signaling, and cuts reaction time by 20 to 30%. At the Rookie tier, this gap is almost always the primary bottleneck because it degrades every other pillar simultaneously.',
      action: 'Sleeping below 7 hours per night is not a minor inefficiency. It is a biological tax on every other adaptation you are trying to drive. Fix this first.'
    },
    recovery: {
      label: 'Recovery',
      urgency: 'critical',
      cost: 'Insufficient recovery between training sessions means the adaptation signal from each session is being partially cancelled by the next session before the tissue repair cycle completes. Net result: you are training more and adapting less. Studies show that athletes training in a chronic state of under-recovery accumulate 40 to 60% less lean mass per training block compared to those who hit recovery markers.',
      action: 'Recovery is not rest. It is an active process requiring adequate protein, sleep, and hydration. All three need to be in place simultaneously.'
    },
    nutrition: {
      label: 'Nutrition',
      urgency: 'critical',
      cost: 'Protein below 0.7g per pound of bodyweight per day means the leucine threshold is not being hit consistently, muscle protein synthesis is sub-maximal, and recovery between sessions is impaired. Micronutrient gaps in a low-quality diet also directly affect hormone production, energy metabolism, and immune function.',
      action: 'Protein is the non-negotiable at this tier. Total calorie adequacy is the second priority. Micronutrient quality is the third. Build in that order.'
    },
    hydration: {
      label: 'Hydration',
      urgency: 'moderate',
      cost: 'A 2% reduction in body water causes a measurable decrease in strength, endurance, and cognitive performance. Chronic low-grade dehydration is common in athletes training intensely and not replacing losses. This compounds over the training week, degrading session quality cumulatively.',
      action: 'Target bodyweight in ounces divided by two as a daily minimum. Add 16 to 24oz per hour of training. Electrolytes matter when sweating is heavy.'
    },
    training: {
      label: 'Training Structure',
      urgency: 'critical',
      cost: 'Training without a structured program means progressive overload is not being applied consistently. Progressive overload is the mechanism that drives adaptation. Without it, the body has no reason to adapt. Random training produces random results. At the Rookie tier, this is often the gap that prevents any other improvement from sticking.',
      action: 'Choose one program. Follow it for 8 weeks minimum before assessing. Log every session. The program is not the variable. Your execution of it is.'
    },
    mental: {
      label: 'Mental Performance',
      urgency: 'moderate',
      cost: 'Psychological stress activates the same cortisol pathway as physical stress. Athletes carrying chronic mental stress are operating with elevated cortisol baseline, which directly inhibits recovery, reduces sleep quality, and reduces testosterone. The mental performance gap at the Rookie tier is usually unmanaged daily stress compounding physical training load.',
      action: 'Stress management is not soft. It is biochemistry. A 10-minute breathing protocol (box breathing: 4 seconds in, 4 hold, 4 out, 4 hold) has demonstrated measurable cortisol reduction in multiple controlled studies.'
    },
    stress: {
      label: 'Stress Management',
      urgency: 'moderate',
      cost: 'Unmanaged stress chronically elevates cortisol, directly opposing the anabolic signals from training and nutrition. This creates a situation where the athlete is doing the right physical work but the biochemical environment is actively working against adaptation. The gap is real and measurable.',
      action: 'Identify your top two stress sources. Address one with a specific behavioral change this week. Acknowledge the second. The awareness alone reduces its physiological impact.'
    },
    supplements: {
      label: 'Supplementation',
      urgency: 'manageable',
      cost: 'No supplement foundation means the training and recovery you are already doing is not being optimally supported. Creatine alone can improve high-intensity output by 10 to 20% when stores are fully saturated. Post-training protein timing can increase net muscle protein balance by up to 33% compared to untimed intake. These are not marginal gains at this tier.',
      action: 'Start with creatine and post-training protein. Both are available, inexpensive, and backed by the deepest evidence base in sports nutrition. Do not add more until these two are locked in.'
    }
  };

  var urgencyLabels = {
    critical: 'Critical',
    moderate: 'Moderate',
    manageable: 'Manageable'
  };
  var urgencyClass = {
    critical: 'gap-urgency--critical',
    moderate: 'gap-urgency--moderate',
    manageable: 'gap-urgency--manageable'
  };

  function getGapInfo(key) {
    return gapData[key] || {
      label: key.charAt(0).toUpperCase() + key.slice(1),
      urgency: 'moderate',
      cost: 'This gap is affecting your performance output. Review the dedicated MasterClass page for a full protocol.',
      action: 'Address this gap with a specific behavioral protocol. See the dedicated MasterClass for detail.'
    };
  }

  function buildGapCard(gapKey, index) {
    var info = getGapInfo(gapKey);
    var priority = ['PRIMARY', 'SECONDARY', 'TERTIARY'][index];
    var url = '/pages/masterclass-' + gapKey.toLowerCase().replace(/\s+/g, '-');
    return '<div class="apn-r-gap-card">' +
      '<div class="gap-meta">' +
        '<span class="gap-name">' + priority + ': ' + info.label + '</span>' +
        '<span class="gap-urgency ' + urgencyClass[info.urgency] + '">' + urgencyLabels[info.urgency] + '</span>' +
      '</div>' +
      '<p>' + info.cost + '</p>' +
      '<p style="color:var(--body); font-weight:600;">' + info.action + '</p>' +
      '<a href="' + url + '">Go to ' + info.label + ' MasterClass &rarr;</a>' +
    '</div>';
  }

  var gaps = [gap1Param, gap2Param, gap3Param];

  /* ---- Gap snapshot cards ---- */
  var gapContainer = document.getElementById('apn-r-gap-container');
  if (gapContainer) {
    var html = '';
    for (var i = 0; i < gaps.length; i++) {
      html += buildGapCard(gaps[i], i);
    }
    gapContainer.innerHTML = html;
  }

  /* ---- Gap link cards (Module 7) ---- */
  var gapLinks = document.getElementById('apn-r-gap-links');
  if (gapLinks) {
    var linkHtml = '<div style="display:grid; gap:16px;">';
    for (var j = 0; j < gaps.length; j++) {
      var info = getGapInfo(gaps[j]);
      var url = '/pages/masterclass-' + gaps[j].toLowerCase().replace(/\s+/g, '-');
      var priority = ['Gap 1: Primary', 'Gap 2: Secondary', 'Gap 3: Tertiary'][j];
      var desc = ['This is your highest-priority gap. Start here.', 'Address after Gap 1 is showing improvement.', 'Third in order. It will benefit from the other two being addressed first.'][j];
      linkHtml += '<a href="' + url + '" class="apn-r-next-card">' +
        '<span class="next-card-label">' + priority + '</span>' +
        '<div class="next-card-title">' + info.label + ' MasterClass</div>' +
        '<p class="next-card-desc">' + desc + '</p>' +
      '</a>';
    }
    linkHtml += '</div>';
    gapLinks.innerHTML = linkHtml;
  }

})();
</script>

