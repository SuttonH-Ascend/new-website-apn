<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Barlow+Condensed:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'Barlow',system-ui,sans-serif;background:#0a0a0a;color:#F8FAFB;overflow-x:hidden;}

  /* Nav */
  #main-nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,10,10,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.06);}
  #main-nav.solid{background:rgba(10,10,10,0.98);}
  .nav-link{font-family:'Barlow',sans-serif;font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.65);text-decoration:none;letter-spacing:0.02em;transition:color 0.18s ease;}
  .nav-link:hover{color:#fff;}
  .nav-link:focus-visible{outline:2px solid #06A5C5;outline-offset:4px;border-radius:2px;}
  .btn-nav{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8125rem;letter-spacing:0.12em;text-transform:uppercase;background:linear-gradient(135deg,#048FAB,#06A5C5);color:#fff;padding:0.5rem 1.25rem;border-radius:4px;text-decoration:none;transition:transform 0.18s ease,box-shadow 0.18s ease;}
  .btn-nav:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(6,165,197,0.4);}
  .btn-nav:active{transform:translateY(0);}
  .btn-nav:focus-visible{outline:2px solid #06A5C5;outline-offset:3px;}
  .hidden-mobile{display:flex;}
  .show-mobile{display:none;}
  @media(max-width:900px){.hidden-mobile{display:none!important;}.show-mobile{display:flex!important;}}

  /* Mobile menu */
  #mobile-menu{position:fixed;top:64px;left:0;right:0;z-index:99;background:rgba(10,10,10,0.98);backdrop-filter:blur(16px);padding:1.5rem;display:none;flex-direction:column;gap:0.25rem;border-bottom:1px solid rgba(255,255,255,0.08);}
  #mobile-menu.open{display:flex;}
  .mobile-nav-link{font-size:1rem;font-weight:500;color:rgba(255,255,255,0.75);text-decoration:none;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);}
  .mobile-nav-link:hover{color:#06A5C5;}

  /* Policy content styling */
  .policy-body h1,.policy-body h2,.policy-body h3,.policy-body h4{font-family:Georgia,serif;font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin-top:2rem;margin-bottom:0.875rem;}
  .policy-body h1{font-size:2rem;}
  .policy-body h2{font-size:1.5rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.08);}
  .policy-body h3{font-size:1.125rem;}
  .policy-body p{font-size:0.9375rem;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:1.25rem;}
  .policy-body ul,.policy-body ol{font-size:0.9375rem;color:rgba(255,255,255,0.65);line-height:1.8;margin-bottom:1.25rem;padding-left:1.5rem;}
  .policy-body li{margin-bottom:0.5rem;}
  .policy-body a{color:#06A5C5;text-decoration:underline;text-underline-offset:3px;}
  .policy-body a:hover{color:#D6F0F6;}
  .policy-body strong{color:rgba(255,255,255,0.85);font-weight:600;}
  .policy-body blockquote{border-left:3px solid #06A5C5;padding-left:1.25rem;margin:1.5rem 0;color:rgba(255,255,255,0.5);font-style:italic;}

  /* Footer */
  .footer-link{font-size:0.875rem;color:rgba(255,255,255,0.45);text-decoration:none;transition:color 0.18s ease;}
  .footer-link:hover{color:#06A5C5;}
  .footer-link:focus-visible{outline:2px solid #06A5C5;outline-offset:2px;border-radius:2px;}

  @media(max-width:900px){
    #footer-grid{grid-template-columns:1fr 1fr!important;}
  }
  @media(max-width:600px){
    #footer-grid{grid-template-columns:1fr!important;}
  }
</style>

<!-- NAV -->
{% render 'nav' %}

<!-- HERO -->
<section style="position:relative;overflow:hidden;padding:8rem 1.5rem 4rem;text-align:center;background:linear-gradient(160deg,#080808 0%,#081218 55%,#080808 100%);">
  <div style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true">
    <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:800px;height:400px;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(6,165,197,0.07) 0%,transparent 70%);"></div>
  </div>
  <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:1rem;">
      <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
      <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#06A5C5;">Legal</span>
      <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
    </div>
    <h1 style="font-family:Georgia,serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:700;letter-spacing:-0.03em;line-height:1.05;color:#f0ede8;margin-bottom:1rem;">{{ policy.title }}</h1>
    {%- if policy.updated_at -%}
      <p style="font-size:0.875rem;color:rgba(255,255,255,0.35);">Last updated: {{ policy.updated_at | date: '%B %d, %Y' }}</p>
    {%- endif -%}
  </div>
</section>

<!-- POLICY NAV TABS -->
<div style="background:#0f0f0f;border-bottom:1px solid rgba(255,255,255,0.07);position:sticky;top:64px;z-index:50;">
  <div style="max-width:960px;margin:0 auto;padding:0 1.5rem;display:flex;gap:0;overflow-x:auto;">
    <a href="{{ routes.root_url }}policies/privacy-policy" style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);text-decoration:none;padding:1rem 1.25rem;border-bottom:2px solid transparent;white-space:nowrap;transition:color 0.18s ease,border-color 0.18s ease;{% if policy.title contains 'Privacy' %}color:#06A5C5;border-bottom-color:#06A5C5;{% endif %}" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='{% if policy.title contains 'Privacy' %}#06A5C5{% else %}rgba(255,255,255,0.5){% endif %}'">Privacy Policy</a>
    <a href="{{ routes.root_url }}policies/terms-of-service" style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);text-decoration:none;padding:1rem 1.25rem;border-bottom:2px solid transparent;white-space:nowrap;transition:color 0.18s ease,border-color 0.18s ease;{% if policy.title contains 'Terms' %}color:#06A5C5;border-bottom-color:#06A5C5;{% endif %}" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='{% if policy.title contains 'Terms' %}#06A5C5{% else %}rgba(255,255,255,0.5){% endif %}'">Terms of Service</a>
    <a href="{{ routes.root_url }}policies/shipping-policy" style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);text-decoration:none;padding:1rem 1.25rem;border-bottom:2px solid transparent;white-space:nowrap;transition:color 0.18s ease,border-color 0.18s ease;{% if policy.title contains 'Shipping' %}color:#06A5C5;border-bottom-color:#06A5C5;{% endif %}" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='{% if policy.title contains 'Shipping' %}#06A5C5{% else %}rgba(255,255,255,0.5){% endif %}'">Shipping Policy</a>
    <a href="{{ routes.root_url }}policies/refund-policy" style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);text-decoration:none;padding:1rem 1.25rem;border-bottom:2px solid transparent;white-space:nowrap;transition:color 0.18s ease,border-color 0.18s ease;{% if policy.title contains 'Refund' or policy.title contains 'Return' %}color:#06A5C5;border-bottom-color:#06A5C5;{% endif %}" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='{% if policy.title contains 'Refund' or policy.title contains 'Return' %}#06A5C5{% else %}rgba(255,255,255,0.5){% endif %}'">Refund Policy</a>
  </div>
</div>

<!-- POLICY CONTENT -->
<section style="padding:4rem 1.5rem 6rem;">
  <div style="max-width:760px;margin:0 auto;">
    <div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:3rem 3.5rem;" class="policy-body">
      {{ policy.body }}
    </div>

    <!-- Contact prompt -->
    <div style="margin-top:3rem;padding:2rem;background:#131313;border:1px solid rgba(6,165,197,0.15);border-radius:12px;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:220px;">
        <p style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#06A5C5;margin-bottom:0.375rem;">Questions?</p>
        <p style="font-size:0.9rem;color:rgba(255,255,255,0.55);line-height:1.6;">If you have any questions about this policy, our team is happy to help.</p>
      </div>
      <a href="/pages/contact-us" style="font-family:'Barlow Condensed',sans-serif;font-size:0.8125rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;background:linear-gradient(135deg,#048FAB,#06A5C5);color:#fff;padding:0.75rem 1.5rem;border-radius:5px;text-decoration:none;white-space:nowrap;transition:transform 0.18s ease,box-shadow 0.18s ease;" onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 20px rgba(6,165,197,0.35)'" onmouseout="this.style.transform='';this.style.boxShadow=''">Contact Us</a>
    </div>

    <!-- Quick links to other policies -->
    <div style="margin-top:2rem;">
      <p style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:1rem;">Other Policies</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
        {%- unless policy.title contains 'Privacy' -%}
          <a href="{{ routes.root_url }}policies/privacy-policy" style="font-size:0.875rem;color:rgba(255,255,255,0.45);text-decoration:none;padding:0.5rem 1rem;border:1px solid rgba(255,255,255,0.1);border-radius:6px;transition:border-color 0.18s ease,color 0.18s ease;" onmouseover="this.style.borderColor='rgba(6,165,197,0.4)';this.style.color='#06A5C5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.45)'">Privacy Policy</a>
        {%- endunless -%}
        {%- unless policy.title contains 'Terms' -%}
          <a href="{{ routes.root_url }}policies/terms-of-service" style="font-size:0.875rem;color:rgba(255,255,255,0.45);text-decoration:none;padding:0.5rem 1rem;border:1px solid rgba(255,255,255,0.1);border-radius:6px;transition:border-color 0.18s ease,color 0.18s ease;" onmouseover="this.style.borderColor='rgba(6,165,197,0.4)';this.style.color='#06A5C5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.45)'">Terms of Service</a>
        {%- endunless -%}
        {%- unless policy.title contains 'Shipping' -%}
          <a href="{{ routes.root_url }}policies/shipping-policy" style="font-size:0.875rem;color:rgba(255,255,255,0.45);text-decoration:none;padding:0.5rem 1rem;border:1px solid rgba(255,255,255,0.1);border-radius:6px;transition:border-color 0.18s ease,color 0.18s ease;" onmouseover="this.style.borderColor='rgba(6,165,197,0.4)';this.style.color='#06A5C5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.45)'">Shipping Policy</a>
        {%- endunless -%}
        {%- unless policy.title contains 'Refund' or policy.title contains 'Return' -%}
          <a href="{{ routes.root_url }}policies/refund-policy" style="font-size:0.875rem;color:rgba(255,255,255,0.45);text-decoration:none;padding:0.5rem 1rem;border:1px solid rgba(255,255,255,0.1);border-radius:6px;transition:border-color 0.18s ease,color 0.18s ease;" onmouseover="this.style.borderColor='rgba(6,165,197,0.4)';this.style.color='#06A5C5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.45)'">Refund Policy</a>
        {%- endunless -%}
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
{% render 'footer' %}

<script>
  window.addEventListener('scroll', function() {
    var nav = document.getElementById('main-nav');
    if (nav && window.scrollY > 20) { nav.classList.add('solid'); } else if (nav) { nav.classList.remove('solid'); }
  }, {passive: true});
  window.toggleMenu = function() {
    var m = document.getElementById('mobile-menu');
    var h = document.getElementById('hamburger');
    var open = m.classList.toggle('open');
    h.setAttribute('aria-expanded', open ? 'true' : 'false');
  };
  window.closeMenu = function() {
    document.getElementById('mobile-menu').classList.remove('open');
    document.getElementById('hamburger').setAttribute('aria-expanded','false');
  };
</script>
