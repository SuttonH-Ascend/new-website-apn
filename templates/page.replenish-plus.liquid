<script>
// Klaviyo subscribe API integration
// Public API Key: R5eNpH | List ID: SgFsmv (Replenish Plus Research Report)
const KLAVIYO_PUBLIC_KEY = 'R5eNpH';
const KLAVIYO_LIST_ID = 'SgFsmv';

async function subscribeToKlaviyo(email) {
  const payload = {
    data: {
      type: 'subscription',
      attributes: {
        profile: {
          data: {
            type: 'profile',
            attributes: {
              email: email,
              properties: {
                source: 'Replenish Plus Advertorial',
                campaign: '2026-03-20-replenish-plus-cold-launch',
                lead_magnet: 'Electrolyte Creatine Research Report'
              }
            }
          }
        }
      },
      relationships: {
        list: {
          data: {
            type: 'list',
            id: KLAVIYO_LIST_ID
          }
        }
      }
    }
  };

  const response = await fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'revision': '2023-12-15'
    },
    body: JSON.stringify(payload)
  });

  return response.status === 202 || response.ok;
}

async function handleSubmit(event, position) {
  event.preventDefault();

  const isBottom = position === 'bottom';
  const emailId = isBottom ? 'emailInputBottom' : 'emailInput';
  const formId = isBottom ? 'captureFormBottom' : 'captureForm';
  const successId = isBottom ? 'captureSuccessBottom' : 'captureSuccess';
  const submitBtnId = isBottom ? null : 'submitBtn';

  const email = document.getElementById(emailId).value;
  const form = document.getElementById(formId);
  const successEl = document.getElementById(successId);

  // Disable form during submission
  const btn = form.querySelector('button');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  try {
    const success = await subscribeToKlaviyo(email);
    if (success) {
      form.style.display = 'none';
      successEl.style.display = 'block';
      // If top form, also hide bottom form to avoid duplicate (optional)
      if (!isBottom) {
        const bottomSection = document.getElementById('report-capture-bottom');
        if (bottomSection) bottomSection.style.display = 'none';
      }
    } else {
      btn.disabled = false;
      btn.textContent = 'Send Me The Report';
      alert('Something went wrong. Please try again.');
    }
  } catch (error) {
    btn.disabled = false;
    btn.textContent = 'Send Me The Report';
    console.error('Subscription error:', error);
    alert('Something went wrong. Please try again.');
  }
}
</script>

