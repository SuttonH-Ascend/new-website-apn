      <div style="height:1px;width:40px;background:#06A5C5;opacity:0.55;"></div>
      <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#06A5C5;">We're Hiring</span>
      <div style="height:1px;width:40px;background:#06A5C5;opacity:0.55;"></div>
    </div>
    <h1 style="font-family:Georgia,serif;font-size:clamp(2.75rem,7vw,5rem);font-weight:700;letter-spacing:-0.03em;line-height:1.02;color:#f0ede8;margin-bottom:1.25rem;">Join the Mission</h1>
    <p style="font-size:1.125rem;color:rgba(255,255,255,0.45);font-weight:300;line-height:1.75;max-width:560px;margin:0 auto 2.5rem;">We're building the premier faith-driven performance nutrition brand in the world. If that mission resonates with you, we'd love to work together.</p>
    <a href="#open-roles" style="font-family:'Barlow Condensed',sans-serif;font-size:0.8125rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;background:linear-gradient(135deg,#048FAB,#06A5C5);color:#fff;padding:0.875rem 2rem;border-radius:5px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 6px 24px rgba(6,165,197,0.25);transition:transform 0.18s ease,box-shadow 0.18s ease;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 32px rgba(6,165,197,0.4)'" onmouseout="this.style.transform='';this.style.boxShadow='0 6px 24px rgba(6,165,197,0.25)'">View Open Roles &darr;</a>
  </div>
