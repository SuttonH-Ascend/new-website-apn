<!-- APPLICATION MODAL -->
<div id="apply-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title" onclick="handleOverlayClick(event)">
  <div id="apply-modal">
    <button onclick="closeApply()" aria-label="Close application form" style="position:absolute;top:1.25rem;right:1.25rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:50%;width:36px;height:36px;cursor:pointer;color:rgba(255,255,255,0.6);font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background 0.18s ease,color 0.18s ease;" onmouseover="this.style.background='rgba(255,255,255,0.12)';this.style.color='#fff'" onmouseout="this.style.background='rgba(255,255,255,0.06)';this.style.color='rgba(255,255,255,0.6)'">&times;</button>

    <div id="apply-form-wrap">
      <div style="margin-bottom:2rem;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:0.875rem;">
          <div style="height:1px;width:24px;background:#06A5C5;opacity:0.55;"></div>
          <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#06A5C5;">Application</span>
        </div>
        <h2 id="modal-title" style="font-family:Georgia,serif;font-size:1.625rem;font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin-bottom:0.375rem;">Apply for <span id="modal-role-name" style="color:#06A5C5;">this Role</span></h2>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.4);line-height:1.6;">We read every application personally. Be specific and be yourself.</p>
      </div>

      <form id="apply-form" action="/contact#application-form" method="post" accept-charset="UTF-8" novalidate>
        <input type="hidden" name="form_type" value="contact"/>
        <input type="hidden" name="utf8" value="&#x2713;"/>
        <input type="hidden" id="hidden-role" name="contact[Role]" value=""/>

        <div class="form-grid">

          <div class="form-grid form-grid-2">
            <div>
              <label for="field-name" class="form-label">Full Name <span style="color:#06A5C5;">*</span></label>
              <input type="text" id="field-name" name="contact[name]" class="form-input" placeholder="John Smith" required autocomplete="name"/>
            </div>
            <div>
              <label for="field-email" class="form-label">Email <span style="color:#06A5C5;">*</span></label>
              <input type="email" id="field-email" name="contact[email]" class="form-input" placeholder="you@email.com" required autocomplete="email"/>
            </div>
          </div>

          <div class="form-grid form-grid-2">
            <div>
              <label for="field-phone" class="form-label">Phone Number</label>
              <input type="tel" id="field-phone" name="contact[Phone]" class="form-input" placeholder="(555) 000-0000" autocomplete="tel"/>
            </div>
            <div>
              <label for="field-location" class="form-label">City, State</label>
              <input type="text" id="field-location" name="contact[Location]" class="form-input" placeholder="Nashville, TN" autocomplete="address-level2"/>
            </div>
          </div>

          <div>
            <label for="field-links" class="form-label">LinkedIn or Portfolio URL</label>
            <input type="url" id="field-links" name="contact[LinkedIn / Portfolio]" class="form-input" placeholder="https://linkedin.com/in/yourname"/>
          </div>

          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:0.25rem;">
            <p style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.3);">Tell Us About Yourself</p>
          </div>

          <div>
            <label for="field-why" class="form-label">Why do you want to join Ascend? <span style="color:#06A5C5;">*</span></label>
            <textarea id="field-why" name="contact[Why Ascend]" class="form-input" placeholder="What is it about this mission that resonates with you? Be specific." required style="min-height:110px;"></textarea>
          </div>

          <div>
            <label for="field-experience" class="form-label">Relevant Experience <span style="color:#06A5C5;">*</span></label>
            <textarea id="field-experience" name="contact[Relevant Experience]" class="form-input" placeholder="Tell us about your background, skills, and any relevant work you've done." required style="min-height:110px;"></textarea>
          </div>

          <div>
            <label for="field-faith" class="form-label">Faith + Fitness Background <span style="color:rgba(255,255,255,0.3);font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span></label>
            <textarea id="field-faith" name="contact[Faith and Fitness Background]" class="form-input" placeholder="Do you compete in a sport? How does your faith inform how you train or work? This is not required, but it helps us understand who you are." style="min-height:90px;"></textarea>
          </div>

          <div>
            <label for="field-source" class="form-label">How did you hear about us?</label>
            <select id="field-source" name="contact[How Did You Hear About Us]" class="form-input">
              <option value="" disabled selected>Select one...</option>
              <option value="Instagram">Instagram</option>
              <option value="Facebook">Facebook</option>
              <option value="TikTok">TikTok</option>
              <option value="Friend / Teammate">Friend / Teammate</option>
              <option value="Church / Community">Church / Community</option>
              <option value="Google Search">Google Search</option>
              <option value="Podcast">Podcast</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <button type="submit" id="apply-submit" class="form-submit">Submit Application &rarr;</button>
            <p style="font-size:0.8125rem;color:rgba(255,255,255,0.3);text-align:center;margin-top:0.875rem;line-height:1.6;">By submitting, you agree to our <a href="{{ routes.root_url }}policies/privacy-policy" style="color:#06A5C5;text-decoration:underline;" target="_blank">Privacy Policy</a>. We'll respond within 3-5 business days.</p>
          </div>

        </div>
      </form>
    </div>

    <div id="apply-success">
      <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,rgba(6,165,197,0.15),rgba(6,165,197,0.06));border:1px solid rgba(6,165,197,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 style="font-family:Georgia,serif;font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin-bottom:0.75rem;">Application Received</h3>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.5);line-height:1.75;max-width:380px;margin:0 auto 0.75rem;">"Whatever you do, work at it with all your heart, as working for the Lord." - Col 3:23</p>
      <p style="font-size:0.875rem;color:rgba(255,255,255,0.35);margin-bottom:2rem;">We read every application personally and will be in touch within 3-5 business days.</p>
      <button onclick="closeApply()" class="apply-btn" style="margin:0 auto;">Back to Careers</button>
    </div>
  </div>
</div>

<!-- HERO -->
<section style="position:relative;overflow:hidden;padding:9rem 1.5rem 7rem;text-align:center;background:linear-gradient(160deg,#080808 0%,#081218 55%,#080808 100%);">
  <div style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true">
    <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:1000px;height:600px;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(6,165,197,0.1) 0%,transparent 70%);"></div>
