<!-- CULTURE / VALUES -->
<section style="padding:6rem 1.5rem;background:#0d0d0d;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:3.5rem;">
      <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:1rem;">
        <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#06A5C5;">Culture</span>
        <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
      </div>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.875rem,4vw,2.875rem);font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin-bottom:0.75rem;">How We Operate</h2>
      <p style="font-size:1rem;color:rgba(255,255,255,0.4);max-width:500px;margin:0 auto;line-height:1.7;">We're not just a supplement company. We're a mission-driven team built on three uncompromising principles.</p>
    </div>

    <div class="values-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">

      <div class="values-card">
        <div style="display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:12px;background:linear-gradient(135deg,rgba(6,165,197,0.12),rgba(4,143,171,0.06));border:1px solid rgba(6,165,197,0.2);margin-bottom:1.25rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 2l1.5 4.5H18l-3.75 2.75 1.5 4.75L12 11.5l-3.75 2.5 1.5-4.75L6 6.5h4.5z"/><path d="M12 14v8"/></svg>
        </div>
        <h3 style="font-family:Georgia,serif;font-size:1.25rem;font-weight:700;letter-spacing:-0.01em;color:#F8FAFB;margin-bottom:0.75rem;">Faith-Driven</h3>
        <p style="font-size:0.9rem;color:rgba(255,255,255,0.45);line-height:1.75;margin-bottom:1.25rem;">Everything we build is filtered through a Christ-centered worldview. Our values aren't a marketing angle - they're the foundation of every decision we make, from product formulation to how we treat customers.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
