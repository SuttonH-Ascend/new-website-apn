<script>
  window.toggleMenu = function() {
    var m = document.getElementById('mobile-menu');
    var h = document.getElementById('hamburger');
    var open = m.classList.toggle('open');
    h.setAttribute('aria-expanded', open ? 'true' : 'false');
  };
  window.closeMenu = function() {
    document.getElementById('mobile-menu').classList.remove('open');
    document.getElementById('hamburger').setAttribute('aria-expanded','false');
  };
  window.addEventListener('scroll', function() {
    var nav = document.getElementById('main-nav');
    if (window.scrollY > 20) { nav.classList.add('solid'); } else { nav.classList.remove('solid'); }
  }, {passive: true});

  window.openApply = function(role) {
    document.getElementById('modal-role-name').textContent = role;
    document.getElementById('hidden-role').value = role;
    document.getElementById('apply-form-wrap').style.display = '';
    document.getElementById('apply-success').style.display = 'none';
    document.getElementById('apply-form').reset();
    document.getElementById('hidden-role').value = role;
    var overlay = document.getElementById('apply-overlay');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(function(){ document.getElementById('field-name').focus(); }, 320);
  };

  window.closeApply = function() {
    document.getElementById('apply-overlay').classList.remove('open');
    document.body.style.overflow = '';
  };

  window.handleOverlayClick = function(e) {
    if (e.target === document.getElementById('apply-overlay')) { closeApply(); }
  };

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeApply(); }
  });

  document.getElementById('apply-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = document.getElementById('apply-submit');

    var name = document.getElementById('field-name').value.trim();
    var email = document.getElementById('field-email').value.trim();
    var why = document.getElementById('field-why').value.trim();
    var exp = document.getElementById('field-experience').value.trim();
    var role = document.getElementById('hidden-role').value;

    if (!name || !email || !why || !exp) {
      var missing = [];
      if (!name) missing.push('Full Name');
      if (!email) missing.push('Email');
      if (!why) missing.push('Why Ascend?');
      if (!exp) missing.push('Relevant Experience');
      alert('Please complete: ' + missing.join(', '));
      return;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert('Please enter a valid email address.');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';

    var body = new URLSearchParams();
    body.append('form_type', 'contact');
    body.append('utf8', '\u2713');
    body.append('contact[name]', name);
    body.append('contact[email]', email);
    body.append('contact[body]',
      'CAREER APPLICATION - ' + role + '\n\n' +
      'Name: ' + name + '\n' +
      'Email: ' + email + '\n' +
      'Phone: ' + document.getElementById('field-phone').value + '\n' +
      'Location: ' + document.getElementById('field-location').value + '\n' +
      'LinkedIn / Portfolio: ' + document.getElementById('field-links').value + '\n\n' +
      '--- WHY ASCEND ---\n' + why + '\n\n' +
      '--- RELEVANT EXPERIENCE ---\n' + exp + '\n\n' +
      '--- FAITH + FITNESS BACKGROUND ---\n' + document.getElementById('field-faith').value + '\n\n' +
      '--- HOW THEY HEARD ---\n' + document.getElementById('field-source').value
    );

    fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body.toString()
    })
    .then(function() {
      document.getElementById('apply-form-wrap').style.display = 'none';
      document.getElementById('apply-success').style.display = 'block';
    })
    .catch(function() {
      document.getElementById('apply-form-wrap').style.display = 'none';
      document.getElementById('apply-success').style.display = 'block';
    });
  });
</script>
