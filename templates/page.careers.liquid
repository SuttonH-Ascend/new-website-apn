      <div class="values-card">
        <div style="display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:12px;background:linear-gradient(135deg,rgba(6,165,197,0.12),rgba(4,143,171,0.06));border:1px solid rgba(6,165,197,0.2);margin-bottom:1.25rem;">
