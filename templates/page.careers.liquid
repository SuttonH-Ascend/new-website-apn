  .values-card:hover{border-color:rgba(6,165,197,0.35);transform:translateY(-4px);box-shadow:0 16px 48px rgba(6,165,197,0.08);}

  /* Position cards */
  .position-card{background:#fff;border:1px solid #E2E8F0;border-radius:12px;padding:2rem 2.25rem;transition:border-color 0.2s ease,box-shadow 0.2s ease;}
  .position-card:hover{border-color:rgba(6,165,197,0.35);box-shadow:0 8px 32px rgba(6,165,197,0.06);}

  /* Apply button */
  .apply-btn{font-family:'Barlow Condensed',sans-serif;font-size:0.8125rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;background:linear-gradient(135deg,#048FAB,#06A5C5);color:#fff;padding:0.75rem 1.75rem;border-radius:5px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:transform 0.18s ease,box-shadow 0.18s ease;}
  .apply-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(6,165,197,0.35);}
  .apply-btn:active{transform:translateY(0);}
  .apply-btn:focus-visible{outline:2px solid #06A5C5;outline-offset:3px;}

  @media(max-width:900px){
    #footer-grid{grid-template-columns:1fr 1fr!important;}
    .values-grid{grid-template-columns:1fr!important;}
    .positions-grid{grid-template-columns:1fr!important;}
  }
  @media(max-width:600px){
    #footer-grid{grid-template-columns:1fr!important;}
  }
</style>

