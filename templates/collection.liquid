  // ── CART ────────────────────────────────────────────────────────────
  function updateCartBadge() {
    fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
      var badge = document.getElementById('cart-badge');
      if (badge) {
        badge.textContent = cart.item_count;
        badge.style.display = cart.item_count > 0 ? 'flex' : 'none';
      }
    });
  }

  function addToCart(productId, btn) {
    var p = PRODUCTS.find(function(x){return x.id===productId;});
    if (!p) return;
    var selectedFlavor = '';
    var activePill = document.querySelector('#pills-'+productId+' .flavor-pill.active');
    if (activePill) selectedFlavor = activePill.textContent.trim();
    var fullName = p.name + (p.sub ? ' — '+p.sub : '') + (selectedFlavor ? ' ('+selectedFlavor+')' : '');
    // Use the Shopify variant ID stored on the product object if available, otherwise use productId as a placeholder
    var variantId = p.variantId || productId;
    if (btn) { btn.disabled = true; btn.innerHTML = 'Adding…'; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r){ return r.json(); })
    .then(function(data) {
      if (btn) {
        var orig = btn.dataset.orig || 'Add to Cart';
        btn.dataset.orig = orig;
        btn.disabled = false;
        btn.innerHTML = '&#10003; Added to Cart';
        btn.style.background = '#22C55E';
        btn.style.boxShadow = '0 4px 16px rgba(34,197,94,0.3)';
        setTimeout(function(){btn.innerHTML=orig;btn.style.background='';btn.style.boxShadow='';btn.disabled=false;},1800);
      }
      // Update cart count badge via Shopify cart API
      fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
        var badge = document.getElementById('cart-badge');
        if (badge) { badge.textContent = cart.item_count; badge.style.display = cart.item_count > 0 ? 'flex' : 'none'; }
      });
      if (typeof fbq==='function') fbq('track','AddToCart',{content_name:fullName,value:p.price,currency:'USD'});
      if (typeof ttq!=='undefined') ttq.track('AddToCart',{content_name:fullName,value:p.price,currency:'USD'});
      if (typeof gtag==='function') gtag('event','conversion',{send_to:'AW-17918778091/cRQ-CK-A5YUcEOu1q-BC',value:p.price,currency:'USD'});
    })
    .catch(function(err){
      console.error('Cart error:', err);
      if (btn) { btn.disabled = false; btn.innerHTML = btn.dataset.orig || 'Add to Cart'; }
    });
  }

  function selectFlavor(productId, flavor, el) {
    var pills = document.querySelectorAll('#pills-'+productId+' .flavor-pill');
    pills.forEach(function(p){p.classList.remove('active');});
    el.classList.add('active');
  }

  // ── RENDER ───────────────────────────────────────────────────────────
  function renderProducts(filter) {
    var filtered = filter === 'all' ? PRODUCTS : PRODUCTS.filter(function(p){return p.category===filter;});
    var grid = document.getElementById('product-grid');
    var empty = document.getElementById('empty-state');
    grid.innerHTML = '';

    if (filtered.length === 0) {
      grid.style.display = 'none';
      empty.style.display = 'block';
      return;
    }
    grid.style.display = 'grid';
    empty.style.display = 'none';

    filtered.forEach(function(p, idx) {
      var card = document.createElement('div');
      card.className = 'product-card card-anim';
      card.style.animationDelay = (idx * 0.04) + 's';

      // Badge HTML
      var badgeHtml = '';
      if (p.badge) {
        badgeHtml = '<span class="product-badge" style="background:' + (p.badgeColor||'#06A5C5') + '1a;color:' + (p.badgeColor||'#06A5C5') + ';border:1px solid ' + (p.badgeColor||'#06A5C5') + '40;">' + p.badge + '</span>';
      }

      // Flavor count badge (on image)
      var flavorCountHtml = '';
      if (p.flavors && p.flavors.length > 1) {
        flavorCountHtml = '<span style="position:absolute;bottom:14px;right:14px;font-family:\'Barlow Condensed\',sans-serif;font-size:0.5625rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;background:rgba(0,0,0,0.7);color:rgba(255,255,255,0.75);padding:4px 10px;border-radius:20px;backdrop-filter:blur(6px);z-index:2;">' + p.flavors.length + ' Flavors</span>';
      }

      // Flavor pills HTML
      var pillsHtml = '';
      if (p.flavors && p.flavors.length > 1) {
        pillsHtml = '<div id="pills-' + p.id + '" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">';
        p.flavors.forEach(function(f, fi) {
          var isActive = (f === p.flavor) ? ' active' : '';
          pillsHtml += '<button class="flavor-pill' + isActive + '" onclick="APNShop.selectFlavor(\'' + p.id + '\',\'' + f + '\',this)">' + f + '</button>';
        });
        pillsHtml += '</div>';
      } else {
        pillsHtml = '<div style="height:4px;"></div>';
      }

      card.innerHTML =
        '<div class="product-img-wrap">' +
          '<img src="' + p.img + '" alt="' + p.name + (p.flavor ? ' ' + p.flavor : '') + '" loading="lazy" onerror="this.src=\'https://placehold.co/400x480/111/333?text=' + encodeURIComponent(p.name) + '\'" />' +
          '<div class="product-img-overlay"></div>' +
          badgeHtml +
          flavorCountHtml +
        '</div>' +
        '<div style="padding:20px 18px 18px;display:flex;flex-direction:column;flex:1;">' +
          '<div style="font-family:\'Barlow Condensed\',sans-serif;font-size:0.5625rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#06A5C5;margin-bottom:4px;">' + p.sub + '</div>' +
          '<div style="font-family:Georgia,serif;font-size:1.125rem;font-weight:700;letter-spacing:-0.01em;color:#f0ede8;margin-bottom:4px;line-height:1.2;">' + p.name + (p.flavor ? '<span style="font-family:\'Barlow\',sans-serif;font-weight:400;font-size:0.875rem;color:#666;margin-left:6px;">' + p.flavor + '</span>' : '') + '</div>' +
          '<div style="font-size:0.8125rem;color:#666;line-height:1.55;margin-bottom:14px;flex:1;">' + p.tagline + '</div>' +
          pillsHtml +
          '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">' +
            '<div style="font-family:Georgia,serif;font-size:1.375rem;font-weight:700;color:#f0ede8;">$' + p.price.toFixed(2) + '</div>' +
            '<div style="font-family:\'Barlow Condensed\',sans-serif;font-size:0.625rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#555;">Free shipping $75+</div>' +
          '</div>' +
          '<div style="display:flex;flex-direction:column;gap:8px;">' +
            '<button class="btn-atc" onclick="APNShop.addToCart(\'' + p.id + '\',this)">Add to Cart</button>' +
            '<a href="' + (p.detailUrl || '#') + '" class="btn-details"' + (p.detailUrl ? '' : ' onclick="return false"') + '>View Details</a>' +
          '</div>' +
        '</div>';

      grid.appendChild(card);
    });
  }

  // ── FILTER ───────────────────────────────────────────────────────────
  function filterProducts(cat, btn) {
    currentFilter = cat;
    document.querySelectorAll('.filter-tab').forEach(function(t){t.classList.remove('active');});
    if (btn) btn.classList.add('active');
    renderProducts(cat);
    // Handle URL param for deep linking
    if (window.history && window.history.replaceState) {
      var url = cat === 'all' ? '/collections/all' : '/collections/all?cat=' + cat;
      window.history.replaceState({}, '', url);
    }
  }

  // ── INIT ─────────────────────────────────────────────────────────────
  window.APNShop = {
    filter: filterProducts,
    addToCart: addToCart,
    selectFlavor: selectFlavor
  };

  document.addEventListener('DOMContentLoaded', function() {
    // Check for category in URL params
    var params = new URLSearchParams(window.location.search);
    var cat = params.get('cat') || 'all';
    var tabBtn = document.querySelector('[data-filter="'+cat+'"]');
    filterProducts(cat, tabBtn);
    updateCartBadge();
  });

  // Mobile menu
  window.toggleMenu = function() {
    var m = document.getElementById('mobile-menu');
    var h = document.getElementById('hamburger');
    var open = m.classList.toggle('open');
    h.setAttribute('aria-expanded', open ? 'true' : 'false');
  };
  window.closeMenu = function() {
    document.getElementById('mobile-menu').classList.remove('open');
    document.getElementById('hamburger').setAttribute('aria-expanded','false');
  };

})();
</script>

