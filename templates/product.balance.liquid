<script>
  
  
  function setImg(thumb,src){document.querySelectorAll('.thumb').forEach(function(t){t.classList.remove('active');});thumb.classList.add('active');var mainImg=document.getElementById('main-img');mainImg.style.opacity='0';setTimeout(function(){mainImg.src=src;mainImg.style.opacity='1';},150);}
  var FAQS=[{q:'What is Balance for?',a:'Balance is a joint and inflammation support formula with 11 ingredients in 2 capsules: Turmeric Root Powder 800mg, Glucosamine Sulfate 200mg, Turmeric 95% Curcuminoids 100mg, Ginger Root Extract 100mg, Chondroitin Sulfate 50mg, Boswellia Extract 40mg, MSM 10mg, BioPerine 10mg, Quercetin 8mg, L-Methionine 8mg, and Bromelain 8mg.'},{q:'Does Balance contain shellfish?',a:'Yes. The glucosamine in Balance is derived from shellfish. Balance contains Shellfish (Crab, Lobster, and Crawfish). Do not take Balance if you have a shellfish allergy.'},{q:'Why does Balance include BioPerine?',a:'BioPerine (black pepper extract standardized for piperine) is included at 10mg to enhance the absorption of curcumin, which has notoriously low bioavailability on its own. The combination of BioPerine with turmeric and curcuminoids significantly improves absorption.'},{q:'Can I stack Balance with Adapt?',a:'Yes. Adapt (ashwagandha) addresses cortisol and stress recovery, while Balance focuses on joint and inflammation support. They work on complementary pathways and can be taken together.'}];
  (function renderFAQ(){var list=document.getElementById('faq-list');FAQS.forEach(function(f){var item=document.createElement('div');item.className='faq-item';item.innerHTML='<button class="faq-btn" aria-expanded="false" onclick="toggleFAQ(this)"><span>'+f.q+'</span><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg></button><div class="faq-body"><p>'+f.a+'</p></div>';list.appendChild(item);});})();
  function toggleFAQ(btn){var expanded=btn.getAttribute('aria-expanded')==='true';document.querySelectorAll('.faq-btn').forEach(function(b){b.setAttribute('aria-expanded','false');b.nextElementSibling.classList.remove('open');});if(!expanded){btn.setAttribute('aria-expanded','true');btn.nextElementSibling.classList.add('open');}}
  function _getCart(){try{return JSON.parse(localStorage.getItem('apn_cart')||'[]');}catch(e){return[];}}
  function _saveCart(cart){localStorage.setItem('apn_cart',JSON.stringify(cart));}
  function _updateCartBadge(){var cart=_getCart();var total=cart.reduce(function(s,i){return s+(i.qty||1);},0);var badge=document.getElementById('cart-badge');if(badge){badge.textContent=total;total>0?badge.classList.add('visible'):badge.classList.remove('visible');}}
  
  function addToCart() {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({id: '{{ product.variants.first.id }}', quantity: 1})
    }).then(function() { window.location = '/cart'; });
  }
  _updateCartBadge();
</script>
