  <div id="wheel-detail-panel" style="max-width:480px;margin:2rem auto 0;opacity:0;transform:translateY(10px);transition:opacity 0.3s,transform 0.3s;pointer-events:none;"><div style="background:#131313;border:1px solid rgba(6,165,197,0.25);border-radius:16px;padding:1.75rem 2rem;text-align:left;"><div id="wdp-tag" style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#06A5C5;margin-bottom:0.5rem;"></div><div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:0.75rem;"><div id="wdp-name" style="font-family:Georgia,serif;font-size:1.35rem;font-weight:700;color:#F8FAFB;line-height:1.2;"></div><div id="wdp-amount" style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:0.06em;color:#06A5C5;white-space:nowrap;"></div></div><p id="wdp-desc" style="font-size:0.875rem;color:#9ca3af;line-height:1.7;"></p></div></div>
  </div>
</section>
<script>
(function(){
  var NODES=[{id:1,tag:'Primary Ingredient',name:'Turmeric Complex',amount:'900mg total',desc:'Turmeric Root Powder 800mg plus Turmeric 95% Curcuminoids 100mg for comprehensive inflammation support from the same plant source.',icon:'<path d="M17 8C8 10 5.9 16.17 3.82 19.22L5.71 21A18 18 0 0 1 10 15c4.33-1 6.33 2 8 2 1 0 2-1 2-3s-1-5-3-6z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:2,tag:'Joint Structure',name:'Glucosamine + Chondroitin',amount:'250mg combined',desc:'Glucosamine Sulfate 2KCl 200mg and Chondroitin Sulfate 50mg for structural joint support. Contains Shellfish (Crab, Lobster, and Crawfish).',icon:'<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:3,tag:'Inflammation',name:'Boswellia + Ginger',amount:'140mg combined',desc:'Boswellia Extract 40mg and Ginger Root Extract 100mg for additional inflammation and recovery support.',icon:'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:4,tag:'Bioavailability',name:'BioPerine',amount:'10mg',desc:'Black pepper extract standardized for piperine. Enhances absorption of curcumin and other fat-soluble nutrients in the formula.',icon:'<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:5,tag:'Additional Support',name:'MSM, Quercetin, Bromelain',amount:'26mg combined',desc:'MSM (Methylsulfonylmethane) 10mg, Quercetin Dihydrate 8mg, L-Methionine 8mg, and Bromelain 8mg for complementary joint and mobility support.',icon:'<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:6,tag:'Serving Profile',name:'Per Serving',amount:'2 Caps / 30 Servings',desc:'2 capsules daily with food. Consistent use over 4 to 8 weeks is recommended to evaluate the full benefit of joint support compounds. Contains Shellfish.',icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'}];
  var CX=330,CY=330,RADIUS=250,rotation=0,speed=0.18,activeId=null,paused=false;
  var nodesEl=document.getElementById('wheel-nodes'),lineEl=document.getElementById('wheel-line'),panel=document.getElementById('wheel-detail-panel');
  var nodeEls={},labelEls={};
  NODES.forEach(function(n){var div=document.createElement('div');div.className='wnode';div.id='wnode-'+n.id;div.innerHTML='<svg width="20" height="20" viewBox="0 0 24 24" style="color:#9ca3af">'+n.icon+'</svg>';div.addEventListener('click',function(e){e.stopPropagation();toggleNode(n.id);});nodesEl.appendChild(div);nodeEls[n.id]=div;var lbl=document.createElement('div');lbl.className='wnode-label';lbl.id='wlbl-'+n.id;lbl.textContent=n.name;nodesEl.appendChild(lbl);labelEls[n.id]=lbl;});
  function getPos(i,t,a){var deg=(i/t)*360+a;var rad=(deg*Math.PI)/180;return{x:CX+RADIUS*Math.cos(rad),y:CY+RADIUS*Math.sin(rad),rad:rad};}
  function updatePositions(){NODES.forEach(function(n,i){var p=getPos(i,NODES.length,rotation);var depth=(Math.sin(p.rad)+1)/2;var opacity=0.35+0.65*depth;nodeEls[n.id].style.left=p.x+'px';nodeEls[n.id].style.top=p.y+'px';nodeEls[n.id].style.zIndex=Math.round(10+20*depth);if(!nodeEls[n.id].classList.contains('active'))nodeEls[n.id].style.opacity=opacity;var outX=p.x+Math.cos(p.rad)*38;var outY=p.y+Math.sin(p.rad)*38;labelEls[n.id].style.left=(outX-45)+'px';labelEls[n.id].style.top=(outY-9)+'px';if(!labelEls[n.id].classList.contains('active'))labelEls[n.id].style.opacity=opacity*0.75;});}
  function loop(){if(!paused)rotation=(rotation+speed)%360;updatePositions();requestAnimationFrame(loop);}loop();
  function toggleNode(id){if(activeId===id){deactivate();return;}activeId=id;paused=true;NODES.forEach(function(n){var el=nodeEls[n.id];var lbl=labelEls[n.id];if(n.id===id){el.classList.add('active');el.querySelector('svg').style.color='#fff';lbl.classList.add('active');lbl.style.color='#06A5C5';lbl.style.opacity='1';}else{el.classList.remove('active');el.querySelector('svg').style.color='#9ca3af';lbl.classList.remove('active');}});var idx=NODES.findIndex(function(n){return n.id===id;});var p=getPos(idx,NODES.length,rotation);lineEl.setAttribute('x1',CX);lineEl.setAttribute('y1',CY);lineEl.setAttribute('x2',p.x);lineEl.setAttribute('y2',p.y);lineEl.setAttribute('opacity','0.4');var node=NODES.find(function(n){return n.id===id;});document.getElementById('wdp-tag').textContent=node.tag;document.getElementById('wdp-name').textContent=node.name;document.getElementById('wdp-amount').textContent=node.amount;document.getElementById('wdp-desc').textContent=node.desc;panel.style.opacity='1';panel.style.transform='translateY(0)';panel.style.pointerEvents='auto';}
  function deactivate(){activeId=null;paused=false;NODES.forEach(function(n){nodeEls[n.id].classList.remove('active');nodeEls[n.id].querySelector('svg').style.color='#9ca3af';labelEls[n.id].classList.remove('active');});lineEl.setAttribute('opacity','0');panel.style.opacity='0';panel.style.transform='translateY(10px)';panel.style.pointerEvents='none';}
  document.getElementById('wheel-wrap').addEventListener('click',function(e){if(e.target===this||e.target.id==='wheel-svg'||e.target.tagName==='circle'||e.target.tagName==='line')deactivate();});
})();
</script>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;"><p class="section-label" style="margin-bottom:0.75rem;">Directions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin-bottom:3.5rem;">How to Use Balance</h2>
  <div class="how-to-steps-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:left;"><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">1</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Take It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Two capsules daily with food. Taking with a meal that contains some fat improves absorption of curcumin and other fat-soluble compounds. Important: contains Shellfish (Crab, Lobster, and Crawfish) via the glucosamine source.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">2</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Be Patient</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Joint support compounds work over time. Expect to evaluate results after a consistent 4 to 8 week run. Many users notice improved mobility and reduced discomfort in the first few weeks of consistent use.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">3</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Track It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Optional: note your joint comfort and range of motion during your first 6 to 8 weeks. Benefits of joint support compounds are cumulative and improve with sustained daily use.</p></div></div>
  <p style="margin-top:1.75rem;font-size:0.8rem;color:#4b5563;">Store in a cool, dry place. Keep out of reach of children. Consult a healthcare professional before use if you have any medical conditions.</p></div>
</section>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;" id="faq"><div style="max-width:700px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Questions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">Frequently Asked</h2></div><div id="faq-list"></div></div></section>
<section style="background:#0a0a0a;padding:6rem 1.5rem;" id="reviews"><div style="max-width:800px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Reviews</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">What Athletes Say</h2></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem 2.5rem;"><div style="display:flex;align-items:flex-start;gap:1.25rem;"><div style="width:48px;height:48px;background:linear-gradient(135deg,#06A5C5,#048FAB);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;">K</div><div style="flex:1;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.25rem;"><span style="font-weight:700;color:#F8FAFB;">Kelly H.</span><span class="stars" style="font-size:0.9rem;">★★★★★</span><span style="font-size:0.75rem;color:#6b7280;margin-left:auto;">Verified Purchase</span></div><p style="font-size:0.875rem;color:#6b7280;margin-bottom:0.75rem;">February 2025</p><p style="color:#9ca3af;line-height:1.7;font-size:0.9375rem;">I started taking Balance about 6 weeks ago for joint discomfort in my knees from years of training. I noticed a real difference around the 4-week mark. My knees feel less stiff in the morning and I can train longer without that nagging ache. The 2-capsule dose is easy and it does not upset my stomach.</p></div></div></div></div></section>
