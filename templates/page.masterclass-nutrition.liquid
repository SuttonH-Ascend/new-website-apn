  <!-- MODULE 6: YOUR 30-DAY CHALLENGE -->
  <div id="apn-nutr-m6" style="background:#0D0D0D;padding:80px 24px;">
    <div style="max-width:680px;margin:0 auto;">
      <span style="font-family:'Barlow',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:4px;color:#06A5C5;margin-bottom:16px;display:block;">The Commitment</span>
      <h2 style="font-family:Georgia,serif;font-size:40px;font-weight:bold;letter-spacing:-0.02em;color:#F8FAFB;margin-bottom:24px;line-height:1.2;">The Gap Closes When You Decide It Does</h2>
      <div style="width:64px;height:3px;background:#06A5C5;margin:0 0 40px;"></div>

      <div style="margin-bottom:48px;">
        <p style="font-family:'Barlow',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#06A5C5;margin-bottom:24px;">4 Measurable Habit Targets</p>

        <div class="apn-nutr-habit">
          <div class="apn-nutr-habit-num">01</div>
          <div class="apn-nutr-habit-text">
            <h4>Hit Your Protein Target 5 Out of 7 Days</h4>
            <p>Bodyweight in pounds multiplied by 0.9 equals your daily minimum in grams. 5 of 7 days is not perfect. It is sustainable. Track it in MyFitnessPal. The number does not lie.</p>
