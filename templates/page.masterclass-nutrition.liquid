<script>
(function() {
  // URL PARAM PARSER
  const params = new URLSearchParams(window.location.search);
  const tierParam = (params.get('tier') || 'athlete').toLowerCase();
  const scoreParam = parseInt(params.get('score') || '55');
  const nameParam = params.get('name') || 'Athlete';
  const gap2Param = params.get('gap2') || null;

  const tierColors = {
    rookie:     '#22C55E',
    competitor: '#F59E0B',
    athlete:    '#06A5C5',
    elite:      '#8B5CF6',
    champion:   '#EF4444'
  };
  const tierNames = {
    rookie:     'Rookie',
    competitor: 'Competitor',
    athlete:    'Athlete',
    elite:      'Elite Athlete',
    champion:   'Champion'
  };

  const tierColor = tierColors[tierParam] || '#06A5C5';
  const tierName  = tierNames[tierParam]  || 'Athlete';

  // INJECT PERSONALIZATION
  const nameEl = document.getElementById('apn-nutr-name-display');
  const scoreEl = document.getElementById('apn-nutr-score-display');
  const badgeEl = document.getElementById('apn-nutr-tier-badge');
  const m1ScoreEl = document.getElementById('apn-nutr-m1-score');
  const m3ScoreEl = document.getElementById('apn-nutr-m3-score');

  if (nameEl) nameEl.textContent = nameParam;
  if (scoreEl) scoreEl.textContent = scoreParam;
  if (m1ScoreEl) m1ScoreEl.textContent = scoreParam;
  if (m3ScoreEl) m3ScoreEl.textContent = scoreParam;

  if (badgeEl) {
    badgeEl.textContent = tierName;
    badgeEl.style.background = tierColor;
    badgeEl.style.color = '#fff';
  }

  // SCORE CONTEXT BLOCK
  const scoreCtxEl = document.getElementById('apn-nutr-score-context');
  if (scoreCtxEl) {
    let ctxHTML = '';
    if (scoreParam <= 39) {
      ctxHTML = '<div style="background:#FEF2F2;border-left:4px solid #EF4444;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#EF4444;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Significant Gap</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' indicates your current nutrition structure is not meeting the demands of consistent training. Your protein intake is likely below the leucine threshold on most meals, your carbohydrate timing is not matched to training demand, and your micronutrient coverage has gaps that are silently reducing muscle function and energy metabolism. This is correctable in 30 days with a structured approach.</p></div>';
    } else if (scoreParam <= 59) {
      ctxHTML = '<div style="background:#FFFBEB;border-left:4px solid #F59E0B;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#F59E0B;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Moderate Gap</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' means your nutrition foundation exists but has structural inconsistencies that are limiting your training adaptation. You are likely hitting protein targets on some days but not consistently. Your carbohydrate intake is probably not periodized to match training days. The gap between where you are and where your training demands you to be is measurable and closeable.</p></div>';
    } else if (scoreParam <= 74) {
      ctxHTML = '<div style="background:#F0FBFD;border-left:4px solid #06A5C5;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#06A5C5;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Optimization Zone</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' tells us your nutrition fundamentals are in place. The gains from here come from precision: consistent leucine-threshold clears at every meal, deliberate carbohydrate periodization between training and rest days, and closing any micronutrient deficiencies that are putting a ceiling on your training output and recovery quality.</p></div>';
    } else if (scoreParam <= 89) {
      ctxHTML = '<div style="background:#F5F3FF;border-left:4px solid #8B5CF6;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#8B5CF6;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Advanced Precision Required</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' means your nutrition is strong. The remaining gap is a precision variable. At this level, the impact shows up in bloodwork (Vitamin D, Zinc, Testosterone), in the tail end of long sessions, and in recovery speed after back-to-back high-intensity days. The margin is narrow. The details matter more at this level than any other.</p></div>';
    } else {
      ctxHTML = '<div style="background:#F0FDF4;border-left:4px solid #22C55E;padding:20px 24px;border-radius:0 4px 4px 0;"><p style="font-family:\'Barlow\',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#22C55E;margin-bottom:8px;">Score: ' + scoreParam + '/100 — Maintenance and Protection</p><p style="font-family:\'Barlow\',sans-serif;font-size:15px;color:#333;line-height:1.65;margin:0;">A score of ' + scoreParam + ' reflects an elite nutrition system. The task now is protection and refinement. Verify quarterly. Audit when training phases change. Do not let a strong system drift through complacency. The gap between 90 and 100 lives in the details of periodization and micronutrient precision that most athletes at this level never fully optimize.</p></div>';
    }
    scoreCtxEl.innerHTML = ctxHTML;
  }

  // TIER-CONDITIONAL SHOW/HIDE
  document.querySelectorAll('.apn-tier-block').forEach(function(el) {
    el.style.display = el.dataset.tier === tierParam ? 'block' : 'none';
  });

  // GAP2 CALLOUT
  if (gap2Param) {
    const gap2El = document.getElementById('apn-nutr-gap2-callout');
    const gap2TextEl = document.getElementById('apn-nutr-gap2-text');
    if (gap2El && gap2TextEl) {
      gap2El.style.display = 'block';
      const gap2Name = gap2Param.charAt(0).toUpperCase() + gap2Param.slice(1);
      let gap2Msg = 'Your secondary gap is ' + gap2Name + '. ';
      if (gap2Param.toLowerCase() === 'recovery') {
        gap2Msg += 'Resilience (Whey Protein Isolate) addresses both gaps simultaneously: it fills protein distribution for MPS optimization (Nutrition gap) and provides the fast-absorbing leucine needed for the 0 to 2 hour post-training recovery window (Recovery gap). One product closes two gaps.';
      } else if (gap2Param.toLowerCase() === 'hydration') {
        gap2Msg += 'Recharge (Creatine Monohydrate) bridges both gaps: it increases intramuscular phosphocreatine for training performance (Nutrition gap) and draws water into muscle cells, directly improving cellular hydration status (Hydration gap). 5g daily serves both functions.';
      } else if (gap2Param.toLowerCase() === 'sleep') {
        gap2Msg += 'The Magnesium Glycinate in your micronutrient stack (Week 4 protocol) bridges both gaps: it is required for ATP synthesis and muscle protein synthesis (Nutrition gap) and modulates GABA to reduce sleep onset latency and improve deep sleep architecture (Sleep gap). 400mg before bed serves both functions.';
      } else {
        gap2Msg += 'Nourish (Greens Superfood) supports both your Nutrition gap (daily micronutrient coverage) and your ' + gap2Name + ' gap through B-vitamins, adaptogenic botanicals, and antioxidant compounds that reduce the oxidative burden of hard training. One scoop daily.';
      }
      gap2TextEl.textContent = gap2Msg;
    }
  }

  // STICKY PROGRESS BAR + INTERSECTION OBSERVER
  const modules = ['apn-nutr-m0','apn-nutr-m1','apn-nutr-m2','apn-nutr-m3','apn-nutr-m4','apn-nutr-m5','apn-nutr-m6','apn-nutr-m7'];
  const dots = document.querySelectorAll('.apn-nutr-prog-dot');
  const navLinks = document.querySelectorAll('.apn-nutr-nav-link');
  let activeModule = 0;

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        const idx = modules.indexOf(entry.target.id);
        if (idx !== -1) {
          activeModule = idx;
          dots.forEach(function(d, i) { d.classList.toggle('active', i <= idx); });
          navLinks.forEach(function(l, i) { l.classList.toggle('active', i === idx); });
          const sidebarFill = document.getElementById('apn-nutr-sidebar-fill');
          if (sidebarFill) {
            sidebarFill.style.height = ((idx / (modules.length - 1)) * 100) + '%';
          }
        }
      }
    });
  }, { threshold: 0.3 });

  modules.forEach(function(id) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

})();

// CHECKBOX SEVERITY
function apnNutrUpdateSeverity() {
  const checked = document.querySelectorAll('.apn-nutr-symptom:checked').length;
  const severityEl = document.getElementById('apn-nutr-severity');
  if (!severityEl) return;
  severityEl.style.display = 'block';
  if (checked <= 2) {
    severityEl.style.background = '#F0FDF4';
    severityEl.style.color = '#166534';
    severityEl.style.border = '1px solid #22C55E';
    severityEl.innerHTML = '<strong>Mild optimization gap (' + checked + '/7 symptoms).</strong> You are maintaining but leaving performance on the table. Your nutrition structure has the right foundation. The protocol in Module 4 will help you find the precision improvements that close the remaining gap.';
  } else if (checked <= 5) {
    severityEl.style.background = '#FFFBEB';
    severityEl.style.color = '#92400E';
    severityEl.style.border = '1px solid #F59E0B';
    severityEl.innerHTML = '<strong>Moderate gap (' + checked + '/7 symptoms).</strong> This is actively limiting your training ceiling. Multiple nutrition sub-gaps are working against you simultaneously. The 4-week protocol addresses each one in sequence. Follow it in order.';
  } else {
    severityEl.style.background = '#FEF2F2';
    severityEl.style.color = '#991B1B';
    severityEl.style.border = '1px solid #EF4444';
    severityEl.innerHTML = '<strong>Severe gap (' + checked + '/7 symptoms).</strong> Nutrition is your primary performance constraint. Everything else you are doing in your training, recovery, and supplementation is underperforming because this system is broken. Close this first. Everything else amplifies what you fix here.';
  }
}

