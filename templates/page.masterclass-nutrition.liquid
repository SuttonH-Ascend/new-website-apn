function apnNutrSelectSubgap(btn, subgapName) {
  document.querySelectorAll('.apn-nutr-subgap-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  const targetEl = document.getElementById('apn-nutr-primary-target');
  const targetTextEl = document.getElementById('apn-nutr-target-text');
  if (targetEl && targetTextEl) {
    targetEl.style.display = 'block';
    targetTextEl.textContent = 'Primary Target: ' + subgapName;
  }
}
</script>