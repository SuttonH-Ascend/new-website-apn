{% comment %}
  Ascend Performance Nutrition — ATHLETE Tier MasterClass
  Tier: Athlete (Score 60-74)
  Personalization: ?score= ?name= ?gap1= ?gap2= ?gap3=
  Version: 1.0 | Production Ready
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section id="apn-masterclass-tier-athlete" style="font-family:'Barlow',sans-serif; background:#F4F4F2; color:#333333;">

<style>
  #apn-masterclass-tier-athlete * { box-sizing: border-box; margin: 0; padding: 0; }

  /* ---- TOKENS ---- */
  #apn-masterclass-tier-athlete {
    --teal:         #108474;
    --tier-blue:    #06A5C5;
    --black:        #0D0D0D;
    --body:         #333333;
    --bg:           #F4F4F2;
    --bg2:          #F8F8F8;
    --border:       #E2E8F0;
    --warning:      #F59E0B;
    --warn-bg:      #FFFBEB;
    --font:         'Barlow', sans-serif;
  }

  /* ---- GLOBAL ---- */
  .apn-a-wrap { max-width: 780px; margin: 0 auto; padding: 0 24px; }
  .apn-a-wrap--wide { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  .apn-a-section-label {
    font-family: var(--font);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
  }

  .apn-a-divider {
    width: 64px;
    height: 3px;
    background: var(--teal);
    margin: 20px 0 32px 0;
  }
  .apn-a-divider--center { margin: 20px auto 32px auto; }

  .apn-a-h1 {
    font-family: var(--font);
    font-weight: 800;
    font-size: clamp(38px, 6vw, 54px);
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: #ffffff;
  }

  .apn-a-h2 {
    font-family: var(--font);
    font-weight: 700;
    font-size: clamp(26px, 4vw, 36px);
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--black);
    margin-bottom: 16px;
  }

  .apn-a-h3 {
    font-family: var(--font);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 10px;
  }

  .apn-a-body {
    font-family: var(--font);
    font-size: 16px;
    line-height: 1.65;
    color: var(--body);
  }

  .apn-a-body + .apn-a-body { margin-top: 16px; }

  /* ---- MODULE SPACING ---- */
  .apn-a-module { padding: 80px 0; }
  .apn-a-module--dark { background: var(--black); }
  .apn-a-module--bg2 { background: var(--bg2); }
  .apn-a-module--bg { background: var(--bg); }

  /* ---- HERO ---- */
  .apn-a-hero {
    background: var(--black);
    padding: 100px 0 80px;
    position: relative;
    overflow: hidden;
  }
  .apn-a-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--teal);
  }
  .apn-a-hero::after {
    content: '';
    position: absolute;
    top: 0; right: -200px; bottom: 0;
    width: 500px;
    background: radial-gradient(ellipse at center, rgba(6,165,197,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .apn-a-hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }
  .apn-a-tier-badge {
    display: inline-block;
    background: var(--tier-blue);
    color: #fff;
    font-family: var(--font);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 3px;
  }
  .apn-a-hero-welcome {
    font-family: var(--font);
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    line-height: 1.5;
  }
  .apn-a-hero-welcome strong { color: rgba(255,255,255,0.9); }
  .apn-a-hero-sub {
    font-family: var(--font);
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.72);
    margin-top: 24px;
    max-width: 600px;
  }
  .apn-a-module-list {
    margin-top: 40px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .apn-a-module-list li {
    font-family: var(--font);
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .apn-a-module-list li::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--tier-blue);
    flex-shrink: 0;
  }
  .apn-a-module-list .read-time {
    margin-left: auto;
    color: rgba(255,255,255,0.35);
    font-size: 12px;
    letter-spacing: 1px;
  }
  .apn-a-scroll-btn {
    display: inline-block;
    margin-top: 44px;
    padding: 14px 32px;
    background: var(--tier-blue);
    color: #fff;
    font-family: var(--font);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 60px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .apn-a-scroll-btn:hover { opacity: 0.88; }

  /* ---- PULL QUOTE ---- */
  .apn-a-pullquote {
    border-left: 4px solid var(--teal);
    background: var(--bg2);
    padding: 24px 28px;
    margin: 40px 0;
    border-radius: 0 4px 4px 0;
  }
  .apn-a-pullquote p {
    font-family: var(--font);
    font-style: italic;
    font-size: 17px;
    line-height: 1.65;
    color: var(--body);
  }
  .apn-a-pullquote cite {
    display: block;
    margin-top: 12px;
    font-family: var(--font);
    font-style: normal;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--teal);
  }

  /* ---- ASSIGNMENT BLOCK ---- */
  .apn-a-assignment {
    border-top: 3px solid var(--teal);
    background: #F4F4F2;
    padding: 24px 28px;
    margin-top: 28px;
    border-radius: 0 0 4px 4px;
  }
  .apn-a-assignment .assignment-label {
    font-family: var(--font);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 10px;
    display: block;
  }
  .apn-a-assignment p {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: var(--body);
  }
  .apn-a-assignment ul {
    margin-top: 10px;
    padding-left: 20px;
  }
  .apn-a-assignment ul li {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.7;
    color: var(--body);
    margin-bottom: 6px;
  }

  /* ---- SCRIPTURE ---- */
  .apn-a-scripture {
    text-align: center;
    padding: 40px 32px;
    margin: 48px 0;
    background: var(--bg2);
    border-radius: 4px;
  }
  .apn-a-scripture p {
    font-family: var(--font);
    font-style: italic;
    font-size: 17px;
    line-height: 1.7;
    color: var(--body);
    max-width: 560px;
    margin: 0 auto;
  }
  .apn-a-scripture cite {
    display: block;
    margin-top: 14px;
    font-family: var(--font);
    font-style: normal;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
  }

  /* ---- WARNING CALLOUT ---- */
  .apn-a-warning {
    border-left: 4px solid var(--warning);
    background: var(--warn-bg);
    padding: 20px 24px;
    margin: 32px 0;
    border-radius: 0 4px 4px 0;
  }
  .apn-a-warning .warn-label {
    font-family: var(--font);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--warning);
    margin-bottom: 8px;
    display: block;
  }
  .apn-a-warning p {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: #92400E;
  }

  /* ---- DATA CALLOUT ---- */
  .apn-a-data-callout {
    background: var(--black);
    color: #fff;
    padding: 28px 32px;
    margin: 32px 0;
    border-radius: 4px;
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .apn-a-data-callout .stat {
    font-family: var(--font);
    font-weight: 800;
    font-size: 36px;
    color: var(--tier-blue);
    line-height: 1;
    flex-shrink: 0;
    min-width: 80px;
  }
  .apn-a-data-callout .stat-body { flex: 1; }
  .apn-a-data-callout .stat-body strong {
    display: block;
    font-family: var(--font);
    font-weight: 700;
    font-size: 15px;
    color: #fff;
    margin-bottom: 6px;
  }
  .apn-a-data-callout .stat-body span {
    font-family: var(--font);
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.55;
  }

  /* ---- GAP CARDS ---- */
  .apn-a-gap-card {
    background: #fff;
    border-left: 4px solid var(--teal);
    border-radius: 0 6px 6px 0;
    padding: 24px 28px;
    margin-bottom: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .apn-a-gap-card .gap-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .apn-a-gap-card .gap-name {
    font-family: var(--font);
    font-weight: 700;
    font-size: 16px;
    color: var(--black);
    text-transform: capitalize;
  }
  .apn-a-gap-card .gap-urgency {
    font-family: var(--font);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
  }
  .gap-urgency--critical { background: #FEE2E2; color: #991B1B; }
  .gap-urgency--moderate { background: #FEF3C7; color: #92400E; }
  .gap-urgency--manageable { background: #D1FAE5; color: #065F46; }
  .apn-a-gap-card p {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: var(--body);
    margin-bottom: 12px;
  }
  .apn-a-gap-card a {
    font-family: var(--font);
    font-weight: 600;
    font-size: 13px;
    color: var(--teal);
    text-decoration: none;
    letter-spacing: 0.5px;
  }
  .apn-a-gap-card a:hover { text-decoration: underline; }

  /* ---- PRODUCT CARD ---- */
  .apn-a-product-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px 28px;
    margin-bottom: 24px;
  }
  .apn-a-product-card .prod-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 16px;
  }
  .apn-a-product-card .prod-name {
    font-family: var(--font);
    font-weight: 700;
    font-size: 18px;
    color: var(--black);
  }
  .apn-a-product-card .prod-price {
    font-family: var(--font);
    font-weight: 700;
    font-size: 16px;
    color: var(--teal);
  }
  .apn-a-product-card .prod-mechanism {
    font-family: var(--font);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 8px;
    display: block;
  }
  .apn-a-product-card p {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: var(--body);
    margin-bottom: 10px;
  }
  .apn-a-product-card .prod-protocol {
    background: var(--bg);
    border-radius: 4px;
    padding: 12px 16px;
    margin-top: 14px;
    font-family: var(--font);
    font-size: 14px;
    color: var(--body);
    line-height: 1.6;
  }
  .apn-a-product-card .prod-protocol strong {
    color: var(--black);
    font-weight: 700;
  }

  /* ---- WEEK BLOCK ---- */
  .apn-a-week {
    border: 1px solid var(--border);
    background: #fff;
    border-radius: 6px;
    margin-bottom: 24px;
    overflow: hidden;
  }
  .apn-a-week-header {
    background: var(--black);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .apn-a-week-header .week-label {
    font-family: var(--font);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--tier-blue);
  }
  .apn-a-week-header .week-title {
    font-family: var(--font);
    font-weight: 700;
    font-size: 16px;
    color: #fff;
  }
  .apn-a-week-body { padding: 24px; }
  .apn-a-week-body ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }
  .apn-a-week-body ul li {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: var(--body);
    padding-left: 20px;
    position: relative;
  }
  .apn-a-week-body ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
  }

  /* ---- TIER PROGRESS ---- */
  .apn-a-tier-progress {
    background: var(--black);
    border-radius: 6px;
    padding: 32px 28px;
    margin: 40px 0;
    color: #fff;
  }
  .apn-a-tier-progress .tier-progress-label {
    font-family: var(--font);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--tier-blue);
    margin-bottom: 16px;
    display: block;
  }
  .apn-a-tier-bar {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 20px 0 28px;
    flex-wrap: wrap;
  }
  .tier-bar-item-a {
    flex: 1;
    text-align: center;
    position: relative;
    min-width: 80px;
  }
  .tier-bar-dot-a {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    margin: 0 auto 8px;
    background: rgba(255,255,255,0.2);
  }
  .tier-bar-dot-a--active { background: var(--tier-blue); }
  .tier-bar-dot-a--done { background: var(--teal); }
  .tier-bar-name-a {
    font-family: var(--font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .tier-bar-name-a--active { color: var(--tier-blue); }
  .tier-bar-name-a--done { color: rgba(255,255,255,0.6); }
  .tier-bar-line-a {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.12);
    min-width: 20px;
    max-width: 60px;
    margin-bottom: 22px;
  }
  .tier-bar-line-a--done { background: var(--teal); }

  /* ---- HRV EXPLAINER ---- */
  .apn-a-hrv-box {
    background: linear-gradient(135deg, rgba(6,165,197,0.08) 0%, rgba(16,132,116,0.08) 100%);
    border: 1px solid rgba(6,165,197,0.25);
    border-radius: 6px;
    padding: 28px 32px;
    margin: 32px 0;
  }
  .apn-a-hrv-box .hrv-label {
    font-family: var(--font);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--tier-blue);
    margin-bottom: 10px;
    display: block;
  }
  .apn-a-hrv-box h4 {
    font-family: var(--font);
    font-weight: 700;
    font-size: 17px;
    color: var(--black);
    margin-bottom: 10px;
  }
  .apn-a-hrv-box p {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.65;
    color: var(--body);
  }

  /* ---- CHALLENGE HABITS ---- */
  .apn-a-habit {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .apn-a-habit:last-child { border-bottom: none; }
  .habit-num-a {
    font-family: var(--font);
    font-weight: 800;
    font-size: 28px;
    color: var(--tier-blue);
    line-height: 1;
    flex-shrink: 0;
    width: 40px;
  }
  .habit-content-a strong {
    display: block;
    font-family: var(--font);
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    margin-bottom: 6px;
  }
  .habit-content-a p {
    font-family: var(--font);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
  }

  /* ---- NEXT STEPS CARDS ---- */
  .apn-a-next-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 24px;
    text-decoration: none;
    display: block;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .apn-a-next-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .apn-a-next-card .next-card-label {
    font-family: var(--font);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 8px;
    display: block;
  }
  .apn-a-next-card .next-card-title {
    font-family: var(--font);
    font-weight: 700;
    font-size: 16px;
    color: var(--black);
    margin-bottom: 6px;
    text-transform: capitalize;
  }
  .apn-a-next-card .next-card-desc {
    font-family: var(--font);
    font-size: 14px;
    color: var(--body);
    line-height: 1.55;
  }

  /* ---- CTA BUTTONS ---- */
  .apn-a-cta-block { display: flex; flex-direction: column; gap: 14px; margin-top: 40px; }
  .apn-a-btn {
    display: inline-block;
    padding: 16px 32px;
    font-family: var(--font);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 60px;
    text-align: center;
    transition: opacity 0.2s;
    cursor: pointer;
    border: 2px solid transparent;
  }
  .apn-a-btn:hover { opacity: 0.85; }
  .apn-a-btn--blue { background: var(--tier-blue); color: #fff; border-color: var(--tier-blue); }
  .apn-a-btn--black { background: var(--black); color: #fff; border-color: var(--black); }

  /* ---- DISCOUNT BANNER ---- */
  .apn-a-discount-banner {
    background: var(--teal);
    color: #fff;
    text-align: center;
    padding: 16px 24px;
    border-radius: 4px;
    margin: 28px 0;
    font-family: var(--font);
    font-size: 15px;
    font-weight: 600;
  }
  .apn-a-discount-banner .code {
    font-weight: 800;
    font-size: 17px;
    letter-spacing: 2px;
    background: rgba(0,0,0,0.15);
    padding: 2px 10px;
    border-radius: 3px;
    margin: 0 4px;
  }

  /* ---- FOOTER ---- */
  .apn-a-footer {
    background: var(--black);
    padding: 60px 0 40px;
    border-top: 3px solid var(--teal);
  }
  .apn-a-footer-tagline {
    font-family: var(--font);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-align: center;
    margin-bottom: 28px;
  }
  .apn-a-footer-signoff {
    font-family: var(--font);
    font-size: 15px;
    color: rgba(255,255,255,0.65);
    text-align: center;
    line-height: 1.7;
  }
  .apn-a-footer-signoff strong {
    display: block;
    color: #fff;
    font-weight: 700;
    margin-top: 4px;
  }

  /* ---- BOTTLENECK BOX ---- */
  .apn-a-bottleneck {
    border: 2px solid var(--tier-blue);
    border-radius: 6px;
    padding: 28px 32px;
    margin: 36px 0;
    background: rgba(6,165,197,0.04);
  }
  .apn-a-bottleneck .bt-label {
    font-family: var(--font);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--tier-blue);
    margin-bottom: 10px;
    display: block;
  }
  .apn-a-bottleneck h4 {
    font-family: var(--font);
    font-weight: 700;
    font-size: 18px;
    color: var(--black);
    margin-bottom: 10px;
  }
  .apn-a-bottleneck p {
