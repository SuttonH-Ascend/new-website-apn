<script>
(function() {
  'use strict';

  var params = new URLSearchParams(window.location.search);
  var scoreParam = parseInt(params.get('score') || '67');
  var nameParam = params.get('name') || 'Athlete';
  var gap1Param = params.get('gap1') || 'sleep';
  var gap2Param = params.get('gap2') || 'recovery';
  var gap3Param = params.get('gap3') || 'nutrition';

  /* ---- Welcome line ---- */
  var welcomeEl = document.getElementById('apn-a-welcome-line');
  if (welcomeEl) {
    welcomeEl.innerHTML = 'Welcome back, <strong>' + nameParam + '</strong>. Your overall score: <strong>' + scoreParam + '/100</strong>.';
  }

  /* ---- Score display ---- */
  var scoreEl = document.getElementById('apn-a-score-display');
  if (scoreEl) {
    scoreEl.textContent = scoreParam + '/100';
  }

  /* ---- Gap data map ---- */
  var gapData = {
    sleep: {
      label: 'Sleep',
      urgency: 'critical',
      cost: 'At the Athlete tier, sleep precision is a more common limiter than sleep duration. Wake time variability of 60 to 90 minutes between weekdays and weekends disrupts the circadian clock, which suppresses HRV by an average of 8 to 12% and reduces next-day cognitive performance and reaction time measurably. You are sleeping enough hours. You are not sleeping them consistently enough.',
      action: 'Tighten wake time to within 20 minutes every day. Set magnesium glycinate 400mg 30 minutes before bed. Track sleep quality score alongside HRV each morning for 14 days to confirm the improvement is real.'
    },
    recovery: {
      label: 'Recovery',
      urgency: 'critical',
      cost: 'At the Athlete tier, incomplete recovery between training sessions is the most common performance ceiling. The body needs 48 to 72 hours to complete protein synthesis and glycogen resynthesis after a high-intensity session. Training before this window closes produces diminishing returns on adaptation and compounding central nervous system fatigue. HRV data is the most reliable way to confirm recovery is complete.',
      action: 'Use HRV to determine training readiness each day. On low-HRV days, reduce intensity to 60 to 70% of normal or substitute active recovery. This is not backing off. It is maximizing the training sessions that actually produce adaptation.'
    },
    nutrition: {
      label: 'Nutrition',
      urgency: 'critical',
      cost: 'At the Athlete tier, nutrition precision is the gap. Total protein is likely close to adequate. The issue is distribution, timing, and carbohydrate periodization around training. Skipping pre-training carbohydrates when training sessions exceed 60 minutes impairs glycolytic output in the second half of the session, directly reducing training volume and therefore adaptation stimulus.',
      action: 'Audit protein distribution across the day. If two of four feedings are below 20g, redistribution is the priority. Add a pre-training carbohydrate source (30 to 50g of simple carbohydrates 30 to 45 minutes before sessions longer than 60 minutes) and measure the effect on session quality scores.'
    },
    hydration: {
      label: 'Hydration',
      urgency: 'moderate',
      cost: 'At training volumes typical for Athlete-tier athletes, sweat sodium losses are significant and plain water rehydration is insufficient for full electrolyte restoration. Sodium depletion reduces plasma volume, which increases cardiovascular strain during training and reduces endurance capacity. This is common in athletes who sweat heavily and only drink water.',
      action: 'Add an electrolyte source with sodium to your intra-training hydration protocol. Target 500 to 750mg of sodium per liter of fluid during training sessions exceeding 60 minutes. Replenish within the first 30 minutes post-training when sweat losses were high.'
    },
    training: {
      label: 'Training Structure',
      urgency: 'moderate',
      cost: 'At the Athlete tier, the training structure gap typically manifests as insufficient periodization rather than absence of a program. Training at a constant intensity across all sessions, without planned deload weeks or wave-loading volume, produces accumulated fatigue without corresponding supercompensation. The body adapts to the specific stimulus applied. If the stimulus does not vary systematically, adaptation plateaus.',
      action: 'Implement a basic periodization structure: 3 weeks of progressively increasing volume followed by 1 deload week at 60% volume. Track session quality scores across the cycle. You should see quality scores peak in Week 2, decline slightly in Week 3, and rebound in the deload week and the following training block.'
    },
    mental: {
      label: 'Mental Performance',
      urgency: 'moderate',
      cost: 'At the Athlete tier, cognitive performance during competition or high-stakes training is the relevant metric. Decision speed under fatigue, sustained attention across long training sessions, and arousal regulation before competition are all measurable. Chronic psychological stress suppresses prefrontal cortex function, which governs exactly these capacities.',
      action: 'Add a 5-minute breathing protocol before training: 5-second inhale, 5-second exhale, for 10 cycles. This activates the parasympathetic nervous system and has demonstrated measurable improvements in HRV and reaction time in pre-training contexts. Simple. Specific. Measurable.'
    },
    stress: {
      label: 'Stress Management',
      urgency: 'moderate',
      cost: 'Training stress and life stress share the same physiological pathway. Cortisol does not distinguish between a heavy squat session and a difficult work deadline. Athletes managing high external stress loads have effectively reduced recovery capacity even on rest days. This shows up as chronically suppressed HRV and slower performance progression than training load would predict.',
      action: 'Track stress load alongside HRV. Rate daily external stress on a 1 to 5 scale each morning. Over 2 weeks, check whether high-stress days correlate with suppressed HRV. If yes, adjust training intensity downward on high-stress days using the same HRV decision rule as physiological stress.'
    },
    supplements: {
      label: 'Supplementation',
      urgency: 'manageable',
      cost: 'At the Athlete tier, the supplement gap is usually not absence of products but imprecision in timing and dosing. Creatine taken inconsistently (4 of 7 days) never fully saturates. Post-training protein delayed by 2 to 3 hours misses the peak mTOR activation window. Magnesium taken at random times does not consistently improve sleep architecture. The products may already be present. The protocols are not.',
      action: 'Map every supplement to a specific time, dose, and behavioral anchor (a meal, a training session, bedtime). Execute the timing protocol for 14 consecutive days. Measure whether the change in timing produces measurable HRV or performance improvements.'
    }
  };

  var urgencyLabels = {
    critical: 'Critical',
    moderate: 'Moderate',
    manageable: 'Manageable'
  };
  var urgencyClass = {
    critical: 'gap-urgency--critical',
    moderate: 'gap-urgency--moderate',
    manageable: 'gap-urgency--manageable'
  };

  function getGapInfo(key) {
    return gapData[key] || {
      label: key.charAt(0).toUpperCase() + key.slice(1),
      urgency: 'moderate',
      cost: 'This pillar is limiting your ceiling. The dedicated MasterClass contains a precision protocol for this gap at the Athlete tier level.',
      action: 'Review the dedicated MasterClass for this gap. Apply the Athlete-tier protocol with specific measurable targets.'
    };
  }

  function buildGapCard(gapKey, index) {
    var info = getGapInfo(gapKey);
    var priority = ['PRIMARY', 'SECONDARY', 'TERTIARY'][index];
    var url = '/pages/masterclass-' + gapKey.toLowerCase().replace(/\s+/g, '-');
    return '<div class="apn-a-gap-card">' +
      '<div class="gap-meta">' +
        '<span class="gap-name">' + priority + ': ' + info.label + '</span>' +
        '<span class="gap-urgency ' + urgencyClass[info.urgency] + '">' + urgencyLabels[info.urgency] + '</span>' +
      '</div>' +
      '<p>' + info.cost + '</p>' +
      '<p style="color:var(--body); font-weight:600;">' + info.action + '</p>' +
      '<a href="' + url + '">Go to ' + info.label + ' MasterClass &rarr;</a>' +
    '</div>';
  }

  var gaps = [gap1Param, gap2Param, gap3Param];

  /* ---- Gap snapshot cards ---- */
  var gapContainer = document.getElementById('apn-a-gap-container');
  if (gapContainer) {
    var html = '';
    for (var i = 0; i < gaps.length; i++) {
      html += buildGapCard(gaps[i], i);
    }
    gapContainer.innerHTML = html;
  }

  /* ---- Gap link cards (Module 7) ---- */
  var gapLinks = document.getElementById('apn-a-gap-links');
  if (gapLinks) {
    var linkHtml = '<div style="display:grid; gap:16px;">';
    for (var j = 0; j < gaps.length; j++) {
      var info = getGapInfo(gaps[j]);
      var url = '/pages/masterclass-' + gaps[j].toLowerCase().replace(/\s+/g, '-');
      var priority = ['Gap 1: Primary Bottleneck', 'Gap 2: Secondary', 'Gap 3: Tertiary'][j];
      var desc = ['Your bottleneck. This gap is capping your ceiling more than any other. Start here.', 'Address after you have 14 days of data showing Gap 1 is improving.', 'Third in order. Gains here accelerate after the first two gaps are closing.'][j];
      linkHtml += '<a href="' + url + '" class="apn-a-next-card">' +
        '<span class="next-card-label">' + priority + '</span>' +
        '<div class="next-card-title">' + info.label + ' MasterClass</div>' +
        '<p class="next-card-desc">' + desc + '</p>' +
      '</a>';
    }
    linkHtml += '</div>';
    gapLinks.innerHTML = linkHtml;
  }

  /* ---- Gap-targeted 4th product ---- */
  var gapProductEl = document.getElementById('apn-a-gap-product');
  if (gapProductEl) {
    var gapProducts = {
      sleep: {
        name: 'Function. Magnesium Glycinate.',
        price: '$19.99',
        mechanism: 'Mechanism: GABA Potentiation and Sleep Architecture',
        desc: 'If sleep is your primary gap, magnesium glycinate is your targeted fourth product. Already included in the core stack above, this doubles down on the sleep architecture improvement. 400mg before bed, consistent nightly use, minimum 14 days to assess impact. Track sleep quality score alongside HRV.',
        protocol: '400mg magnesium glycinate 30 to 60 minutes before bed. Consistent nightly use is required. Effects are not acute. They accumulate over 7 to 14 days of consistent use.'
      },
      recovery: {
        name: 'Adapt. Ashwagandha.',
        price: '$29.99',
        mechanism: 'Mechanism: HPA Axis Modulation and Cortisol Reduction',
        desc: 'If recovery is your primary gap, ashwagandha (KSM-66 extract, the most studied form) is your targeted addition. The mechanism is HPA axis modulation: ashwagandha reduces cortisol by 14 to 28% in athletes under training stress according to multiple randomized controlled trials. Lower chronic cortisol means faster recovery, better sleep architecture, and improved lean mass preservation under heavy training loads.',
        protocol: '300 to 600mg KSM-66 ashwagandha extract daily. With food to improve absorption. Morning or evening. Consistent daily use required. Effect is cumulative over 4 to 8 weeks.'
      },
      nutrition: {
        name: 'Nourish. Greens and Reds Superfood.',
        price: '$49.99',
        mechanism: 'Mechanism: Micronutrient Density and Antioxidant Support',
        desc: 'If nutrition is your primary gap and micronutrient quality is part of the issue, Nourish provides a concentrated source of vitamins, minerals, and phytonutrients that are consistently below optimal in performance athlete diets. Athletes training 4 to 5 times per week have elevated requirements for antioxidants (to manage exercise-induced oxidative stress) and B vitamins (for energy metabolism). Most whole-food diets at adequate calories still fall short of these elevated requirements.',
        protocol: 'One serving daily, mixed with water. Morning, with or without food. Use alongside whole food meals, not as a replacement. This supplements the dietary foundation. It does not replace it.'
      },
      hydration: {
        name: 'Replenish. Hydration Powder.',
        price: '$34.99',
        mechanism: 'Mechanism: Electrolyte Replacement and Plasma Volume Maintenance',
        desc: 'If hydration is your primary gap, Replenish provides the sodium, potassium, and magnesium ratio required for full electrolyte restoration after training. The specific issue for Athlete-tier athletes is not total water intake but sodium replacement. Sweat rates of 1 to 2 liters per hour with sodium concentrations of 500 to 1,000mg per liter mean that plain water rehydration produces dilution hyponatremia in athletes who sweat heavily and train for 60-plus minutes.',
        protocol: 'One serving during or immediately after training sessions exceeding 60 minutes. Additional serving on hot-weather training days. Do not use pre-training: osmolality of the formula is optimized for intra or post-training use.'
      },
      mental: {
        name: 'Clarity. Methylene Blue Drops.',
        price: '$39.99',
        mechanism: 'Mechanism: Mitochondrial Electron Transport and Cognitive Function',
        desc: 'If mental performance is your primary gap, Clarity supports cognitive function at the mitochondrial level. Methylene blue acts as an alternative electron carrier in the mitochondrial electron transport chain, supporting ATP production in neurons even under hypoxic or metabolic stress conditions. Research on methylene blue shows improvements in memory consolidation, processing speed, and sustained attention. For athletes whose competitive performance involves real-time decision-making under fatigue, this is a specific, mechanism-backed cognitive support tool.',
        protocol: 'Low-dose protocol: 0.5 to 1mg per kg bodyweight, taken 30 to 60 minutes before training or competition. Do not exceed recommended dose. Start at the lower end of the range and assess tolerance over 7 days before increasing.'
      }
    };

    var defaultProduct = {
      name: 'Balance. Platinum Turmeric.',
      price: '$29.99',
      mechanism: 'Mechanism: NF-kB Pathway Inhibition and Systemic Inflammation Reduction',
      desc: 'For athletes whose primary gap relates to inflammation, recovery, or joint function, Balance provides curcumin (the active compound in turmeric) with enhanced bioavailability. Standard turmeric has poor bioavailability. The Platinum formula addresses this with piperine co-administration, which increases curcumin bioavailability by up to 2,000% according to published research. The mechanism is NF-kB pathway inhibition, reducing the pro-inflammatory cytokine cascade that contributes to delayed-onset muscle soreness and systemic inflammation under heavy training loads.',
      protocol: '500 to 1,000mg curcumin equivalent daily, taken with food containing fat (curcumin is fat-soluble). Consistent daily use required. Anti-inflammatory effects are cumulative and measurable after 4 to 6 weeks of consistent use.'
    };

    var gapProd = gapProducts[gap1Param] || defaultProduct;

    gapProductEl.innerHTML = '<div class="apn-a-product-card" style="border: 2px solid rgba(6,165,197,0.3);">' +
      '<div style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:16px;">' +
        '<div>' +
          '<span style="font-family:var(--font); font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--tier-blue); display:block; margin-bottom:4px;">Gap-Targeted Product (Based on Your Gap 1)</span>' +
          '<div class="prod-name">' + gapProd.name + '</div>' +
        '</div>' +
        '<div class="prod-price">' + gapProd.price + '</div>' +
      '</div>' +
      '<span class="prod-mechanism">' + gapProd.mechanism + '</span>' +
      '<p>' + gapProd.desc + '</p>' +
      '<div class="prod-protocol"><strong>Protocol:</strong> ' + gapProd.protocol + '</div>' +
    '</div>';
  }

})();
</script>

