<script>
(function(){
  var NODES=[{id:1,tag:'Core Fatty Acid',name:'EPA',amount:'180mg',desc:'Eicosapentaenoic acid at 180mg per softgel from fish oil concentrate. EPA is the primary omega-3 for cardiovascular support and inflammation modulation.',icon:'<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:2,tag:'Brain Health',name:'DHA',amount:'120mg',desc:'Docosahexaenoic acid at 120mg per softgel. DHA is a structural fat of the brain and retina, essential for cognitive function and visual acuity.',icon:'<circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M6 20v-2a6 6 0 0 1 12 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'},{id:3,tag:'Fish Oil',name:'Fish Oil Concentrate',amount:'1,000mg',desc:'1,000mg fish oil concentrate per softgel. Sourced from Sardines and Anchovies. Contains Fish allergen.',icon:'<path d="M3 3v18h18M3 9l6-2 4 4 5-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:4,tag:'Antioxidant',name:'Vitamin E',amount:'In Softgel',desc:'Vitamin E is included as a natural antioxidant to protect the fish oil from oxidation and extend freshness.',icon:'<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>'},{id:5,tag:'Allergen',name:'Contains Fish',amount:'Sardines, Anchovies',desc:'This product contains Fish (Sardines, Anchovies). Do not take if you have a fish or seafood allergy.',icon:'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:6,tag:'Serving Profile',name:'Per Softgel',amount:'100 Servings',desc:'1 softgel daily with a meal that contains fat. Refrigerate after opening to maintain freshness. 100 softgels per container.',icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'}];
  var CX=330,CY=330,RADIUS=250,rotation=0,speed=0.18,activeId=null,paused=false;
  var nodesEl=document.getElementById('wheel-nodes'),lineEl=document.getElementById('wheel-line'),panel=document.getElementById('wheel-detail-panel');
  var nodeEls={},labelEls={};
  NODES.forEach(function(n){var div=document.createElement('div');div.className='wnode';div.id='wnode-'+n.id;div.innerHTML='<svg width="20" height="20" viewBox="0 0 24 24" style="color:#9ca3af">'+n.icon+'</svg>';div.addEventListener('click',function(e){e.stopPropagation();toggleNode(n.id);});nodesEl.appendChild(div);nodeEls[n.id]=div;var lbl=document.createElement('div');lbl.className='wnode-label';lbl.id='wlbl-'+n.id;lbl.textContent=n.name;nodesEl.appendChild(lbl);labelEls[n.id]=lbl;});
  function getPos(i,t,a){var deg=(i/t)*360+a;var rad=(deg*Math.PI)/180;return{x:CX+RADIUS*Math.cos(rad),y:CY+RADIUS*Math.sin(rad),rad:rad};}
  function updatePositions(){NODES.forEach(function(n,i){var p=getPos(i,NODES.length,rotation);var depth=(Math.sin(p.rad)+1)/2;var opacity=0.35+0.65*depth;nodeEls[n.id].style.left=p.x+'px';nodeEls[n.id].style.top=p.y+'px';nodeEls[n.id].style.zIndex=Math.round(10+20*depth);if(!nodeEls[n.id].classList.contains('active'))nodeEls[n.id].style.opacity=opacity;var outX=p.x+Math.cos(p.rad)*38;var outY=p.y+Math.sin(p.rad)*38;labelEls[n.id].style.left=(outX-45)+'px';labelEls[n.id].style.top=(outY-9)+'px';if(!labelEls[n.id].classList.contains('active'))labelEls[n.id].style.opacity=opacity*0.75;});}
  function loop(){if(!paused)rotation=(rotation+speed)%360;updatePositions();requestAnimationFrame(loop);}loop();
  function toggleNode(id){if(activeId===id){deactivate();return;}activeId=id;paused=true;NODES.forEach(function(n){var el=nodeEls[n.id];var lbl=labelEls[n.id];if(n.id===id){el.classList.add('active');el.querySelector('svg').style.color='#fff';lbl.classList.add('active');lbl.style.color='#06A5C5';lbl.style.opacity='1';}else{el.classList.remove('active');el.querySelector('svg').style.color='#9ca3af';lbl.classList.remove('active');}});var idx=NODES.findIndex(function(n){return n.id===id;});var p=getPos(idx,NODES.length,rotation);lineEl.setAttribute('x1',CX);lineEl.setAttribute('y1',CY);lineEl.setAttribute('x2',p.x);lineEl.setAttribute('y2',p.y);lineEl.setAttribute('opacity','0.4');var node=NODES.find(function(n){return n.id===id;});document.getElementById('wdp-tag').textContent=node.tag;document.getElementById('wdp-name').textContent=node.name;document.getElementById('wdp-amount').textContent=node.amount;document.getElementById('wdp-desc').textContent=node.desc;panel.style.opacity='1';panel.style.transform='translateY(0)';panel.style.pointerEvents='auto';}
  function deactivate(){activeId=null;paused=false;NODES.forEach(function(n){nodeEls[n.id].classList.remove('active');nodeEls[n.id].querySelector('svg').style.color='#9ca3af';labelEls[n.id].classList.remove('active');});lineEl.setAttribute('opacity','0');panel.style.opacity='0';panel.style.transform='translateY(10px)';panel.style.pointerEvents='none';}
  document.getElementById('wheel-wrap').addEventListener('click',function(e){if(e.target===this||e.target.id==='wheel-svg'||e.target.tagName==='circle'||e.target.tagName==='line')deactivate();});
})();
</script>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;"><p class="section-label" style="margin-bottom:0.75rem;">Directions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin-bottom:3.5rem;">How to Use Omega-3</h2>
  <div class="how-to-steps-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:left;"><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">1</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Take It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Swallow 1 softgel with a meal that contains fat. The fat in the meal triggers bile secretion, which is required for omega-3 absorption.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">2</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Refrigerate</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">After opening, refrigerate the bottle to prevent oxidation. Oxidized fish oil is less effective and can cause the fishy aftertaste or burps that people associate with fish oil.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">3</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Be Consistent</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Raising your Omega-3 Index takes time. Consistent daily use for 3-4 months is typically required to move from a low index to the optimal 8%+ range.</p></div></div>
  <p style="margin-top:1.75rem;font-size:0.8rem;color:#4b5563;">Store in a cool, dry place. Keep out of reach of children. Consult a healthcare professional before use if you have any medical conditions.</p></div>
</section>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;" id="faq"><div style="max-width:700px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Questions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">Frequently Asked</h2></div><div id="faq-list"></div></div></section>
<section style="background:#0a0a0a;padding:6rem 1.5rem;" id="reviews"><div style="max-width:800px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Reviews</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">What Athletes Say</h2></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem 2.5rem;"><div style="display:flex;align-items:flex-start;gap:1.25rem;"><div style="width:48px;height:48px;background:linear-gradient(135deg,#06A5C5,#048FAB);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;">M</div><div style="flex:1;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.25rem;"><span style="font-weight:700;color:#F8FAFB;">Mike O.</span><span class="stars" style="font-size:0.9rem;">★★★★★</span><span style="font-size:0.75rem;color:#6b7280;margin-left:auto;">Verified Purchase</span></div><p style="font-size:0.875rem;color:#6b7280;margin-bottom:0.75rem;">February 2025</p><p style="color:#9ca3af;line-height:1.7;font-size:0.9375rem;">I have tried a lot of fish oil and always noticed the cheap ones. Omega-3 from Ascend has zero fishy taste or burps when taken with food. My joint recovery from long runs has improved noticeably over two months of use and my last bloodwork showed improved triglycerides. Clean product.</p></div></div></div></div></section>
<script>
  function setImg(thumb,src){document.querySelectorAll('.thumb').forEach(function(t){t.classList.remove('active');});thumb.classList.add('active');var mainImg=document.getElementById('main-img');mainImg.style.opacity='0';setTimeout(function(){mainImg.src=src;mainImg.style.opacity='1';},150);}
  var FAQS=[{q:'What is in Omega-3?',a:'Each softgel contains 1,000mg of fish oil concentrate providing 180mg EPA and 120mg DHA. Other Ingredients: Softgel (gelatin, glycerin and water) and Vitamin E. Contains Fish (Sardines, Anchovies). 100 softgels per container, 1 softgel per serving.'},{q:'Will Omega-3 cause fishy burps?',a:'Taking the softgel with a meal that contains fat typically reduces the likelihood of fishy aftertaste. Refrigerating the bottle after opening also helps maintain freshness.'},{q:'How long until I notice benefits?',a:'Omega-3 benefits accumulate over time. Joint and inflammation improvements are often noticed within 4 to 8 weeks. Cardiovascular benefits develop over months of consistent use. Cognitive benefits can take 3 to 6 months.'},{q:'Can I take Omega-3 with other Ascend products?',a:'Yes. Omega-3 pairs well with the full Ascend stack. There are no interactions to be concerned about. Taking it with Foundation at the same meal with fat is a convenient approach.'}];
  (function renderFAQ(){var list=document.getElementById('faq-list');FAQS.forEach(function(f){var item=document.createElement('div');item.className='faq-item';item.innerHTML='<button class="faq-btn" aria-expanded="false" onclick="toggleFAQ(this)"><span>'+f.q+'</span><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg></button><div class="faq-body"><p>'+f.a+'</p></div>';list.appendChild(item);});})();
  function toggleFAQ(btn){var expanded=btn.getAttribute('aria-expanded')==='true';document.querySelectorAll('.faq-btn').forEach(function(b){b.setAttribute('aria-expanded','false');b.nextElementSibling.classList.remove('open');});if(!expanded){btn.setAttribute('aria-expanded','true');btn.nextElementSibling.classList.add('open');}}
  function addToCart(){
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({id: '{{ product.variants.first.id }}', quantity: 1})
    }).then(() => { window.location = '/cart'; });
  }
</script>
