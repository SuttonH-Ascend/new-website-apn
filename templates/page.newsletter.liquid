<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Barlow+Condensed:wght@500;600;700;800;900&display=swap" rel="stylesheet"/>

<style>
  .nl-page-wrap *,.nl-page-wrap *::before,.nl-page-wrap *::after{box-sizing:border-box;}

  .nl-grain{position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");background-size:200px 200px;pointer-events:none;z-index:0;opacity:0.6;}
  .nl-atmosphere{position:fixed;inset:0;background:radial-gradient(ellipse 80% 60% at 20% 10%,rgba(6,165,197,0.13) 0%,transparent 65%),radial-gradient(ellipse 60% 80% at 85% 80%,rgba(4,143,171,0.09) 0%,transparent 60%),radial-gradient(ellipse 50% 50% at 50% 50%,rgba(6,165,197,0.04) 0%,transparent 70%);pointer-events:none;z-index:0;}

  .nl-page-wrap{position:relative;z-index:1;min-height:100vh;display:grid;grid-template-columns:1fr 1fr;font-family:'Barlow',system-ui,sans-serif;color:#F8FAFB;}

  .nl-hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;overflow:hidden;}
  .nl-hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;}
  .nl-hero-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(6,9,10,0.25) 0%,transparent 55%),linear-gradient(to top,rgba(6,9,10,0.95) 0%,rgba(6,9,10,0.55) 40%,rgba(6,9,10,0.1) 80%);}
  .nl-hero-tint{position:absolute;inset:0;background:rgba(6,165,197,0.07);mix-blend-mode:multiply;}
  .nl-hero-content{position:relative;z-index:2;padding:3rem;}

  .nl-form-panel{position:relative;display:flex;flex-direction:column;justify-content:center;padding:4rem 3.5rem;background:rgba(10,12,14,0.9);backdrop-filter:blur(2px);border-left:1px solid rgba(255,255,255,0.05);}

  .nl-logo{display:flex;align-items:center;gap:0.75rem;margin-bottom:3rem;text-decoration:none;}
  .nl-logo img{height:48px;width:auto;}
  .nl-logo-div{width:1px;height:28px;background:rgba(255,255,255,0.12);}
  .nl-logo-text{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.625rem;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.55);line-height:1.3;}

  .nl-label{display:inline-flex;align-items:center;gap:0.5rem;font-family:'Barlow Condensed',sans-serif;font-size:0.625rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#06A5C5;margin-bottom:1.125rem;}
  .nl-label::before{content:'';display:block;width:20px;height:1px;background:#06A5C5;}

  .nl-headline{font-family:Georgia,serif;font-size:clamp(2.25rem,3.5vw,3rem);font-weight:700;letter-spacing:-0.03em;line-height:1.08;color:#F8FAFB;margin-bottom:1rem;}
  .nl-accent{color:#06A5C5;}
  .nl-sub{font-size:1rem;line-height:1.7;color:rgba(248,250,251,0.58);max-width:380px;margin-bottom:2.5rem;}

  .nl-stats{display:flex;gap:0.875rem;flex-wrap:wrap;}
  .nl-stat{background:rgba(6,9,10,0.72);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.75rem 1.125rem;backdrop-filter:blur(8px);}
  .nl-stat-val{font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;color:#06A5C5;line-height:1;margin-bottom:0.2rem;}
  .nl-stat-lbl{font-size:0.6875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:rgba(248,250,251,0.4);}

  .nl-social{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;}
  .nl-avatars{display:flex;}
  .nl-avatar{width:32px;height:32px;border-radius:50%;border:2px solid #06090A;overflow:hidden;margin-left:-8px;}
  .nl-avatar:first-child{margin-left:0;}
  .nl-avatar img{width:100%;height:100%;object-fit:cover;}
  .nl-social-txt{font-size:0.8125rem;color:rgba(248,250,251,0.5);line-height:1.45;}
  .nl-social-txt strong{color:#F8FAFB;}

  .nl-benefits{display:flex;flex-direction:column;gap:0.875rem;margin-bottom:2.5rem;}
  .nl-benefit{display:flex;align-items:flex-start;gap:0.75rem;}
  .nl-check{flex-shrink:0;width:20px;height:20px;border-radius:50%;background:rgba(6,165,197,0.15);border:1px solid rgba(6,165,197,0.3);display:flex;align-items:center;justify-content:center;margin-top:0.1rem;}
  .nl-benefit-txt{font-size:0.9rem;line-height:1.5;color:rgba(248,250,251,0.72);}
  .nl-benefit-txt strong{color:#F8FAFB;font-weight:600;}

  .nl-divider{display:flex;align-items:center;gap:0.75rem;margin:1.375rem 0;}
  .nl-divider::before,.nl-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.07);}
  .nl-divider span{font-size:0.6875rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.2);}

  .nl-form-group{display:flex;flex-direction:column;gap:0.5rem;margin-bottom:0.875rem;}
  .nl-label-sm{font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(248,250,251,0.45);}
  .nl-input{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:8px;padding:0.875rem 1rem;font-family:'Barlow',sans-serif;font-size:0.9375rem;color:#F8FAFB;outline:none;transition:border-color 0.18s ease,background 0.18s ease,box-shadow 0.18s ease;width:100%;}
  .nl-input::placeholder{color:rgba(255,255,255,0.18);}
  .nl-input:hover{border-color:rgba(6,165,197,0.28);}
  .nl-input:focus{border-color:#06A5C5;background:rgba(6,165,197,0.05);box-shadow:0 0 0 3px rgba(6,165,197,0.1);}

  .nl-btn{width:100%;padding:1rem 1.5rem;border-radius:8px;border:none;background:linear-gradient(135deg,#048FAB 0%,#06A5C5 60%,#07B8DC 100%);color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:0.9375rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;cursor:pointer;margin-top:0.375rem;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;gap:0.625rem;box-shadow:0 4px 18px rgba(6,165,197,0.38),0 1px 3px rgba(0,0,0,0.4);transition:transform 0.18s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.18s ease,opacity 0.18s ease;}
  .nl-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.12) 0%,transparent 60%);pointer-events:none;}
  .nl-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(6,165,197,0.5),0 2px 6px rgba(0,0,0,0.4);}
  .nl-btn:active{transform:translateY(0);}
  .nl-btn:focus-visible{outline:2px solid #06A5C5;outline-offset:3px;}
  .nl-btn:disabled{opacity:0.55;cursor:not-allowed;transform:none;}

  .nl-privacy{margin-top:1rem;font-size:0.75rem;color:rgba(255,255,255,0.28);line-height:1.55;text-align:center;}
  .nl-privacy a{color:rgba(6,165,197,0.55);text-decoration:none;transition:color 0.15s ease;}
  .nl-privacy a:hover{color:#06A5C5;}

  .nl-error{display:none;font-size:0.8125rem;color:#F87171;margin-bottom:0.5rem;padding:0.5rem 0.75rem;background:rgba(248,113,113,0.08);border-radius:6px;border:1px solid rgba(248,113,113,0.2);}

  .nl-success{display:none;text-align:center;padding:1.5rem 0;}
  .nl-success-icon{width:64px;height:64px;border-radius:50%;background:rgba(6,165,197,0.12);border:1px solid rgba(6,165,197,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;}
  .nl-success-title{font-family:Georgia,serif;font-size:1.875rem;font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin-bottom:0.75rem;}
  .nl-success-sub{font-size:0.9375rem;line-height:1.65;color:rgba(248,250,251,0.5);}
  .nl-back{display:inline-flex;align-items:center;gap:0.5rem;margin-top:2rem;font-family:'Barlow Condensed',sans-serif;font-size:0.8125rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#06A5C5;text-decoration:none;transition:opacity 0.18s ease;}
  .nl-back:hover{opacity:0.65;}

  @media(max-width:768px){
    .nl-page-wrap{grid-template-columns:1fr;}
    .nl-hero{min-height:52vh;}
    .nl-hero-content{padding:2rem 1.5rem;}
    .nl-headline{font-size:1.875rem;}
    .nl-sub{font-size:0.875rem;}
    .nl-form-panel{padding:2.5rem 1.5rem;border-left:none;border-top:1px solid rgba(255,255,255,0.05);}
    .nl-logo{margin-bottom:2rem;}
    .nl-stat{padding:0.625rem 0.875rem;}
    .nl-stat-val{font-size:1.25rem;}
  }
  @media(max-width:480px){
    .nl-stats{gap:0.625rem;}
    .nl-hero{min-height:42vh;}
  }
</style>

<div class="nl-grain" aria-hidden="true"></div>
<div class="nl-atmosphere" aria-hidden="true"></div>

<div class="nl-page-wrap">

  <!-- LEFT: Hero -->
  <div class="nl-hero">
    <img class="nl-hero-img" src="{{ 'fitness.webp' | asset_url }}" alt="Athlete in training" />
    <div class="nl-hero-overlay" aria-hidden="true"></div>
    <div class="nl-hero-tint" aria-hidden="true"></div>

    <div class="nl-hero-content">
      <div class="nl-label">Locker Room</div>
      <h1 class="nl-headline">
        Train Smarter.<br />
        <span class="nl-accent">Recover Harder.</span><br />
        Win More.
      </h1>
      <p class="nl-sub">
        The APN newsletter is where athletes get the edge - protocols, drops, and intel the public never sees.
      </p>

      <div class="nl-stats">
        <div class="nl-stat">
          <div class="nl-stat-val">24K+</div>
          <div class="nl-stat-lbl">Athletes</div>
        </div>
        <div class="nl-stat">
          <div class="nl-stat-val">3x</div>
          <div class="nl-stat-lbl">Per Week</div>
        </div>
        <div class="nl-stat">
          <div class="nl-stat-val">0</div>
          <div class="nl-stat-lbl">Spam. Ever.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: Form -->
  <div class="nl-form-panel">

    <a href="/" class="nl-logo">
      <img src="{{ 'ascend real 1_2 trans.png' | asset_url }}" alt="Ascend Performance Nutrition" />
      <div class="nl-logo-div"></div>
      <div class="nl-logo-text">Performance<br />Nutrition</div>
    </a>

    <div id="nl-form-wrap">

      <div class="nl-label">Free to join</div>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.625rem,2.5vw,2.125rem);font-weight:700;letter-spacing:-0.03em;line-height:1.1;color:#F8FAFB;margin-bottom:0.875rem;">
        Join the Locker Room
      </h2>
      <p style="font-size:0.875rem;line-height:1.7;color:rgba(248,250,251,0.48);margin-bottom:1.75rem;">
        Exclusive protocols, first access to new products, and member-only discounts. Straight to your inbox.
      </p>

      <div class="nl-social">
        <div class="nl-avatars">
          <div class="nl-avatar"><img src="{{ 'founderpic.jpg' | asset_url }}" alt="" /></div>
          <div class="nl-avatar" style="background:linear-gradient(135deg,#0a2530,#06A5C5);"></div>
          <div class="nl-avatar" style="background:linear-gradient(135deg,#1a1a1a,#2a2a2a);"></div>
          <div class="nl-avatar" style="background:linear-gradient(135deg,#0d1f26,#048FAB);"></div>
        </div>
        <div class="nl-social-txt">
          Join <strong>24,000+ athletes</strong><br />already in the Locker Room
        </div>
      </div>

      <div class="nl-benefits">
        <div class="nl-benefit">
          <div class="nl-check"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div class="nl-benefit-txt"><strong>15% off your first order</strong> - exclusive subscriber code</div>
        </div>
        <div class="nl-benefit">
          <div class="nl-check"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div class="nl-benefit-txt"><strong>Performance protocols</strong> curated by certified coaches</div>
        </div>
        <div class="nl-benefit">
          <div class="nl-check"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div class="nl-benefit-txt"><strong>Early access</strong> to new product launches and limited drops</div>
        </div>
        <div class="nl-benefit">
          <div class="nl-check"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div class="nl-benefit-txt"><strong>Flash sales and restocks</strong> - members get 24h head start</div>
        </div>
      </div>

      <div class="nl-divider"><span>Sign up free</span></div>

      <form id="nl-form" onsubmit="nlHandleSubmit(event)" novalidate>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div class="nl-form-group">
            <label class="nl-label-sm" for="nl-first">First Name</label>
            <input class="nl-input" type="text" id="nl-first" name="first_name" placeholder="Austin" autocomplete="given-name" />
          </div>
          <div class="nl-form-group">
            <label class="nl-label-sm" for="nl-last">Last Name</label>
            <input class="nl-input" type="text" id="nl-last" name="last_name" placeholder="Rhodes" autocomplete="family-name" />
          </div>
        </div>

        <div class="nl-form-group">
          <label class="nl-label-sm" for="nl-email">Email Address</label>
          <input class="nl-input" type="email" id="nl-email" name="email" placeholder="you@email.com" autocomplete="email" required />
        </div>

        <div id="nl-error" class="nl-error"></div>

        <button type="submit" class="nl-btn" id="nl-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
          <span id="nl-btn-text">Join the Locker Room</span>
        </button>

        <p class="nl-privacy">
          No spam. Unsubscribe anytime. By joining you agree to our
          <a href="/pages/privacy-policy">Privacy Policy</a>.
        </p>
      </form>
    </div>

    <div class="nl-success" id="nl-success">
      <div class="nl-success-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="nl-success-title">You're In.</div>
      <p class="nl-success-sub">
        Welcome to the Locker Room.<br />
        Check your inbox for your 15% discount code.
      </p>
      <a href="/" class="nl-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Ascend
      </a>
    </div>

  </div>
</div>

<script>
async function nlHandleSubmit(e) {
  e.preventDefault();
  const email = document.getElementById('nl-email').value.trim();
  const firstName = document.getElementById('nl-first').value.trim();
  const lastName = document.getElementById('nl-last').value.trim();
  const errEl = document.getElementById('nl-error');
  const btn = document.getElementById('nl-btn');
  const btnText = document.getElementById('nl-btn-text');

  errEl.style.display = 'none';

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errEl.textContent = 'Please enter a valid email address.';
    errEl.style.display = 'block';
    document.getElementById('nl-email').focus();
    return;
  }

  btn.disabled = true;
  btnText.textContent = 'Joining...';

  const profileAttrs = { email };
  if (firstName) profileAttrs.first_name = firstName;
  if (lastName) profileAttrs.last_name = lastName;

  try {
    const res = await fetch('https://a.klaviyo.com/client/subscriptions/?company_id=R5eNpH', {
      method: 'POST',
      headers: { 'Content-Type': 'application/vnd.api+json', 'revision': '2024-10-15' },
      body: JSON.stringify({
        data: {
          type: 'subscription',
          attributes: {
            list_id: 'RSeqfi',
            custom_source: 'Locker Room Opt-In Page',
            profiles: { data: [{ type: 'profile', attributes: profileAttrs }] }
          }
        }
      })
    });

    if (res.ok || res.status === 202) {
      document.getElementById('nl-form-wrap').style.display = 'none';
      const s = document.getElementById('nl-success');
      s.style.display = 'block';
      s.style.opacity = '0';
      s.style.transform = 'translateY(14px)';
      s.style.transition = 'opacity 0.4s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1)';
      requestAnimationFrame(() => { s.style.opacity = '1'; s.style.transform = 'translateY(0)'; });
    } else {
      throw new Error('failed');
    }
  } catch (err) {
    errEl.textContent = 'Something went wrong. Please try again.';
    errEl.style.display = 'block';
    btn.disabled = false;
    btnText.textContent = 'Join the Locker Room';
  }
}
</script>
