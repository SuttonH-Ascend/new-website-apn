<!-- ═══════════════════ SCRIPTS ═══════════════════ -->
<script>
(function() {

  // ─── PRODUCT IDENTITY ────────────────────────────────────────────
  var PRODUCT_HANDLE = {{ product.handle | json }};
  var PRODUCT_TITLE  = {{ product.title | json }};
  var PRODUCT_TYPE   = {{ product.type | json }};

  // ─── FAQ DATA ────────────────────────────────────────────────────
  // Prefer metafield, fall back to handle-keyed defaults
  var FAQS = {% if product.metafields.custom.faqs %}{{ product.metafields.custom.faqs.value | json }}{% else %}null{% endif %};

  if (!FAQS || !FAQS.length) {
    var faqDefaults = {
      'recharge': [
        { q: 'Do I need to do a loading phase?', a: 'No. A loading phase (20g/day for 5 days) saturates muscles faster, but the same result is achieved with daily 5g doses over 3-4 weeks. Both approaches work. If you want faster results, load. If you prefer simplicity, just take one scoop daily without interruption.' },
        { q: 'Will creatine cause water retention or bloating?', a: 'Creatine draws water into your muscle cells, which increases cellular volume and supports muscle fullness. This is different from subcutaneous water retention that causes a soft or bloated look. Most athletes notice increased fullness in the muscle belly, not puffiness.' },
        { q: 'When is the best time to take Recharge?', a: 'Consistency outweighs timing. Post-workout is a popular option since muscles may be more receptive to uptake, but daily use at any time produces the same saturation over a few weeks. Pick a time you will not forget.' },
        { q: 'Is Recharge truly unflavored? Will it taste like anything?', a: 'Yes, completely unflavored. Pure creatine monohydrate has minimal taste on its own and dissolves cleanly. Mix it into your protein shake, water, or juice without any change in flavor.' },
        { q: 'Can I stack Recharge with other Ascend products?', a: 'Yes. Recharge is designed to complement the full Ascend stack. It pairs especially well with Resilience (protein) for post-workout recovery and Replenish Plus (electrolytes) for hydration. Stack them without flavor interference.' }
      ],
      'resilience': [
        { q: 'What is the difference between whey isolate and whey concentrate?', a: 'Whey isolate undergoes additional filtration to remove most of the fat and lactose, resulting in a higher protein percentage per gram. Resilience uses 100% whey protein isolate — no concentrate — which means a cleaner profile, fewer calories from fat, and better tolerance for those sensitive to lactose.' },
        { q: 'Are both flavors made with the same formula?', a: 'Yes, with minor differences. Both use whey protein isolate, natural flavors, and stevia. The Chocolate flavor delivers 18g protein per 25g scoop. The Vanilla flavor delivers 19g protein per 24.4g scoop. Both have 90 calories per serving and the same clean three-ingredient profile.' },
        { q: 'Can I stack Resilience with Recharge?', a: 'Absolutely. Adding one scoop of Recharge (creatine) to your Resilience shake is a popular and effective post-workout stack. The unflavored creatine does not affect the taste of the protein.' },
        { q: 'How does Resilience mix?', a: 'Resilience is designed to mix easily with a shaker bottle or blender. Use 6-8 oz of water or milk for a thicker consistency, or 10-12 oz for a lighter shake. Avoid stirring — shake it.' },
        { q: 'Is Resilience suitable for people who are lactose intolerant?', a: 'Whey protein isolate contains very low levels of lactose due to the additional filtration process. Many people with mild lactose sensitivity tolerate whey isolate well. If you have severe lactose intolerance, consult your healthcare provider.' }
      ]
    };
    FAQS = faqDefaults[PRODUCT_HANDLE] || [];
  }

  // ─── HOW TO USE STEPS ───────────────────────────────────────────
  var HOW_TO = {% if product.metafields.custom.how_to_use %}{{ product.metafields.custom.how_to_use.value | json }}{% else %}null{% endif %};

  if (!HOW_TO || !HOW_TO.length) {
    var howToDefaults = {
      'recharge': [
        { num: '1', title: 'Mix It', body: 'Add 1 level scoop (5g) to 8 oz of water, juice, or your protein shake. Stir or shake until dissolved.' },
        { num: '2', title: 'Time It', body: 'Take daily, any time of day. Consistency matters more than timing. Post-workout or with a meal works well for most athletes.' },
        { num: '3', title: 'Load (Optional)', body: 'Accelerate saturation with a loading phase: 4 scoops daily (20g) spread across the day for 5 days, then drop to 1 scoop daily.' }
      ],
      'resilience': [
        { num: '1', title: 'Scoop', body: 'Add 1 scoop to your shaker bottle. Use 6-10 oz of water or milk depending on your preferred consistency.' },
        { num: '2', title: 'Shake', body: 'Seal your shaker and shake for 10-15 seconds until fully mixed. No blender needed — Resilience dissolves cleanly.' },
        { num: '3', title: 'Drink', body: 'Consume within 30-60 minutes post-workout for optimal muscle protein synthesis, or any time as a high-quality protein source.' }
      ]
    };
    HOW_TO = howToDefaults[PRODUCT_HANDLE] || [
      { num: '1', title: 'Prepare', body: 'Follow the serving instructions on the product label.' },
      { num: '2', title: 'Consume', body: 'Take as directed. Consistency is key for best results.' },
      { num: '3', title: 'Repeat', body: 'Use daily as part of your performance nutrition routine.' }
    ];
  }

  // ─── IMPACT STATS ────────────────────────────────────────────────
  var IMPACT_STATS = {% if product.metafields.custom.impact_stats %}{{ product.metafields.custom.impact_stats.value | json }}{% else %}null{% endif %};

  if (!IMPACT_STATS || !IMPACT_STATS.length) {
    var impactDefaults = {
      'recharge': [
        { value: '5,000', unit: 'mg', label: 'Pure Creatine Per Serving', desc: 'The clinical dose used in research. Every single scoop.' },
        { value: '50', unit: '', label: 'Servings Per Container', desc: '50 days of consistent fueling at the daily maintenance dose.' },
        { value: '#1', unit: '', label: 'Most Studied Supplement', desc: 'Creatine monohydrate is the most research-backed compound in sports science.' }
      ],
      'resilience': [
        { value: '18-19', unit: 'g', label: 'Protein Per Serving', desc: 'Whey protein isolate delivering a complete amino acid profile every scoop.' },
        { value: '28', unit: '', label: 'Servings Per Container', desc: '28 servings of premium whey protein isolate per tub.' },
        { value: '3', unit: '', label: 'Ingredients Only', desc: 'Whey protein isolate, natural flavors, stevia. Nothing else.' }
      ]
    };
    IMPACT_STATS = impactDefaults[PRODUCT_HANDLE] || [];
  }

  // ─── INGREDIENT WHEEL NODES ──────────────────────────────────────
  var NODES = {% if product.metafields.custom.ingredient_nodes %}{{ product.metafields.custom.ingredient_nodes.value | json }}{% else %}null{% endif %};

  if (!NODES || !NODES.length) {
    var nodeDefaults = {
      'recharge': [
        { id:1, tag:'Core Ingredient', name:'Creatine Monohydrate', amount:'5,000mg', desc:'The most researched performance compound in sports science. Every scoop delivers the full 5g clinical dose that drives strength, power, and lean body mass accumulation.', color:'#06A5C5', icon:'<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>' },
        { id:2, tag:'Mechanism', name:'ATP Regeneration', amount:'How It Works', desc:'Creatine phosphate donates a phosphate group to ADP, rapidly regenerating ATP during high-intensity effort. More ATP means more reps, more power, less fatigue between sets.', color:'#8B5CF6', icon:'<circle cx="12" cy="12" r="2" fill="currentColor"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>' },
        { id:3, tag:'Formula Purity', name:'Zero Fillers', amount:'100% Pure', desc:'No binders. No dyes. No flavoring agents. No anti-caking additives. One ingredient, one purpose. What you see on the label is all that is in the tub.', color:'#22C55E', icon:'<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' },
        { id:4, tag:'Muscle Saturation', name:'Loading Protocol', amount:'3-4 Weeks', desc:'Creatine accumulates in muscle tissue. Full saturation is reached in 3-4 weeks at 5g/day, or in 5-7 days with a 20g/day loading phase spread across 4 doses.', color:'#F59E0B', icon:'<path d="M3 3v18h18M3 9l6-2 4 4 5-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>' },
        { id:5, tag:'Versatility', name:'Unflavored', amount:'Stacks Clean', desc:'Dissolves completely in water, juice, or protein shakes without altering taste or texture. Add it to any beverage in your stack. No grit. No clumping.', color:'#06A5C5', icon:'<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
        { id:6, tag:'Value', name:'Serving Profile', amount:'50 x 5g', desc:'50 servings at 5g each. At the daily maintenance dose, one tub fuels 50 straight days of training. No rationing. No running out mid-cycle.', color:'#EF4444', icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' }
      ],
      'resilience': [
        { id:1, tag:'Core Ingredient', name:'Whey Protein Isolate', amount:'18-19g', desc:'Cold-processed whey protein isolate. Higher protein purity than concentrate. Lower fat, lower carbs, lower lactose. Complete amino acid profile in every serving.', color:'#06A5C5', icon:'<path d="M12 2a5 5 0 0 1 5 5c0 2.76-2.24 5-5 5S7 9.76 7 7a5 5 0 0 1 5-5z" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M3 21c0-4.42 4.03-8 9-8s9 3.58 9 8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
        { id:2, tag:'Amino Acids', name:'Leucine Content', amount:'~2g', desc:'Leucine is the primary anabolic trigger for muscle protein synthesis. Whey protein isolate is naturally high in leucine, making it an optimal choice for post-workout recovery and muscle building.', color:'#8B5CF6', icon:'<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>' },
        { id:3, tag:'Formula Purity', name:'3-Ingredient Formula', amount:'Nothing Else', desc:'Whey protein isolate, natural flavors, stevia. No soy. No fillers. No artificial sweeteners beyond stevia. The cleanest protein formula we could build.', color:'#22C55E', icon:'<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' },
        { id:4, tag:'Serving Size', name:'Scoop Weight', amount:'Choc 25g / Van 24.4g', desc:'Serving size is one scoop. Chocolate is 25g per scoop, Vanilla is 24.4g per scoop. Both deliver 90 calories and a complete amino acid profile per serving.', color:'#F59E0B', icon:'<path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" fill="none" stroke="currentColor" stroke-width="1.5"/>' },
        { id:5, tag:'Sweetener', name:'Stevia Only', amount:'No Sucralose', desc:'Sweetened exclusively with stevia — a natural, zero-calorie plant-derived sweetener. No sucralose, no acesulfame-K, no aspartame. Clean sweetness, clean formula.', color:'#06A5C5', icon:'<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
        { id:6, tag:'Value', name:'Serving Profile', amount:'28 Servings', desc:'28 servings per tub. At one shake per day, one tub fuels a full month of post-workout recovery nutrition. No cutting corners on protein content to inflate serving counts.', color:'#EF4444', icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' }
      ]
    };
    NODES = nodeDefaults[PRODUCT_HANDLE] || [];
  }

  // ─── RELATED PRODUCTS ────────────────────────────────────────────
  // Hardcoded defaults; theme.js recommendations API handles dynamic loading
  var RELATED = [
    { name: 'Resilience', sub: 'Whey Protein Isolate', price: '$54.99', img: '{{ "resilience-vanilla-one.png" | asset_url }}', href: '/products/resilience', tag: 'Protein' },
    { name: 'Replenish Plus', sub: 'Advanced Electrolytes', price: '$29.99', img: '{{ "replenish-plus-one.jpeg" | asset_url }}', href: '/products/replenish-plus', tag: 'Hydration' },
    { name: 'Fortify', sub: 'Colostrum Powder', price: '$34.99', img: '{{ "fortify-one.png" | asset_url }}', href: '/products/fortify', tag: 'Wellness' }
  ];

  // ─── RENDER IMPACT STATS ─────────────────────────────────────────
  (function renderImpact() {
    var strip = document.getElementById('impact-strip');
    if (!strip || !IMPACT_STATS.length) return;
    IMPACT_STATS.forEach(function(s, i) {
      var isLast = (i === IMPACT_STATS.length - 1);
      var div = document.createElement('div');
      div.className = isLast ? '' : 'impact-card';
      div.style.cssText = 'padding:3rem 2.5rem;text-align:center;';
      div.innerHTML =
        '<div style="font-family:Georgia,serif;font-size:3.5rem;font-weight:700;color:#06A5C5;letter-spacing:-0.03em;line-height:1;">' +
          s.value + (s.unit ? '<span style="font-size:1.5rem;">' + s.unit + '</span>' : '') +
        '</div>' +
        '<div style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#F8FAFB;margin:0.5rem 0 0.4rem;">' + s.label + '</div>' +
        '<p style="font-size:0.85rem;color:#6b7280;">' + s.desc + '</p>';
      strip.appendChild(div);
    });
  })();

  // ─── RENDER HOW TO STEPS ─────────────────────────────────────────
  (function renderHowTo() {
    var grid = document.getElementById('how-to-grid');
    if (!grid || !HOW_TO.length) return;
    HOW_TO.forEach(function(s) {
      var div = document.createElement('div');
      div.style.cssText = 'background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;';
      div.innerHTML =
        '<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">' +
          '<div class="step-num">' + s.num + '</div>' +
          '<span style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">' + s.title + '</span>' +
        '</div>' +
        '<p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">' + s.body + '</p>';
      grid.appendChild(div);
    });
  })();

  // ─── RENDER FAQ ──────────────────────────────────────────────────
  (function renderFAQ() {
    var list = document.getElementById('faq-list');
    if (!list) return;
    FAQS.forEach(function(f) {
      var item = document.createElement('div');
      item.className = 'faq-item';
      item.innerHTML =
        '<button class="faq-btn" aria-expanded="false" onclick="toggleFAQ(this)">' +
          '<span>' + f.q + '</span>' +
          '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg>' +
        '</button>' +
        '<div class="faq-body"><p>' + f.a + '</p></div>';
      list.appendChild(item);
    });
  })();

  // ─── RENDER RELATED PRODUCTS ─────────────────────────────────────
  (function renderRelated() {
    var grid = document.getElementById('related-grid');
    if (!grid) return;
    RELATED.forEach(function(p) {
      var card = document.createElement('a');
      card.href = p.href;
      card.className = 'related-card';
      card.innerHTML =
        '<div style="background:#0a0a0a;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;padding:2rem;position:relative;">' +
          '<span style="position:absolute;top:0.75rem;left:0.75rem;background:rgba(6,165,197,0.1);border:1px solid rgba(6,165,197,0.25);border-radius:999px;padding:0.2rem 0.6rem;font-size:0.7rem;font-family:\'Barlow Condensed\',sans-serif;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#06A5C5;">' + p.tag + '</span>' +
          '<img src="' + p.img + '" alt="' + p.name + '" style="width:80%;height:80%;object-fit:contain;" onerror="this.src=\'https://placehold.co/300x300/131313/06A5C5?text=' + encodeURIComponent(p.name) + '\'">' +
        '</div>' +
        '<div style="padding:1.25rem 1.5rem 1.5rem;">' +
          '<div style="font-family:\'Barlow Condensed\',sans-serif;font-weight:800;font-size:1.15rem;letter-spacing:0.04em;color:#F8FAFB;">' + p.name + '</div>' +
          '<div style="font-size:0.8rem;color:#6b7280;margin-bottom:0.75rem;">' + p.sub + '</div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;">' +
            '<span style="font-family:Georgia,serif;font-size:1.1rem;font-weight:700;color:#F8FAFB;">' + p.price + '</span>' +
            '<span style="font-size:0.75rem;font-family:\'Barlow Condensed\',sans-serif;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#06A5C5;">View Product</span>' +
          '</div>' +
        '</div>';
      grid.appendChild(card);
    });
  })();

  // ─── INGREDIENT WHEEL ────────────────────────────────────────────
  (function initWheel() {
    if (!NODES || !NODES.length) return;

    var CX = 330, CY = 330, RADIUS = 250;
    var rotation = 0;
    var speed = 0.18;
    var activeId = null;
    var paused = false;

    var nodesEl = document.getElementById('wheel-nodes');
    var lineEl  = document.getElementById('wheel-line');
    var panel   = document.getElementById('wheel-detail-panel');

    var nodeEls  = {};
    var labelEls = {};

    NODES.forEach(function(n) {
      var div = document.createElement('div');
      div.className = 'wnode';
      div.id = 'wnode-' + n.id;
      div.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" style="color:#9ca3af">' + n.icon + '</svg>';
      div.addEventListener('click', function(e) { e.stopPropagation(); toggleNode(n.id); });
      nodesEl.appendChild(div);
      nodeEls[n.id] = div;

      var lbl = document.createElement('div');
      lbl.className = 'wnode-label';
      lbl.id = 'wlbl-' + n.id;
      lbl.textContent = n.name;
      nodesEl.appendChild(lbl);
      labelEls[n.id] = lbl;
    });

    function getPos(index, total, angle) {
      var deg = (index / total) * 360 + angle;
      var rad = (deg * Math.PI) / 180;
      return { x: CX + RADIUS * Math.cos(rad), y: CY + RADIUS * Math.sin(rad), rad: rad };
    }

    function updatePositions() {
      NODES.forEach(function(n, i) {
        var p = getPos(i, NODES.length, rotation);
        var depth = (Math.sin(p.rad) + 1) / 2;
        var opacity = 0.35 + 0.65 * depth;
        var nodeEl = nodeEls[n.id];
        var lblEl  = labelEls[n.id];

        nodeEl.style.left = p.x + 'px';
        nodeEl.style.top  = p.y + 'px';
        nodeEl.style.zIndex = Math.round(10 + 20 * depth);
        if (!nodeEl.classList.contains('active')) nodeEl.style.opacity = opacity;

        var outX = p.x + Math.cos(p.rad) * 38;
        var outY = p.y + Math.sin(p.rad) * 38;
        lblEl.style.left = (outX - 45) + 'px';
        lblEl.style.top  = (outY - 9) + 'px';
        if (!lblEl.classList.contains('active')) lblEl.style.opacity = opacity * 0.75;
      });
    }

    (function loop() {
      if (!paused) rotation = (rotation + speed) % 360;
      updatePositions();
      requestAnimationFrame(loop);
    })();

    function toggleNode(id) {
      if (activeId === id) { deactivate(); return; }
      activeId = id;
      paused = true;

      NODES.forEach(function(n) {
        var el  = nodeEls[n.id];
        var lbl = labelEls[n.id];
        if (n.id === id) {
          el.classList.add('active');
          el.querySelector('svg').style.color = '#fff';
          lbl.classList.add('active');
          lbl.style.color = '#06A5C5';
          lbl.style.opacity = '1';
        } else {
          el.classList.remove('active');
          el.querySelector('svg').style.color = '#9ca3af';
          lbl.classList.remove('active');
        }
      });

      var idx = NODES.findIndex(function(n) { return n.id === id; });
      var p = getPos(idx, NODES.length, rotation);
      lineEl.setAttribute('x1', CX); lineEl.setAttribute('y1', CY);
      lineEl.setAttribute('x2', p.x); lineEl.setAttribute('y2', p.y);
      lineEl.setAttribute('opacity', '0.4');

      var node = NODES.find(function(n) { return n.id === id; });
      document.getElementById('wdp-tag').textContent    = node.tag;
      document.getElementById('wdp-name').textContent   = node.name;
      document.getElementById('wdp-amount').textContent = node.amount;
      document.getElementById('wdp-desc').textContent   = node.desc;
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
      panel.style.pointerEvents = 'auto';
    }

    function deactivate() {
      activeId = null;
      paused = false;
      NODES.forEach(function(n) {
        nodeEls[n.id].classList.remove('active');
        nodeEls[n.id].querySelector('svg').style.color = '#9ca3af';
        labelEls[n.id].classList.remove('active');
      });
      lineEl.setAttribute('opacity', '0');
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(10px)';
      panel.style.pointerEvents = 'none';
    }

    document.getElementById('wheel-wrap').addEventListener('click', function(e) {
      if (e.target === this || e.target.id === 'wheel-svg' || e.target.tagName === 'circle' || e.target.tagName === 'line') {
        deactivate();
      }
    });
  })();

  // ─── IMAGE GALLERY ───────────────────────────────────────────────
  window.setImg = function(thumb, src) {
    document.querySelectorAll('.thumb').forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
    var mainImg = document.getElementById('main-img');
    mainImg.style.opacity = '0';
    setTimeout(function() { mainImg.src = src; mainImg.style.opacity = '1'; }, 150);
  };

  // ─── FAQ TOGGLE ──────────────────────────────────────────────────
  window.toggleFAQ = function(btn) {
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    document.querySelectorAll('.faq-btn').forEach(function(b) {
      b.setAttribute('aria-expanded', 'false');
      b.nextElementSibling.classList.remove('open');
    });
    if (!expanded) {
      btn.setAttribute('aria-expanded', 'true');
      btn.nextElementSibling.classList.add('open');
    }
  };

  // ─── VARIANT SELECTOR ────────────────────────────────────────────
  window.selectVariant = function(variantId, variantTitle, variantPriceCents, btn, imgSrc) {
    document.querySelectorAll('.flavor-btn').forEach(function(b) { b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    document.getElementById('selected-variant-id').value = variantId;
    var flavorLabel = document.getElementById('flavor-label');
    if (flavorLabel) flavorLabel.textContent = variantTitle;
    var formatted = '$' + (variantPriceCents / 100).toFixed(2);
    var priceDisplay = document.getElementById('price-display');
    if (priceDisplay) priceDisplay.textContent = formatted;
    var cartBtn = document.getElementById('add-to-cart-btn');
    if (cartBtn) cartBtn.textContent = 'Add to Cart \u2014 ' + formatted;
    // Update main product image if variant has a featured image
    if (imgSrc) {
      var mainImg = document.getElementById('main-img');
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(function() { mainImg.src = imgSrc; mainImg.style.opacity = '1'; }, 150);
      }
    }
  };

  // ─── CART BADGE INIT ─────────────────────────────────────────────
  (function() {
    var badge = document.getElementById('cart-badge');
    if (!badge) return;
    var count = {{ cart.item_count }};
    if (count > 0) { badge.textContent = count; badge.classList.add('visible'); }
  })();

})();
</script>
