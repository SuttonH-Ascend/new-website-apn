{% comment %}
  APN Product Template — dynamic for all products via Liquid variables.
  Visual design preserved exactly from products/recharge.html.
{% endcomment %}

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #0a0a0a; color: #F8FAFB; font-family: 'Barlow', sans-serif; line-height: 1.65; }

  /* NAV */
  .nav-link { color: #9ca3af; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: #F8FAFB; }
  .btn-nav { background: #06A5C5; color: #fff; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.5rem 1.1rem; border-radius: 6px; text-decoration: none; transition: background 0.2s, transform 0.15s; }
  .btn-nav:hover { background: #048FAB; transform: translateY(-1px); }

  /* GALLERY */
  .thumb { cursor: pointer; border: 2px solid transparent; border-radius: 10px; overflow: hidden; transition: border-color 0.2s, opacity 0.2s; opacity: 0.6; }
  .thumb:hover { opacity: 0.85; }
  .thumb.active { border-color: #06A5C5; opacity: 1; }
  #main-img { transition: opacity 0.25s; }

  /* STATS PILL */
  .stat-pill { background: rgba(6,165,197,0.1); border: 1px solid rgba(6,165,197,0.25); border-radius: 999px; padding: 0.35rem 0.9rem; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; color: #06A5C5; white-space: nowrap; }

  /* CTA BUTTON */
  .btn-cta { display: block; width: 100%; background: #06A5C5; color: #fff; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 1.05rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 1rem 2rem; border-radius: 10px; border: none; cursor: pointer;
    box-shadow: 0 4px 20px rgba(6,165,197,0.35), 0 1px 4px rgba(0,0,0,0.4);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s; }
  .btn-cta:hover { background: #048FAB; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(6,165,197,0.45), 0 2px 8px rgba(0,0,0,0.4); }
  .btn-cta:active { transform: translateY(0); }
  .btn-cta.added { background: #22C55E; }

  /* FLAVOR BUTTONS */
  .flavor-btn { border: 1.5px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 0.45rem 1rem; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; background: transparent; color: #9ca3af; cursor: pointer; transition: border-color 0.2s, color 0.2s, background 0.2s; }
  .flavor-btn:hover { border-color: rgba(6,165,197,0.5); color: #F8FAFB; }
  .flavor-btn.active { border-color: #06A5C5; color: #06A5C5; background: rgba(6,165,197,0.08); }

  /* BENEFIT CHECK */
  .benefit-item { display: flex; align-items: flex-start; gap: 0.65rem; }
  .benefit-icon { width: 20px; height: 20px; background: rgba(6,165,197,0.15); border: 1px solid #06A5C5; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }

  /* IMPACT STRIP */
  .impact-card { border-right: 1px solid rgba(255,255,255,0.07); }
  .impact-card:last-child { border-right: none; }

  /* SCIENCE CARD */
  .ingredient-card { background: linear-gradient(135deg, rgba(6,165,197,0.12) 0%, rgba(6,165,197,0.04) 100%); border: 1px solid rgba(6,165,197,0.2); border-radius: 16px; }

  /* STEPS */
  .step-num { width: 40px; height: 40px; background: #06A5C5; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 1.1rem; flex-shrink: 0; }

  /* SUPP FACTS TABLE */
  .supp-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .supp-table th, .supp-table td { border-bottom: 1px solid rgba(255,255,255,0.08); padding: 0.6rem 0; }
  .supp-table th { text-align: left; font-weight: 700; color: #F8FAFB; }
  .supp-table td:last-child { text-align: right; color: #9ca3af; }

  /* FAQ */
  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.07); }
  .faq-btn { width: 100%; text-align: left; background: none; border: none; color: #F8FAFB; cursor: pointer; padding: 1.25rem 0; display: flex; justify-content: space-between; align-items: center; font-family: 'Barlow', sans-serif; font-size: 1rem; font-weight: 600; }
  .faq-btn svg { flex-shrink: 0; transition: transform 0.25s; color: #06A5C5; }
  .faq-btn[aria-expanded="true"] svg { transform: rotate(45deg); }
  .faq-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; color: #9ca3af; line-height: 1.7; font-size: 0.9375rem; }
  .faq-body.open { max-height: 200px; padding-bottom: 1.25rem; }

  /* RELATED CARD */
  .related-card { background: #131313; border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s; }
  .related-card:hover { border-color: rgba(6,165,197,0.35); transform: translateY(-3px); }

  /* STAR RATING */
  .stars { color: #FBBF24; letter-spacing: -1px; }

  /* TRUST ICON ROW */
  .trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: #9ca3af; }
  .trust-item svg { color: #06A5C5; }

  /* BREADCRUMB */
  .breadcrumb a { color: #6b7280; font-size: 0.8rem; text-decoration: none; letter-spacing: 0.04em; }
  .breadcrumb a:hover { color: #9ca3af; }
  .breadcrumb span { color: #374151; margin: 0 0.4rem; font-size: 0.8rem; }

  /* SECTION LABEL */
  .section-label { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: #06A5C5; }

  /* CART BADGE */
  #cart-badge { display: none; background: #06A5C5; color: #fff; border-radius: 50%; width: 18px; height: 18px; font-size: 0.65rem; font-weight: 700; align-items: center; justify-content: center; position: absolute; top: -5px; right: -5px; }
  #cart-badge.visible { display: flex; }
</style>



<!-- ═══════════════════ BREADCRUMB ═══════════════════ -->
<div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;" class="breadcrumb">
  <div style="padding-top:88px;padding-bottom:0.75rem;display:flex;align-items:center;">
    <a href="{{ routes.root_url }}">Home</a>
    <span>/</span>
    <a href="{{ routes.collections_url }}/all">Shop</a>
    <span>/</span>
    <a href="{{ routes.collections_url }}/{{ product.type | handleize }}" style="color:#9ca3af;">{{ product.type }}</a>
    <span>/</span>
    <span style="color:#F8FAFB;font-size:0.8rem;">{{ product.title }}</span>
  </div>
</div>

<!-- ═══════════════════ PRODUCT HERO ═══════════════════ -->
<section style="max-width:1200px;margin:0 auto;padding:1.5rem 1.5rem 5rem;">
  <div class="product-hero-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;">

    <!-- LEFT: IMAGE GALLERY -->
    <div class="product-sticky-img" style="position:sticky;top:84px;">
      <!-- Main Image -->
      <div style="background:#131313;border-radius:20px;overflow:hidden;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,0.06);box-shadow:0 24px 60px rgba(0,0,0,0.6);">
        <img id="main-img"
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.title }}"
          style="width:90%;height:90%;object-fit:contain;">
      </div>
      <p style="text-align:center;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin:0.75rem 0 0.25rem;font-family:'Barlow Condensed',sans-serif;font-weight:600;">Swipe to See More</p>
      <!-- Thumbnails -->
      <div class="thumb-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-top:1rem;">
        {% for image in product.images %}
          <div class="thumb {% if forloop.first %}active{% endif %}" onclick="setImg(this, '{{ image | image_url: width: 800 }}')">
            <div style="background:#131313;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;padding:0.5rem;">
              <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: product.title }}" style="width:100%;height:100%;object-fit:contain;">
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT: BUY BOX -->
    <div style="padding-top:0.5rem;">

      <!-- Category Badge -->
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span class="section-label" style="background:rgba(6,165,197,0.1);border:1px solid rgba(6,165,197,0.25);padding:0.3rem 0.75rem;border-radius:999px;">{{ product.type }}</span>
        <span style="font-size:0.75rem;color:#6b7280;letter-spacing:0.04em;">SKU: {{ product.selected_or_first_available_variant.sku }}</span>
      </div>

      <!-- Product Name -->
      <h1 style="font-family:Georgia,serif;font-size:3rem;font-weight:700;letter-spacing:-0.03em;line-height:1;color:#F8FAFB;margin-bottom:0.35rem;">{{ product.title | upcase }}</h1>
      <p style="font-family:'Barlow Condensed',sans-serif;font-size:1.15rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6b7280;margin-bottom:1.25rem;">{{ product.metafields.custom.subtitle | default: product.type }}</p>

      <!-- Rating -->
      <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.5rem;">
        <span class="stars">★★★★★</span>
        <span style="font-size:0.875rem;font-weight:600;color:#F8FAFB;">5.0</span>
        <a href="#reviews" style="font-size:0.8rem;color:#06A5C5;text-decoration:none;">Reviews</a>
      </div>

      <!-- Divider -->
      <div style="border-top:1px solid rgba(255,255,255,0.07);margin-bottom:1.5rem;"></div>

      <!-- Price -->
      <div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:1.5rem;">
        <span id="price-display" style="font-family:'Barlow Condensed',sans-serif;font-size:2.25rem;font-weight:800;color:#F8FAFB;">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span style="font-size:1rem;color:#6b7280;text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
        {% endif %}
        <span style="font-size:0.8rem;color:#22C55E;font-weight:600;">
          {% if product.available %}In Stock{% else %}Out of Stock{% endif %}
        </span>
      </div>

      <!-- Stat Pills (from metafields) -->
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;" id="stat-pills-wrap">
        {% if product.metafields.custom.stat_pills %}
          {% assign pills = product.metafields.custom.stat_pills.value %}
          {% for pill in pills %}
            <span class="stat-pill">{{ pill }}</span>
          {% endfor %}
        {% endif %}
      </div>

      <!-- Description -->
      <div style="color:#9ca3af;line-height:1.7;font-size:0.9375rem;margin-bottom:1.75rem;">
        {{ product.description }}
      </div>

      <!-- Variants / Flavor Selector -->
      {% if product.variants.size > 1 %}
        <div style="margin-bottom:1.75rem;">
          <p style="font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#6b7280;margin-bottom:0.65rem;">
            {{ product.options[0] }}: <span id="flavor-label" style="color:#F8FAFB;">{{ product.selected_or_first_available_variant.title }}</span>
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            {% for variant in product.variants %}
              <button
                class="flavor-btn {% if forloop.first %}active{% endif %}"
                onclick="selectVariant({{ variant.id }}, '{{ variant.title | escape }}', {{ variant.price }}, this, '{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 800 }}{% endif %}')">
                {{ variant.title }}
              </button>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      <!-- Hidden variant input -->
      <input type="hidden" id="selected-variant-id" value="{{ product.selected_or_first_available_variant.id }}" />

      <!-- Add to Cart -->
      <button class="btn-cta" id="add-to-cart-btn" onclick="APN.addToCart(document.getElementById('selected-variant-id').value, 1, this)">
        Add to Cart - {{ product.price | money }}
      </button>

      <!-- Free Shipping Note -->
      <p style="text-align:center;font-size:0.8rem;color:#6b7280;margin-top:0.75rem;">
        Free shipping on orders over $50
      </p>

      <!-- Supplement Facts Button -->
      <button onclick="document.getElementById('sf-modal').style.display='flex'" style="display:block;width:100%;margin-top:1rem;background:transparent;border:1px solid rgba(255,255,255,0.12);color:#9ca3af;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.65rem 1rem;border-radius:8px;cursor:pointer;transition:border-color 0.2s,color 0.2s;"
        onmouseover="this.style.borderColor='rgba(6,165,197,0.4)';this.style.color='#06A5C5'"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='#9ca3af'">
        View Supplement Facts
      </button>
    </div>
  </div>
</section>

<!-- SUPPLEMENT FACTS MODAL -->
<div id="sf-modal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.85);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:1.5rem;" onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#131313;border:1px solid rgba(255,255,255,0.1);border-radius:20px;width:100%;max-width:480px;overflow:hidden;position:relative;">
    <button onclick="document.getElementById('sf-modal').style.display='none'" style="position:absolute;top:1rem;right:1rem;background:rgba(255,255,255,0.08);border:none;color:#9ca3af;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:1.1rem;display:flex;align-items:center;justify-content:center;line-height:1;">&#x2715;</button>
    <div style="background:rgba(255,255,255,0.04);padding:1.5rem 2rem;border-bottom:3px solid rgba(255,255,255,0.15);">
      <div style="font-family:Georgia,serif;font-size:1.5rem;font-weight:700;color:#F8FAFB;margin-bottom:0.25rem;">Supplement Facts</div>
      <div id="sf-serving-info" style="font-size:0.85rem;color:#9ca3af;">{{ product.metafields.custom.serving_size | default: 'See label for details' }}</div>
    </div>
    <div style="display:flex;justify-content:flex-end;padding:0.75rem 2rem;border-bottom:2px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.02);gap:3rem;">
      <span style="font-size:0.8rem;font-weight:700;color:#9ca3af;">Amount Per Serving</span>
      <span style="font-size:0.8rem;font-weight:700;color:#9ca3af;width:48px;text-align:right;">% DV</span>
    </div>
    <div id="sf-facts-body" style="padding:0 2rem;">
      {% if product.metafields.custom.supplement_facts_image %}
        <img src="{{ product.metafields.custom.supplement_facts_image | image_url: width: 400 }}" alt="Supplement Facts" style="width:100%;margin:1rem 0;">
      {% else %}
        <p style="padding:1.5rem 0;font-size:0.85rem;color:#6b7280;">See product label for full supplement facts.</p>
      {% endif %}
    </div>
    <div style="padding:1rem 2rem 1.5rem;">
      <p style="font-size:0.78rem;color:#6b7280;">** Daily Value not established.</p>
      <p style="font-size:0.78rem;color:#4b5563;margin-top:0.4rem;">{{ product.metafields.custom.other_ingredients | default: '' }}</p>
    </div>
  </div>
</div>

<!-- ═══════════════════ FLAVOR SHOWCASE ═══════════════════ -->
{% render 'flavor-showcase', product: product %}

<!-- ═══════════════════ IMPACT NUMBERS ═══════════════════ -->
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div id="impact-strip" style="display:grid;grid-template-columns:repeat(3,1fr);">
      {% comment %}Impact numbers rendered by JS from metafield or defaults below{% endcomment %}
    </div>
  </div>
</section>

<!-- ═══════════════════ INGREDIENT WHEEL ═══════════════════ -->
<section style="background:#080808;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;overflow:hidden;">
  <div style="max-width:800px;margin:0 auto;text-align:center;">
    <div style="margin-bottom:3.5rem;">
      <p class="section-label" style="margin-bottom:0.75rem;">Formula Breakdown</p>
      <h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">Inside the Formula</h2>
      <p style="color:#6b7280;margin-top:0.5rem;font-size:0.875rem;">Click any node to explore.</p>
    </div>

    <!-- WHEEL -->
    <div style="display:flex;justify-content:center;">
      <div id="wheel-wrap" style="position:relative;width:660px;height:660px;flex-shrink:0;">
        <!-- SVG: orbit ring + connector line -->
        <svg id="wheel-svg" viewBox="0 0 660 660" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;">
          <circle cx="330" cy="330" r="250" fill="none" stroke="rgba(6,165,197,0.10)" stroke-width="1" stroke-dasharray="5 12"/>
          <circle cx="330" cy="330" r="250" fill="none" stroke="rgba(6,165,197,0.03)" stroke-width="30"/>
          <line id="wheel-line" x1="330" y1="330" x2="330" y2="330" stroke="#06A5C5" stroke-width="1" stroke-dasharray="4 5" opacity="0"/>
        </svg>

        <!-- Center: product image -->
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;width:260px;height:260px;display:flex;align-items:center;justify-content:center;">
          <div style="position:absolute;width:220px;height:220px;border-radius:50%;border:2px solid rgba(6,165,197,0.4);box-shadow:0 0 0 10px rgba(6,165,197,0.05),0 0 50px rgba(6,165,197,0.2),0 0 90px rgba(6,165,197,0.08);"></div>
          <img id="wheel-product-img"
            src="{{ product.featured_image | image_url: width: 400 }}"
            alt="{{ product.title }}"
            style="position:relative;z-index:2;width:250px;height:250px;object-fit:contain;filter:drop-shadow(0 0 18px rgba(6,165,197,0.25));">
          <div style="position:absolute;width:234px;height:234px;border-radius:50%;border:1px solid rgba(6,165,197,0.18);animation:wping 2.8s ease-out infinite;"></div>
          <div style="position:absolute;width:234px;height:234px;border-radius:50%;border:1px solid rgba(6,165,197,0.12);animation:wping 2.8s ease-out 1.4s infinite;"></div>
        </div>

        <!-- Nodes (JS rendered) -->
        <div id="wheel-nodes" style="position:absolute;top:0;left:0;width:100%;height:100%;"></div>
      </div>
    </div>

    <!-- DETAIL CARD -->
    <div id="wheel-detail-panel" style="max-width:480px;margin:2rem auto 0;opacity:0;transform:translateY(10px);transition:opacity 0.3s,transform 0.3s;pointer-events:none;">
      <div style="background:#131313;border:1px solid rgba(6,165,197,0.25);border-radius:16px;padding:1.75rem 2rem;text-align:left;">
        <div id="wdp-tag" style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#06A5C5;margin-bottom:0.5rem;"></div>
        <div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:0.75rem;">
          <div id="wdp-name" style="font-family:Georgia,serif;font-size:1.35rem;font-weight:700;color:#F8FAFB;line-height:1.2;"></div>
          <div id="wdp-amount" style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:0.06em;color:#06A5C5;white-space:nowrap;"></div>
        </div>
        <p id="wdp-desc" style="font-size:0.875rem;color:#9ca3af;line-height:1.7;"></p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes wping {
    0%   { transform: translate(-50%,-50%) scale(1); opacity: 0.6; }
    100% { transform: translate(-50%,-50%) scale(1.6); opacity: 0; }
  }
  .wnode {
    position: absolute;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #131313;
    border: 1.5px solid rgba(6,165,197,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transform: translate(-50%, -50%);
    transition: background 0.25s, border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    z-index: 20;
  }
  .wnode:hover { border-color: #06A5C5; background: rgba(6,165,197,0.12); transform: translate(-50%,-50%) scale(1.1); }
  .wnode.active { background: #06A5C5; border-color: #06A5C5; box-shadow: 0 0 20px rgba(6,165,197,0.5); transform: translate(-50%,-50%) scale(1.2); }
  .wnode svg { pointer-events: none; }
  .wnode-label {
    position: absolute;
    width: 90px;
    text-align: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248,250,251,0.6);
    pointer-events: none;
    line-height: 1.3;
    transition: color 0.25s;
  }
  .wnode-label.active { color: #06A5C5; }
</style>

<!-- ═══════════════════ HOW TO USE ═══════════════════ -->
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <p class="section-label" style="margin-bottom:0.75rem;">Directions</p>
    <h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin-bottom:3.5rem;">How to Use {{ product.title }}</h2>
