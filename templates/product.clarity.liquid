lows the compound to absorb directly through the mucous membrane under the tongue, bypassing first-pass liver metabolism. Onset is typically within 15-30 minutes.',icon:'<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'},{id:6,tag:'Serving Profile',name:'Per Serving',amount:'60 Servings',desc:'20 drops (1ml) under the tongue or mixed in water. Start with 10 drops to assess response. Do not exceed 10mg (1ml) daily. Morning use is recommended.',icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'}];
  var CX=330,CY=330,RADIUS=250,rotation=0,speed=0.18,activeId=null,paused=false;
  var nodesEl=document.getElementById('wheel-nodes'),lineEl=document.getElementById('wheel-line'),panel=document.getElementById('wheel-detail-panel');
  var nodeEls={},labelEls={};
  NODES.forEach(function(n){var div=document.createElement('div');div.className='wnode';div.id='wnode-'+n.id;div.innerHTML='<svg width="20" height="20" viewBox="0 0 24 24" style="color:#9ca3af">'+n.icon+'</svg>';div.addEventListener('click',function(e){e.stopPropagation();toggleNode(n.id);});nodesEl.appendChild(div);nodeEls[n.id]=div;var lbl=document.createElement('div');lbl.className='wnode-label';lbl.id='wlbl-'+n.id;lbl.textContent=n.name;nodesEl.appendChild(lbl);labelEls[n.id]=lbl;});
  function getPos(i,t,a){var deg=(i/t)*360+a;var rad=(deg*Math.PI)/180;return{x:CX+RADIUS*Math.cos(rad),y:CY+RADIUS*Math.sin(rad),rad:rad};}
  function updatePositions(){NODES.forEach(function(n,i){var p=getPos(i,NODES.length,rotation);var depth=(Math.sin(p.rad)+1)/2;var opacity=0.35+0.65*depth;nodeEls[n.id].style.left=p.x+'px';nodeEls[n.id].style.top=p.y+'px';nodeEls[n.id].style.zIndex=Math.round(10+20*depth);if(!nodeEls[n.id].classList.contains('active'))nodeEls[n.id].style.opacity=opacity;var outX=p.x+Math.cos(p.rad)*38;var outY=p.y+Math.sin(p.rad)*38;labelEls[n.id].style.left=(outX-45)+'px';labelEls[n.id].style.top=(outY-9)+'px';if(!labelEls[n.id].classList.contains('active'))labelEls[n.id].style.opacity=opacity*0.75;});}
  function loop(){if(!paused)rotation=(rotation+speed)%360;updatePositions();requestAnimationFrame(loop);}loop();
  function toggleNode(id){if(activeId===id){deactivate();return;}activeId=id;paused=true;NODES.forEach(function(n){var el=nodeEls[n.id];var lbl=labelEls[n.id];if(n.id===id){el.classList.add('active');el.querySelector('svg').style.color='#fff';lbl.classList.add('active');lbl.style.color='#06A5C5';lbl.style.opacity='1';}else{el.classList.remove('active');el.querySelector('svg').style.color='#9ca3af';lbl.classList.remove('active');}});var idx=NODES.findIndex(function(n){return n.id===id;});var p=getPos(idx,NODES.length,rotation);lineEl.setAttribute('x1',CX);lineEl.setAttribute('y1',CY);lineEl.setAttribute('x2',p.x);lineEl.setAttribute('y2',p.y);lineEl.setAttribute('opacity','0.4');var node=NODES.find(function(n){return n.id===id;});document.getElementById('wdp-tag').textContent=node.tag;document.getElementById('wdp-name').textContent=node.name;document.getElementById('wdp-amount').textContent=node.amount;document.getElementById('wdp-desc').textContent=node.desc;panel.style.opacity='1';panel.style.transform='translateY(0)';panel.style.pointerEvents='auto';}
  function deactivate(){activeId=null;paused=false;NODES.forEach(function(n){nodeEls[n.id].classList.remove('active');nodeEls[n.id].querySelector('svg').style.color='#9ca3af';labelEls[n.id].classList.remove('active');});lineEl.setAttribute('opacity','0');panel.style.opacity='0';panel.style.transform='translateY(10px)';panel.style.pointerEvents='none';}
  document.getElementById('wheel-wrap').addEventListener('click',function(e){if(e.target===this||e.target.id==='wheel-svg'||e.target.tagName==='circle'||e.target.tagName==='line')deactivate();});
})();
</script>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;"><p class="section-label" style="margin-bottom:0.75rem;">Directions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin-bottom:3.5rem;">How to Use Clarity</h2>
  <div class="how-to-steps-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:left;"><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">1</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Drop It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Place 20 drops (1ml) directly under the tongue. Hold for 30-60 seconds before swallowing. Alternatively, mix in 4oz of water.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">2</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Time It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Morning use is recommended to benefit from the cognitive and energy effects during peak waking hours. Avoid use within 6 hours of sleep.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">3</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Start Low</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">New users: begin with 10 drops (0.5ml) for the first 3-5 days to assess individual response before using a full 20-drop serving.</p></div></div>
  <p style="margin-top:1.75rem;font-size:0.8rem;color:#4b5563;">Store in a cool, dry place. Keep out of reach of children. Consult a healthcare professional before use if you have any medical conditions.</p></div>
</section>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;" id="faq"><div style="max-width:700px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Questions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">Frequently Asked</h2></div><div id="faq-list"></div></div></section>
<section style="background:#0a0a0a;padding:6rem 1.5rem;" id="reviews"><div style="max-width:800px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Reviews</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">What Athletes Say</h2></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem 2.5rem;"><div style="display:flex;align-items:flex-start;gap:1.25rem;"><div style="width:48px;height:48px;background:linear-gradient(135deg,#06A5C5,#048FAB);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;">C</div><div style="flex:1;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.25rem;"><span style="font-weight:700;color:#F8FAFB;">Chris P.</span><span class="stars" style="font-size:0.9rem;">★★★★★</span><span style="font-size:0.75rem;color:#6b7280;margin-left:auto;">Verified Purchase</span></div><p style="font-size:0.875rem;color:#6b7280;margin-bottom:0.75rem;">March 2025</p><p style="color:#9ca3af;line-height:1.7;font-size:0.9375rem;">I was skeptical about methylene blue but the cognitive effect is real. About 20 minutes after taking Clarity I notice a clear shift in focus and mental clarity without any stimulant feeling. The blue tongue thing is a little funny at first but you get used to it. Worth trying.</p></div></div></div></div></section>
