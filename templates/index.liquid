<script>
  // ── Google Ads conversion helpers ──
  function gtagConversion(sendTo, extras) {
    if (typeof gtag !== 'function') return;
    gtag('event', 'conversion', Object.assign({ send_to: sendTo }, extras || {}));
  }

  // ── Meta + TikTok helpers ──
  function trackAddToCart(productName, value) {
    if (typeof fbq === 'function') fbq('track', 'AddToCart', { content_name: productName, value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('AddToCart', { content_name: productName, value: value, currency: 'USD' });
    gtagConversion('AW-17918778091/cRQ-CK-A5YUcEOu1q-BC');
  }

  function trackViewProduct(productName, value) {
    if (typeof fbq === 'function') fbq('track', 'ViewContent', { content_name: productName, value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('ViewContent', { content_name: productName });
    gtagConversion('AW-17918778091/fzStCJya2oUcEOu1q-BC');
  }

  function trackQuizStarted() {
    if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'Quiz Started' });
    if (typeof ttq !== 'undefined') ttq.track('InitiateCheckout', { content_name: 'Quiz Started' });
    gtagConversion('AW-17918778091/ry7KCNqz0YUcEOu1q-BC');
  }

  function trackQuizCompleted(email) {
    if (typeof fbq === 'function') fbq('track', 'CompleteRegistration', { content_name: 'Quiz Completed' });
    if (typeof ttq !== 'undefined') {
      if (email) ttq.identify({ email: email });
      ttq.track('CompleteRegistration', { content_name: 'Quiz Completed' });
    }
    gtagConversion('AW-17918778091/ZJsJCOKh2oUcEOu1q-BC');
  }

  function trackPurchase(value, transactionId) {
    if (typeof fbq === 'function') fbq('track', 'Purchase', { value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('PlaceAnOrder', { value: value, currency: 'USD' });
    gtagConversion('AW-17918778091/95JhCKr75IUcEOu1q-BC', { value: value, currency: 'USD', transaction_id: transactionId || '' });
  }

  // ── Wire Add to Cart buttons ──
  document.querySelectorAll('.btn-add-cart').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var label = btn.getAttribute('aria-label') || 'Product';
      trackAddToCart(label, 0);
    });
  });

  // ── Wire Quiz CTA buttons ──
  document.querySelectorAll('a[href="#quiz"], a[href="#"]:not(.footer-link)').forEach(function(el) {
    if (el.textContent.trim().toLowerCase().includes('quiz')) {
      el.addEventListener('click', function() { trackQuizStarted(); });
    }
  });
</script>
