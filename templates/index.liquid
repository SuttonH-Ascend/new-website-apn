<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

<script>
  gsap.registerPlugin(ScrollTrigger);

  // ── Pillars Scroll FX ──
  (function() {
    const TOTAL = 4;
    let current = 0;
    let isAnimating = false;

    const bgs       = document.querySelectorAll('.pillar-bg');
    const words     = document.querySelectorAll('.p-center-word');
    const leftItems = document.querySelectorAll('.p-left-item');
    const rightItems= document.querySelectorAll('.p-right-item');
    const fillEl    = document.getElementById('pillar-progress-fill');
    const currEl    = document.getElementById('pillar-current');

    function goTo(to) {
      if (to === current || isAnimating) return;
      const from = current;
      const down = to > from;
      isAnimating = true;
      const D = 0.6;

      // backgrounds
      gsap.set(bgs[to], { opacity: 0, yPercent: down ? 5 : -5 });
      gsap.to(bgs[to],  { opacity: 1, yPercent: 0, duration: D, ease: 'power2.out' });
      gsap.to(bgs[from],{ opacity: 0, yPercent: down ? -5 : 5, duration: D, ease: 'power2.out' });

      // center word slide
      gsap.to(words[from], { y: down ? '-110%' : '110%', opacity: 0, duration: D * 0.5, ease: 'power3.in' });
      gsap.set(words[to],  { y: down ? '110%' : '-110%', opacity: 0 });
      gsap.to(words[to],   { y: '0%', opacity: 1, duration: D, delay: 0.08, ease: 'power3.out' });

      // side items  -  highlight active
      [...leftItems, ...rightItems].forEach(el => {
        const idx = parseInt(el.dataset.idx);
        el.classList.toggle('active', idx === to);
      });

      // progress
      if (fillEl) fillEl.style.width = ((to / (TOTAL - 1)) * 100) + '%';
      if (currEl) currEl.textContent = String(to + 1).padStart(2, '0');

      // mobile label sync
      document.querySelectorAll('.p-mobile-label').forEach(function(el) {
        el.style.display = parseInt(el.dataset.idx) === to ? 'block' : 'none';
      });

      current = to;
      setTimeout(() => { isAnimating = false; }, D * 1000 + 120);
    }

    window.pillarGoTo = goTo;

    // Initial: set bgs[1-3] hidden, activate idx 0
    gsap.set(Array.from(bgs).slice(1), { opacity: 0 });
    leftItems[0].classList.add('active');
    rightItems[0].classList.add('active');

    // Pin + scroll drive
    ScrollTrigger.create({
      trigger: '#pillars-track',
      start: 'top top',
      end: 'bottom bottom',
      pin: '#pillars-stage',
      pinSpacing: true,
      onUpdate(self) {
        if (isAnimating) return;
        const target = Math.min(TOTAL - 1, Math.floor(self.progress * TOTAL));
        if (target !== current) goTo(target);
      }
    });
  })();

  // ── Nav scroll effect  -  transparent over hero, dark after ──
  const nav = document.getElementById('main-nav');
  const heroHeight = () => window.innerHeight * 4.8; // ~end of pillar track
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > heroHeight());
  }, { passive: true });

  // ── Hero image load ──
  const heroBg = document.getElementById('hero-bg');
  const img = new Image();
  img.onload = () => heroBg.classList.add('loaded');
  img.src = '{{ 'iwo-jima.webp' | asset_url }}';

  // ── Product filter ──
  function filterProducts(filter) {
    const items = document.querySelectorAll('.product-item');
    const tabs = document.querySelectorAll('.filter-tab');

    tabs.forEach(t => {
      t.classList.toggle('active', t.dataset.filter === filter);
      t.setAttribute('aria-pressed', t.dataset.filter === filter ? 'true' : 'false');
    });

    items.forEach(item => {
      const match = filter === 'all' || item.dataset.category === filter;
      item.classList.toggle('hidden', !match);
    });
  }

  // ── Scroll fade-in ──
  const fadeEls = document.querySelectorAll('.fade-up');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 60);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  fadeEls.forEach(el => observer.observe(el));

  // ── Mobile menu ──
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  hamburger.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });
  function closeMobileMenu() {
    mobileMenu.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  // ── Newsletter submit ──
  function handleNewsletterSubmit(e) {
    e.preventDefault();
    const input = document.getElementById('email-input');
    const btn = e.target.querySelector('button[type="submit"]');
    if (!input.value || !input.value.includes('@')) {
      input.style.borderColor = '#EF4444';
      return;
    }
    btn.textContent = 'You\'re In!';
    btn.style.background = 'linear-gradient(135deg,#22C55E,#16A34A)';
    input.value = '';
    input.placeholder = 'Welcome to the Locker Room!';
    input.disabled = true;
    btn.disabled = true;
  }
</script>

<!-- ═══════════════════════════════════════════
     CONVERSION EVENT TRACKING
═══════════════════════════════════════════ -->
<script>
  // ── Google Ads conversion helpers ──
  function gtagConversion(sendTo, extras) {
    if (typeof gtag !== 'function') return;
    gtag('event', 'conversion', Object.assign({ send_to: sendTo }, extras || {}));
  }

  // ── Meta + TikTok helpers ──
  function trackAddToCart(productName, value) {
    if (typeof fbq === 'function') fbq('track', 'AddToCart', { content_name: productName, value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('AddToCart', { content_name: productName, value: value, currency: 'USD' });
    gtagConversion('AW-17918778091/cRQ-CK-A5YUcEOu1q-BC');
  }

  function trackViewProduct(productName, value) {
    if (typeof fbq === 'function') fbq('track', 'ViewContent', { content_name: productName, value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('ViewContent', { content_name: productName });
    gtagConversion('AW-17918778091/fzStCJya2oUcEOu1q-BC');
  }

  function trackQuizStarted() {
    if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'Quiz Started' });
    if (typeof ttq !== 'undefined') ttq.track('InitiateCheckout', { content_name: 'Quiz Started' });
    gtagConversion('AW-17918778091/ry7KCNqz0YUcEOu1q-BC');
  }

  function trackQuizCompleted(email) {
    if (typeof fbq === 'function') fbq('track', 'CompleteRegistration', { content_name: 'Quiz Completed' });
    if (typeof ttq !== 'undefined') {
      if (email) ttq.identify({ email: email });
      ttq.track('CompleteRegistration', { content_name: 'Quiz Completed' });
    }
    gtagConversion('AW-17918778091/ZJsJCOKh2oUcEOu1q-BC');
  }

  function trackPurchase(value, transactionId) {
    if (typeof fbq === 'function') fbq('track', 'Purchase', { value: value, currency: 'USD' });
    if (typeof ttq !== 'undefined') ttq.track('PlaceAnOrder', { value: value, currency: 'USD' });
    gtagConversion('AW-17918778091/95JhCKr75IUcEOu1q-BC', { value: value, currency: 'USD', transaction_id: transactionId || '' });
  }

  // ── Wire Add to Cart buttons ──
  document.querySelectorAll('.btn-add-cart').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var label = btn.getAttribute('aria-label') || 'Product';
      trackAddToCart(label, 0);
    });
  });

  // ── Wire Quiz CTA buttons ──
  document.querySelectorAll('a[href="/pages/performance-quiz"], a[href="#"]:not(.footer-link)').forEach(function(el) {
    if (el.textContent.trim().toLowerCase().includes('quiz')) {
      el.addEventListener('click', function() { trackQuizStarted(); });
    }
  });

  // ── Stack Add to Cart ──
  {% assign resilience_id = all_products['resilience'].variants.first.id %}
  {% assign replenishplus_id = all_products['replenishplus'].variants.first.id %}
  {% assign fortify_id = all_products['fortify'].variants.first.id %}
  var STACK_VARIANTS = {
    'resilience':   {{ resilience_id | default: 0 }},
    'replenishplus':{{ replenishplus_id | default: 0 }},
    'fortify':      {{ fortify_id | default: 0 }}
  };

  function stackAddToCart(handle, btn) {
    var vid = STACK_VARIANTS[handle];
    if (!vid) { window.location = '/products/' + handle; return; }
    if (btn) { btn.disabled = true; btn.textContent = 'Adding...'; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({id: vid, quantity: 1})
    })
    .then(function(r){ return r.json(); })
    .then(function() {
      if (btn) {
        btn.textContent = 'Added to Cart!';
        btn.style.background = '#22C55E';
        setTimeout(function(){
          btn.textContent = 'Shop ' + handle.charAt(0).toUpperCase() + handle.slice(1).replace('plus',' Plus') + ' +';
          btn.style.background = '';
          btn.disabled = false;
        }, 2000);
      }
      // update cart badge in nav
      fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
        var badge = document.querySelector('.cart-badge');
        if(badge){ badge.textContent = cart.item_count; badge.style.display = cart.item_count > 0 ? 'flex' : 'none'; }
      });
    })
    .catch(function(){ window.location = '/products/' + handle; });
  }

  function stackAddAll(btn) {
    if (btn) { btn.disabled = true; btn.textContent = 'Adding All...'; }
    var handles = ['resilience','replenishplus','fortify'];
    var items = handles.map(function(h){ return {id: STACK_VARIANTS[h], quantity: 1}; }).filter(function(i){ return i.id; });
    if (!items.length) { window.location = '/collections/all'; return; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({items: items})
    })
    .then(function(r){ return r.json(); })
    .then(function() {
      window.location = '/cart';
    })
    .catch(function(){ window.location = '/cart'; });
  }
</script>

