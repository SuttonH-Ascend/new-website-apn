<script>
(function(){
  var NODES=[{id:1,tag:'Core Ingredient',name:'Organic Ashwagandha',amount:'650mg',desc:'650mg of organic ashwagandha root (Withania somnifera) per capsule. Ashwagandha is an adaptogenic herb with a long history of use in traditional medicine and a growing body of research on stress, recovery, and performance.',icon:'<path d="M17 8C8 10 5.9 16.17 3.82 19.22L5.71 21A18 18 0 0 1 10 15c4.33-1 6.33 2 8 2 1 0 2-1 2-3s-1-5-3-6z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:2,tag:'Absorption Support',name:'Organic Black Pepper',amount:'5mg',desc:'5mg of organic black pepper fruit (Piper nigrum) provides piperine, a natural compound that supports bioavailability of herbal extracts including ashwagandha. A small but functionally meaningful addition to the formula.',icon:'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:3,tag:'Adaptogen Effect',name:'Stress Resilience',amount:'Daily Use',desc:'Ashwagandha is classified as an adaptogen, a class of herbs that support the body\'s ability to manage physical and psychological stress. Effects are cumulative and develop over weeks of consistent use.',icon:'<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:4,tag:'Recovery',name:'Rest and Repair',amount:'Nightly Use',desc:'Taking ashwagandha in the evening may support sleep quality and the rest-and-repair processes that happen during recovery. Morning use can support resilience throughout the training day. Choose based on your goal.',icon:'<circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'},{id:5,tag:'Clean Formula',name:'Pullulan Capsule',amount:'No Gelatin',desc:'The capsule is made from pullulan, a plant-derived polysaccharide. No gelatin, no artificial fillers, no excipients beyond what is listed on the label.',icon:'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'},{id:6,tag:'Serving Profile',name:'Per Serving',amount:'60 Servings',desc:'One capsule per serving, 60 servings per container. Take with a meal. Allow 4-8 weeks for the full adaptogenic effect to develop with consistent daily use.',icon:'<rect x="3" y="6" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 6V4a2 2 0 0 1 4 0v2M16 6V4a2 2 0 0 0-4 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>'}];
  var CX=330,CY=330,RADIUS=250,rotation=0,speed=0.18,activeId=null,paused=false;
  var nodesEl=document.getElementById('wheel-nodes'),lineEl=document.getElementById('wheel-line'),panel=document.getElementById('wheel-detail-panel');
  var nodeEls={},labelEls={};
  NODES.forEach(function(n){var div=document.createElement('div');div.className='wnode';div.id='wnode-'+n.id;div.innerHTML='<svg width="20" height="20" viewBox="0 0 24 24" style="color:#9ca3af">'+n.icon+'</svg>';div.addEventListener('click',function(e){e.stopPropagation();toggleNode(n.id);});nodesEl.appendChild(div);nodeEls[n.id]=div;var lbl=document.createElement('div');lbl.className='wnode-label';lbl.id='wlbl-'+n.id;lbl.textContent=n.name;nodesEl.appendChild(lbl);labelEls[n.id]=lbl;});
  function getPos(i,t,a){var deg=(i/t)*360+a;var rad=(deg*Math.PI)/180;return{x:CX+RADIUS*Math.cos(rad),y:CY+RADIUS*Math.sin(rad),rad:rad};}
  function updatePositions(){NODES.forEach(function(n,i){var p=getPos(i,NODES.length,rotation);var depth=(Math.sin(p.rad)+1)/2;var opacity=0.35+0.65*depth;nodeEls[n.id].style.left=p.x+'px';nodeEls[n.id].style.top=p.y+'px';nodeEls[n.id].style.zIndex=Math.round(10+20*depth);if(!nodeEls[n.id].classList.contains('active'))nodeEls[n.id].style.opacity=opacity;var outX=p.x+Math.cos(p.rad)*38;var outY=p.y+Math.sin(p.rad)*38;labelEls[n.id].style.left=(outX-45)+'px';labelEls[n.id].style.top=(outY-9)+'px';if(!labelEls[n.id].classList.contains('active'))labelEls[n.id].style.opacity=opacity*0.75;});}
  function loop(){if(!paused)rotation=(rotation+speed)%360;updatePositions();requestAnimationFrame(loop);}loop();
  function toggleNode(id){if(activeId===id){deactivate();return;}activeId=id;paused=true;NODES.forEach(function(n){var el=nodeEls[n.id];var lbl=labelEls[n.id];if(n.id===id){el.classList.add('active');el.querySelector('svg').style.color='#fff';lbl.classList.add('active');lbl.style.color='#06A5C5';lbl.style.opacity='1';}else{el.classList.remove('active');el.querySelector('svg').style.color='#9ca3af';lbl.classList.remove('active');}});var idx=NODES.findIndex(function(n){return n.id===id;});var p=getPos(idx,NODES.length,rotation);lineEl.setAttribute('x1',CX);lineEl.setAttribute('y1',CY);lineEl.setAttribute('x2',p.x);lineEl.setAttribute('y2',p.y);lineEl.setAttribute('opacity','0.4');var node=NODES.find(function(n){return n.id===id;});document.getElementById('wdp-tag').textContent=node.tag;document.getElementById('wdp-name').textContent=node.name;document.getElementById('wdp-amount').textContent=node.amount;document.getElementById('wdp-desc').textContent=node.desc;panel.style.opacity='1';panel.style.transform='translateY(0)';panel.style.pointerEvents='auto';}
  function deactivate(){activeId=null;paused=false;NODES.forEach(function(n){nodeEls[n.id].classList.remove('active');nodeEls[n.id].querySelector('svg').style.color='#9ca3af';labelEls[n.id].classList.remove('active');});lineEl.setAttribute('opacity','0');panel.style.opacity='0';panel.style.transform='translateY(10px)';panel.style.pointerEvents='none';}
  document.getElementById('wheel-wrap').addEventListener('click',function(e){if(e.target===this||e.target.id==='wheel-svg'||e.target.tagName==='circle'||e.target.tagName==='line')deactivate();});
})();
</script>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;"><p class="section-label" style="margin-bottom:0.75rem;">Directions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin-bottom:3.5rem;">How to Use Adapt</h2>
  <div class="how-to-steps-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:left;"><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">1</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Take It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">One capsule daily with a meal. Take with a full glass of water. Do not exceed one capsule per day.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">2</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Time It</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Morning use supports stress resilience throughout the day. Evening use promotes deeper sleep. Choose based on your primary goal.</p></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;"><div class="step-num">3</div><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.08em;text-transform:uppercase;color:#F8FAFB;">Stay Consistent</span></div><p style="font-size:0.9rem;color:#9ca3af;line-height:1.7;">Allow 4-8 weeks for the full adaptogenic effect. Adaptogens work cumulatively, not acutely. Consistency matters more than timing.</p></div></div>
  <p style="margin-top:1.75rem;font-size:0.8rem;color:#4b5563;">Store in a cool, dry place. Keep out of reach of children. Consult a healthcare professional before use if you have any medical conditions.</p></div>
</section>
<section style="background:#0D0D0D;border-top:1px solid rgba(255,255,255,0.06);padding:6rem 1.5rem;" id="faq"><div style="max-width:700px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Questions</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">Frequently Asked</h2></div><div id="faq-list"></div></div></section>
<section style="background:#0a0a0a;padding:6rem 1.5rem;" id="reviews"><div style="max-width:800px;margin:0 auto;"><div style="text-align:center;margin-bottom:3rem;"><p class="section-label" style="margin-bottom:0.75rem;">Reviews</p><h2 style="font-family:Georgia,serif;font-size:2.4rem;font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;">What Athletes Say</h2></div><div style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:2rem 2.5rem;"><div style="display:flex;align-items:flex-start;gap:1.25rem;"><div style="width:48px;height:48px;background:linear-gradient(135deg,#06A5C5,#048FAB);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;">R</div><div style="flex:1;"><div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.25rem;"><span style="font-weight:700;color:#F8FAFB;">Rachel M.</span><span class="stars" style="font-size:0.9rem;">★★★★★</span><span style="font-size:0.75rem;color:#6b7280;margin-left:auto;">Verified Purchase</span></div><p style="font-size:0.875rem;color:#6b7280;margin-bottom:0.75rem;">February 2025</p><p style="color:#9ca3af;line-height:1.7;font-size:0.9375rem;">I work a high-stress job and train six days a week. Adapt has genuinely changed my recovery. My sleep is deeper, I wake up less wired, and my training performance has improved noticeably. This is one of those supplements that sneaks up on you over a few weeks.</p></div></div></div></div></section>
<script>
  
  
  function setImg(thumb,src){document.querySelectorAll('.thumb').forEach(function(t){t.classList.remove('active');});thumb.classList.add('active');var mainImg=document.getElementById('main-img');mainImg.style.opacity='0';setTimeout(function(){mainImg.src=src;mainImg.style.opacity='1';},150);}
  var FAQS=[{q:'How long until I notice results from Adapt?',a:'Adaptogens work cumulatively. Most users notice improved stress resilience and sleep quality within 2-3 weeks. Full effects develop over 4-8 weeks of consistent daily use. Do not assess early results against the full potential of the product.'},{q:'What is in Adapt?',a:'Each capsule contains 650mg of organic ashwagandha root (Withania somnifera) and 5mg of organic black pepper fruit (Piper nigrum). The capsule shell is pullulan, a plant-derived material. That is the complete ingredient list.'},{q:'Should I take Adapt in the morning or at night?',a:'One capsule per day, taken with a meal. Morning use supports stress resilience throughout the day. Evening use may benefit sleep quality. Choose based on your primary goal. Do not exceed one capsule per day.'},{q:'Is Adapt safe for long-term use?',a:'Yes. Ashwagandha has a long history of use and modern research indicates it is well-tolerated at this dose range with consistent daily use. Consult a healthcare professional before use if you have medical conditions or are taking medications.'}];
  (function renderFAQ(){var list=document.getElementById('faq-list');FAQS.forEach(function(f){var item=document.createElement('div');item.className='faq-item';item.innerHTML='<button class="faq-btn" aria-expanded="false" onclick="toggleFAQ(this)"><span>'+f.q+'</span><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg></button><div class="faq-body"><p>'+f.a+'</p></div>';list.appendChild(item);});})();
  function toggleFAQ(btn){var expanded=btn.getAttribute('aria-expanded')==='true';document.querySelectorAll('.faq-btn').forEach(function(b){b.setAttribute('aria-expanded','false');b.nextElementSibling.classList.remove('open');});if(!expanded){btn.setAttribute('aria-expanded','true');btn.nextElementSibling.classList.add('open');}}
  function _getCart(){try{return JSON.parse(localStorage.getItem('apn_cart')||'[]');}catch(e){return[];}}
  function _saveCart(cart){localStorage.setItem('apn_cart',JSON.stringify(cart));}
  function _updateCartBadge(){var cart=_getCart();var total=cart.reduce(function(s,i){return s+(i.qty||1);},0);var badge=document.getElementById('cart-badge');if(badge){badge.textContent=total;total>0?badge.classList.add('visible'):badge.classList.remove('visible');}}
  
  function addToCart() {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({id: '{{ product.variants.first.id }}', quantity: 1})
    }).then(function() { window.location = '/cart'; });
  }
  _updateCartBadge();
</script>
