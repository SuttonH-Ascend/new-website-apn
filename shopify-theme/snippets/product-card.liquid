{%- comment -%}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- assign card_product = product -%}
{%- assign first_variant = card_product.selected_or_first_available_variant -%}
{%- assign product_category = card_product.metafields.custom.category | default: card_product.type -%}

<article class="apn-product-card" style="display:flex;flex-direction:column;">

  <!-- Image -->
  <a href="{{ card_product.url }}" style="display:block;position:relative;background:#F8FAFB;aspect-ratio:1/1;overflow:hidden;border-radius:8px 8px 0 0;" tabindex="-1" aria-hidden="true">
    {%- if card_product.featured_image -%}
      <img
        src="{{ card_product.featured_image | image_url: width: 600 }}"
        alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
        width="600"
        height="600"
        loading="lazy"
        style="width:100%;height:100%;object-fit:contain;padding:1rem;transition:transform 0.3s ease;"
        onmouseover="this.style.transform='scale(1.05)'"
        onmouseout="this.style.transform='scale(1)'"
      />
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#E2E8F0;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
      </div>
    {%- endif -%}

    <!-- Category badge -->
    {%- if product_category != blank -%}
      <div style="position:absolute;top:0.75rem;left:0.75rem;background:#0D0D0D;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.625rem;letter-spacing:0.14em;text-transform:uppercase;padding:0.3rem 0.6rem;border-radius:3px;">{{ product_category }}</div>
    {%- endif -%}

    <!-- Sale badge -->
    {%- if first_variant.compare_at_price > first_variant.price -%}
      <div style="position:absolute;top:0.75rem;right:0.75rem;background:#06A5C5;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:0.625rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.3rem 0.6rem;border-radius:3px;">Sale</div>
    {%- endif -%}
  </a>

  <!-- Info -->
  <div style="padding:1.25rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
    <a href="{{ card_product.url }}" style="text-decoration:none;">
      <h3 style="font-family:Georgia,serif;font-weight:700;font-size:1.125rem;color:#0D0D0D;margin:0;line-height:1.2;">{{ card_product.title }}</h3>
    </a>

    {%- if card_product.metafields.custom.subtitle != blank -%}
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0;">{{ card_product.metafields.custom.subtitle }}</p>
    {%- elsif card_product.type != blank -%}
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0;">{{ card_product.type }}</p>
    {%- endif -%}

    {%- if card_product.description != blank -%}
      <p style="font-size:0.8125rem;line-height:1.6;color:#6B7280;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ card_product.description | strip_html }}</p>
    {%- endif -%}

    <div style="margin-top:auto;padding-top:0.75rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
      <!-- Price -->
      <div style="display:flex;align-items:baseline;gap:0.5rem;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#0D0D0D;">{{ first_variant.price | money }}</span>
        {%- if first_variant.compare_at_price > first_variant.price -%}
          <span style="font-size:0.875rem;color:#6B7280;text-decoration:line-through;">{{ first_variant.compare_at_price | money }}</span>
        {%- endif -%}
      </div>

      <!-- Add to cart -->
      {%- if first_variant.available -%}
        <button
          onclick="APN.addToCart({{ first_variant.id }}, 1, this)"
          class="apn-btn apn-btn-dark"
          style="padding:0.625rem 1.25rem;font-size:0.8125rem;"
          aria-label="Add {{ card_product.title }} to cart"
        >
          Add to Cart
        </button>
      {%- else -%}
        <button disabled class="apn-btn" style="padding:0.625rem 1.25rem;font-size:0.8125rem;background:#E2E8F0;color:#6B7280;cursor:not-allowed;">Sold Out</button>
      {%- endif -%}
    </div>
  </div>

</article>
