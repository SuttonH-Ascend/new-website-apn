{%- comment -%}
  Related products section.
  Uses Shopify recommendations API (product_recommendations) — requires Online Store 2.0.
{%- endcomment -%}

<section id="product-related" style="background:#fff;padding:5rem 1.5rem;">
  <div style="max-width:1280px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:3rem;" class="apn-fade-up">
      <div class="apn-section-label" style="justify-content:center;">Complete Your Stack</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3.5vw,2.5rem);color:#0D0D0D;margin:0;">You May Also Like</h2>
    </div>

    <!-- Shopify recommendations (rendered via JS) -->
    <div id="apn-recommendations" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;" class="apn-fade-up">
      <!-- Populated by recommendations API below -->
    </div>

  </div>

  <script>
    (function() {
      var productId = {{ product.id }};
      var limit = 4;
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=' + limit)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var container = document.getElementById('apn-recommendations');
          if (!container || !data.products || data.products.length === 0) return;
          container.innerHTML = data.products.map(function(p) {
            var variant = p.variants && p.variants[0];
            var price = variant ? '$' + (variant.price / 100).toFixed(2) : '';
            var img = p.images && p.images[0]
              ? '<img src="' + p.images[0].src + '" alt="' + p.title.replace(/"/g,'&quot;') + '" style="max-width:80%;max-height:80%;object-fit:contain;transition:transform 0.3s ease;" onmouseover="this.style.transform=\'scale(1.05)\'" onmouseout="this.style.transform=\'scale(1)\'" />'
              : '';
            return '<article class="apn-product-card">' +
              '<a href="' + p.url + '" style="display:block;position:relative;background:#F8FAFB;aspect-ratio:1/1;overflow:hidden;border-radius:8px 8px 0 0;display:flex;align-items:center;justify-content:center;" tabindex="-1">' +
                (p.product_type ? '<div style="position:absolute;top:0.75rem;left:0.75rem;background:#0D0D0D;color:#fff;font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:0.625rem;letter-spacing:0.14em;text-transform:uppercase;padding:0.3rem 0.6rem;border-radius:3px;">' + p.product_type + '</div>' : '') +
                img +
              '</a>' +
              '<div style="padding:1.25rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">' +
                '<a href="' + p.url + '" style="text-decoration:none;"><h3 style="font-family:Georgia,serif;font-weight:700;font-size:1.0625rem;color:#0D0D0D;margin:0;">' + p.title + '</h3></a>' +
                (p.product_type ? '<p style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0;">' + p.product_type + '</p>' : '') +
                '<div style="margin-top:auto;padding-top:0.75rem;display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">' +
                  '<span style="font-family:\'Barlow Condensed\',sans-serif;font-weight:800;font-size:1.125rem;color:#0D0D0D;">' + price + '</span>' +
                  (variant && variant.available
                    ? '<button onclick="APN.addToCart(' + variant.id + ',1,this)" class="apn-btn apn-btn-dark" style="padding:0.5rem 1rem;font-size:0.8125rem;">Add to Cart</button>'
                    : '<span style="font-size:0.8125rem;color:#6B7280;">Sold Out</span>') +
                '</div>' +
              '</div>' +
            '</article>';
          }).join('');
        });
    })();
  </script>

  <style>
    @media (max-width: 1024px) { #apn-recommendations { grid-template-columns: repeat(3,1fr) !important; } }
    @media (max-width: 720px)  { #apn-recommendations { grid-template-columns: repeat(2,1fr) !important; } }
    @media (max-width: 480px)  { #apn-recommendations { grid-template-columns: 1fr !important; } }
  </style>
</section>
