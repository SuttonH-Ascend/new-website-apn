{%- comment -%}
  Product ingredients section.
  Uses product.metafields.custom.ingredients (JSON array of {name, amount, benefit})
  Falls back to product.description if no metafields.
{%- endcomment -%}

{%- assign ingredients = product.metafields.custom.ingredients.value -%}

{%- if ingredients != blank -%}
<section id="product-ingredients" style="background:#0D0D0D;padding:5rem 1.5rem;position:relative;overflow:hidden;">

  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(6,165,197,0.06) 0%,transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1280px;margin:0 auto;position:relative;">

    <div style="text-align:center;margin-bottom:3.5rem;" class="apn-fade-up">
      <div class="apn-section-label" style="justify-content:center;color:#06A5C5;">What's Inside</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#fff;margin:0;">Every Ingredient. Every Dose. Transparent.</h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;" class="apn-fade-up">
      {%- for ingredient in ingredients -%}
        <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:1.75rem;transition:border-color 0.2s ease;" onmouseover="this.style.borderColor='rgba(6,165,197,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#06A5C5;line-height:1;margin-bottom:0.5rem;">{{ ingredient.amount }}</div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:0.9375rem;letter-spacing:0.06em;text-transform:uppercase;color:#fff;margin:0 0 0.5rem;">{{ ingredient.name }}</h3>
          <p style="font-size:0.8125rem;line-height:1.65;color:rgba(255,255,255,0.45);margin:0;">{{ ingredient.benefit }}</p>
        </div>
      {%- endfor -%}
    </div>

    <!-- Supplement facts link -->
    {%- if product.metafields.custom.supplement_facts != blank -%}
      <div style="text-align:center;margin-top:2.5rem;">
        <button onclick="document.getElementById('apn-supp-facts').style.display='flex'" class="apn-btn apn-btn-outline-light" style="font-size:0.875rem;">
          View Full Supplement Facts
        </button>
      </div>

      <!-- Modal -->
      <div id="apn-supp-facts" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center;padding:1.5rem;" onclick="if(event.target===this)this.style.display='none'">
        <div style="background:#fff;border-radius:8px;max-width:500px;width:100%;max-height:80vh;overflow-y:auto;padding:2rem;position:relative;">
          <button onclick="document.getElementById('apn-supp-facts').style.display='none'" aria-label="Close" style="position:absolute;top:1rem;right:1rem;background:none;border:none;cursor:pointer;color:#0D0D0D;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 1rem;">Supplement Facts</h3>
          {{ product.metafields.custom.supplement_facts }}
        </div>
      </div>
    {%- endif -%}

  </div>

  <style>
    @media (max-width: 900px) { #product-ingredients div[style*="repeat(3"] { grid-template-columns: repeat(2,1fr) !important; } }
    @media (max-width: 560px) { #product-ingredients div[style*="repeat(3"] { grid-template-columns: 1fr !important; } }
  </style>
</section>
{%- endif -%}
