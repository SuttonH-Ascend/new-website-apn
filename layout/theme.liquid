<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} | {{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}" />
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}" />

  {{ content_for_header }}

  <!-- Tailwind CSS (loaded in <head> so classes apply before paint) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Barlow+Condensed:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <!-- OG tags -->
  <meta property="og:site_name" content="{{ shop.name }}" />
  <meta property="og:url" content="{{ canonical_url }}" />
  <meta property="og:title" content="{{ page_title | default: shop.name }}" />
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}" />
  {%- endif -%}

  <!-- APN Global Stylesheet -->
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" />

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #0a0a0a; color: #F8FAFB; font-family: 'Barlow', system-ui, sans-serif; }
    @media (max-width: 768px) {
      .product-hero-grid { grid-template-columns: 1fr !important; gap: 1.5rem !important; }
      .product-sticky-img { position: static !important; top: auto !important; }
      .thumb-grid { grid-template-columns: repeat(4,1fr) !important; }
    }
  </style>

  <!-- Microsoft Clarity -->
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window,document,"clarity","script","v9tqcwb652");
  </script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F8E53SP741"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-F8E53SP741', {
      page_title: {{ page_title | json }},
      page_location: window.location.href
    });
    gtag('config', 'AW-17918778091');
  </script>

  <!-- Meta Pixel -->
  <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}
    (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '876546821553793');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=876546821553793&ev=PageView&noscript=1"/></noscript>
</head>

<body class="apn-body">

  {% section 'header' %}

  {{ content_for_layout }}

  {% section 'footer' %}

  <!-- ── Global cart drawer (opened by APN.addToCart on any page) ────── -->
  <div id="apn-cart-overlay" onclick="if(typeof APN!=='undefined')APN.closeCart()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:998;backdrop-filter:blur(2px);"></div>

  <aside id="apn-cart-drawer" aria-label="Shopping cart" style="position:fixed;top:0;right:0;bottom:0;width:min(420px,100vw);background:#131313;z-index:999;transform:translateX(100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);display:flex;flex-direction:column;box-shadow:-8px 0 40px rgba(0,0,0,0.6);border-left:1px solid rgba(255,255,255,0.07);">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#F8FAFB;margin:0;">
        Cart <span id="apn-drawer-count" style="color:#06A5C5;font-weight:700;"></span>
      </h2>
      <button onclick="if(typeof APN!=='undefined')APN.closeCart()" aria-label="Close cart" style="background:none;border:none;cursor:pointer;padding:0.375rem;color:#F8FAFB;line-height:1;border-radius:4px;transition:background 0.15s;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Items -->
    <div id="apn-cart-items" style="flex:1;overflow-y:auto;padding:1.5rem;"></div>

    <!-- Footer -->
    <div style="padding:1.25rem 1.5rem;border-top:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
        <span style="font-family:'Barlow',sans-serif;font-weight:600;font-size:0.9375rem;color:#F8FAFB;">Subtotal</span>
        <span id="apn-cart-subtotal" style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.125rem;color:#F8FAFB;"></span>
      </div>
      <a href="/cart" style="display:flex;align-items:center;justify-content:center;width:100%;background:linear-gradient(135deg,#06A5C5,#048FAB);color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:0.875rem;letter-spacing:0.12em;text-transform:uppercase;padding:1rem;border-radius:4px;text-decoration:none;box-shadow:0 4px 16px rgba(6,165,197,0.35);transition:opacity 0.18s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
        Checkout →
      </a>
      <a href="{{ routes.collections_url }}/all" style="display:block;text-align:center;margin-top:0.75rem;font-family:'Barlow',sans-serif;font-size:0.875rem;color:#6B7280;text-decoration:none;" onmouseover="this.style.color='#06A5C5'" onmouseout="this.style.color='#6B7280'">Continue Shopping</a>
    </div>
  </aside>

  <!-- ── Global cart JS ───────────────────────────────────────────────── -->
  <script>
    var APN = window.APN || {};

    APN.openCart = function() {
      APN._refreshCart();
      document.getElementById('apn-cart-drawer').style.transform = 'translateX(0)';
      document.getElementById('apn-cart-overlay').style.display = 'block';
      document.body.style.overflow = 'hidden';
    };

    APN.closeCart = function() {
      document.getElementById('apn-cart-drawer').style.transform = 'translateX(100%)';
      document.getElementById('apn-cart-overlay').style.display = 'none';
      document.body.style.overflow = '';
    };

    APN._refreshCart = function() {
      fetch('/cart.js')
        .then(function(r){ return r.json(); })
        .then(function(cart) {
          /* badge(s) on page */
          document.querySelectorAll('.apn-cart-count,[id$="cart-badge"],[id$="cart-count"]').forEach(function(el){
            el.textContent = cart.item_count || '';
          });

          var drawerCount = document.getElementById('apn-drawer-count');
          var drawerSub   = document.getElementById('apn-cart-subtotal');
          var drawerItems = document.getElementById('apn-cart-items');

          if(drawerCount) drawerCount.textContent = cart.item_count ? '(' + cart.item_count + ')' : '';
          if(drawerSub)   drawerSub.textContent   = APN._money(cart.total_price);

          if(!drawerItems) return;
          if(!cart.item_count) {
            drawerItems.innerHTML = '<p style="text-align:center;color:#6B7280;padding:3rem 1rem;font-size:0.9375rem;">Your cart is empty.</p>';
            return;
          }
          drawerItems.innerHTML = cart.items.map(function(item){
            return '<div style="display:flex;gap:1rem;margin-bottom:1.25rem;padding-bottom:1.25rem;border-bottom:1px solid rgba(255,255,255,0.07);">'
              + (item.image ? '<img src="'+item.image+'" alt="'+item.product_title.replace(/"/g,'&quot;')+'" style="width:72px;height:72px;object-fit:contain;background:#0a0a0a;border:1px solid rgba(255,255,255,0.08);border-radius:6px;flex-shrink:0;"/>' : '')
              + '<div style="flex:1;min-width:0;">'
                + '<p style="font-family:\'Barlow\',sans-serif;font-weight:600;font-size:0.875rem;color:#F8FAFB;margin:0 0 0.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+item.product_title+'</p>'
                + (item.variant_title && item.variant_title!=='Default Title' ? '<p style="font-size:0.8125rem;color:#9ca3af;margin:0 0 0.5rem;">'+item.variant_title+'</p>' : '')
                + '<div style="display:flex;align-items:center;justify-content:space-between;">'
                  + '<div style="display:flex;align-items:center;gap:0.5rem;">'
                    + '<button onclick="APN._qty(\''+item.key+'\','+(item.quantity-1)+')" style="width:26px;height:26px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.06);border-radius:4px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;color:#F8FAFB;" aria-label="Decrease">−</button>'
                    + '<span style="font-size:0.875rem;font-weight:600;min-width:20px;text-align:center;color:#F8FAFB;">'+item.quantity+'</span>'
                    + '<button onclick="APN._qty(\''+item.key+'\','+(item.quantity+1)+')" style="width:26px;height:26px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.06);border-radius:4px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;color:#F8FAFB;" aria-label="Increase">+</button>'
                  + '</div>'
                  + '<span style="font-family:\'Barlow Condensed\',sans-serif;font-weight:800;font-size:0.9375rem;color:#F8FAFB;">'+APN._money(item.final_line_price)+'</span>'
                + '</div>'
              + '</div>'
            + '</div>';
          }).join('');
        });
    };

    APN.addToCart = function(variantId, qty, btn) {
      if(!variantId){ console.warn('APN.addToCart: no variant ID'); return; }
      qty = qty || 1;
      if(btn){ btn.disabled = true; btn.textContent = 'Adding…'; }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: qty })
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(data.status){ throw new Error(data.description || 'Could not add to cart'); }
        APN._refreshCart();
        APN.openCart();
        if(btn){ btn.disabled=false; var orig=btn.dataset.orig||'Add to Cart'; btn.dataset.orig=orig; btn.textContent='Added!'; setTimeout(function(){btn.textContent=orig;},2000); }
        // GA4 add_to_cart event
        if(window.gtag) gtag('event','add_to_cart',{currency:'USD',value:(data.price/100),items:[{item_id:data.variant_id,item_name:data.product_title,price:(data.price/100),quantity:qty}]});
        // Meta AddToCart event
        if(window.fbq) fbq('track','AddToCart',{content_ids:[data.variant_id],content_name:data.product_title,value:(data.price/100),currency:'USD'});
      })
      .catch(function(err){
        console.error('Cart error:',err);
        if(btn){ btn.disabled=false; btn.textContent=btn.dataset.orig||'Add to Cart'; }
      });
    };

    APN._qty = function(key, qty) {
      if(qty < 1){ APN._remove(key); return; }
      var u={}; u[key]=qty;
      fetch('/cart/update.js',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({updates:u}) })
        .then(function(){ APN._refreshCart(); });
    };

    APN._remove = function(key) {
      fetch('/cart/change.js',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id:key,quantity:0}) })
        .then(function(){ APN._refreshCart(); });
    };

    APN._money = function(cents) {
      return '$'+(cents/100).toFixed(2);
    };

    APN.toggleMenu = function() {
      var menu = document.getElementById('apn-mobile-menu');
      var btn  = document.getElementById('apn-hamburger');
      if (!menu) return;
      var open = menu.classList.toggle('open');
      if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    };

    APN.closeMenu = function() {
      var menu = document.getElementById('apn-mobile-menu');
      var btn  = document.getElementById('apn-hamburger');
      if (menu) menu.classList.remove('open');
      if (btn)  btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    /* init badge on load */
    document.addEventListener('DOMContentLoaded', function(){ APN._refreshCart(); });
  </script>

  {%- if first_time_accessed and order -%}
  <!-- Purchase tracking - fires once on order confirmation -->
  <script>
    if(window.gtag) gtag('event','purchase',{
      transaction_id: '{{ order.order_number }}',
      value: {{ order.total_price | money_without_currency }},
      currency: '{{ order.currency }}',
      items: [{% for line in order.line_items %}{item_id:'{{ line.variant_id }}',item_name:{{ line.title | json }},price:{{ line.price | money_without_currency }},quantity:{{ line.quantity }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
    });
    if(window.fbq) fbq('track','Purchase',{
      value: {{ order.total_price | money_without_currency }},
      currency: '{{ order.currency }}',
      content_ids: [{% for line in order.line_items %}'{{ line.variant_id }}'{% unless forloop.last %},{% endunless %}{% endfor %}]
    });
  </script>
  {%- endif -%}

</body>
</html>
