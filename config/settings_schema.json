[
  {
    "name": "theme_info",
    "theme_name": "APN Theme",
    "theme_version": "1.0.0",
    "theme_author": "Ascend Performance Nutrition",
    "theme_documentation_url": "https://github.com/SuttonH-Ascend/new-website-apn",
    "theme_support_url": "https://github.com/SuttonH-Ascend/new-website-apn"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary brand color",
        "default": "#06A5C5"
      },
      {
        "type": "color",
        "id": "color_dark",
        "label": "Dark / background color",
        "default": "#0D0D0D"
      },
      {
        "type": "color",
        "id": "color_body",
        "label": "Body text color",
        "default": "#333333"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "helvetica_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "helvetica_n4"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_cart_drawer",
        "label": "Enable cart drawer",
        "default": true
      },
      {
        "type": "text",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (in dollars)",
        "default": "75"
      }
    ]
  },
  {
    "name": "Analytics",
    "settings": [
      {
        "type": "text",
        "id": "meta_pixel_id",
        "label": "Meta (Facebook) Pixel ID",
        "info": "Paste your Pixel ID only — not the full script"
      },
      {
        "type": "text",
        "id": "tiktok_pixel_id",
        "label": "TikTok Pixel ID"
      },
      {
        "type": "text",
        "id": "google_ads_id",
        "label": "Google Ads Conversion ID"
      },
      {
        "type": "text",
        "id": "ms_clarity_id",
        "label": "Microsoft Clarity Project ID"
      }
    ]
  }
]
