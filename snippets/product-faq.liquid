{%- comment -%}
  Product FAQ accordion.
  Uses product.metafields.custom.faq (JSON array of {question, answer})
{%- endcomment -%}

{%- assign faqs = product.metafields.custom.faq.value -%}

{%- if faqs != blank -%}
<section id="product-faq" style="background:#fff;padding:5rem 1.5rem;">
  <div style="max-width:720px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:3rem;" class="apn-fade-up">
      <div class="apn-section-label" style="justify-content:center;">FAQ</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3vw,2.25rem);color:#0D0D0D;margin:0;">Frequently Asked Questions</h2>
    </div>

    <div style="display:flex;flex-direction:column;gap:0;" class="apn-fade-up">
      {%- for faq in faqs -%}
        <div style="border-bottom:1px solid #E2E8F0;">
          <button
            onclick="APNFaq.toggle(this)"
            aria-expanded="false"
            style="width:100%;text-align:left;background:none;border:none;padding:1.25rem 0;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:1rem;"
          >
            <span style="font-family:'Barlow',sans-serif;font-weight:700;font-size:1rem;color:#0D0D0D;line-height:1.4;">{{ faq.question }}</span>
            <svg class="apn-faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#06A5C5" stroke-width="2.5" style="flex-shrink:0;transition:transform 0.2s ease;" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="apn-faq-answer" style="display:none;padding:0 0 1.25rem;">
            <p style="font-size:0.9375rem;line-height:1.75;color:#6B7280;margin:0;">{{ faq.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>

  <script>
    var APNFaq = {
      toggle: function(btn) {
        var answer = btn.nextElementSibling;
        var icon = btn.querySelector('.apn-faq-icon');
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', !isOpen);
        answer.style.display = isOpen ? 'none' : 'block';
        if (icon) icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
      }
    };
  </script>
</section>
{%- endif -%}
