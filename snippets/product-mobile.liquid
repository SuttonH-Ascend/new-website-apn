<style>
  /* ── Product page mobile layout ── */
  @media (max-width: 900px) {
    /* Stack image above details, tight padding */
    .product-hero-grid {
      grid-template-columns: 1fr !important;
      gap: 1.25rem !important;
      padding: 0.75rem 1rem 3rem !important;
    }
    .product-sticky-img { position: static !important; top: auto !important; }

    /* Breadcrumb smaller + less top padding */
    .breadcrumb { font-size: 0.7rem !important; }
    .breadcrumb > div { padding-top: 76px !important; padding-bottom: 0.5rem !important; }

    /* H1 scale down on tablet */
    .product-hero-grid h1 { font-size: 2rem !important; }

    /* Main image - full-width square, capped height */
    .product-sticky-img > div:first-child {
      border-radius: 14px !important;
      max-height: 380px !important;
      aspect-ratio: 1/1 !important;
    }

    /* Thumb row - scrollable horizontal strip */
    .thumb-grid {
      grid-template-columns: repeat(5, 64px) !important;
      gap: 0.5rem !important;
      overflow-x: auto !important;
      scrollbar-width: none !important;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
    }
    .thumb-grid::-webkit-scrollbar { display: none; }

    /* Stat pills wrap nicely */
    .product-hero-grid [style*="flex-wrap"] { flex-wrap: wrap !important; gap: 0.5rem !important; }

    /* Ingredient wheel + how-to sections */
    .wheel-section { padding: 3rem 1rem !important; }
    .how-to-section { padding: 3rem 1rem !important; }

    /* Impact stat numbers: single column */
    .impact-stat-grid { grid-template-columns: 1fr !important; }
    .impact-card { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.07) !important; }



    /* How to use: single column */
    .how-to-steps-grid { grid-template-columns: 1fr !important; }
  }

  @media (max-width: 480px) {
    /* Hero: full bleed */
    .product-hero-grid { padding: 0.5rem 0.75rem 2.5rem !important; }
    .product-hero-grid h1 { font-size: 1.75rem !important; letter-spacing: -0.02em !important; }

    /* Limit image height on small phones */
    .product-sticky-img > div:first-child { max-height: 300px !important; }

    /* ATC button: big touch target */
    .btn-atc-main, button.btn-cta { min-height: 54px !important; font-size: 1rem !important; }

    /* Flavor buttons scroll horizontally */
    .flavor-grid {
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      scrollbar-width: none !important;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
      gap: 0.5rem !important;
    }
    .flavor-grid::-webkit-scrollbar { display: none; }

    /* Price text size */
    .product-hero-grid [style*="font-size:1.75rem"] { font-size: 1.5rem !important; }
    .product-hero-grid [style*="font-size:2rem"] { font-size: 1.625rem !important; }

    /* Related products: 1 col on very small */
    .related-grid { grid-template-columns: 1fr !important; }
  }

  /* ── Swipe indicator ── */
  .swipe-hint {
    display: none;
    text-align: center;
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.3);
    margin-top: 0.5rem;
    letter-spacing: 0.08em;
    font-family: 'Barlow Condensed', sans-serif;
    text-transform: uppercase;
  }
  @media (max-width: 900px) {
    .swipe-hint { display: block; }
    /* Thumbnail strip layout */
    .thumb-strip {
      display: flex !important;
      flex-direction: row !important;
      gap: 0.5rem !important;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 4px;
    }
    .thumb-strip::-webkit-scrollbar { display: none; }
    .thumb-strip .thumb { flex-shrink: 0 !important; width: 60px !important; height: 60px !important; }
  }
</style>

<script>
/* ── Ingredient wheel: scale to viewport on mobile ── */
(function() {
  function scaleWheel() {
    var wrap = document.getElementById('wheel-wrap');
    if (!wrap) return;
    if (window.innerWidth > 900) {
      wrap.style.transform = '';
      wrap.style.marginBottom = '';
      return;
    }
    var available = Math.min(window.innerWidth * 0.9, 480);
    var scale = available / 660;
    wrap.style.transformOrigin = 'top center';
    wrap.style.transform = 'scale(' + scale + ')';
    wrap.style.marginBottom = Math.round(-660 * (1 - scale)) + 'px';
  }
  scaleWheel();
  window.addEventListener('resize', scaleWheel);
})();

/* ── Touch swipe for product main image ── */
(function() {
  var mainImg = document.getElementById('main-img');
  if (!mainImg) return;

  var touchStartX = 0;
  var touchStartY = 0;
  var thumbs = document.querySelectorAll('.thumb');

  function getActiveIdx() {
    for (var i = 0; i < thumbs.length; i++) {
      if (thumbs[i].classList.contains('active')) return i;
    }
    return 0;
  }

  function goToThumb(idx) {
    if (idx < 0) idx = thumbs.length - 1;
    if (idx >= thumbs.length) idx = 0;
    if (thumbs[idx]) thumbs[idx].click();
  }

  mainImg.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  mainImg.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    var dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) < 40 || Math.abs(dy) > Math.abs(dx)) return;
    goToThumb(dx < 0 ? getActiveIdx() + 1 : getActiveIdx() - 1);
  }, { passive: true });

  /* Show swipe hint on mobile */
  if (window.innerWidth <= 900 && thumbs.length > 1) {
    var hint = document.createElement('p');
    hint.className = 'swipe-hint';
    hint.textContent = 'Swipe to see more';
    var wrap = mainImg.closest('[style*="border-radius"]') || mainImg.parentNode;
    if (wrap && wrap.parentNode) wrap.parentNode.insertBefore(hint, wrap.nextSibling);
  }
})();
</script>
