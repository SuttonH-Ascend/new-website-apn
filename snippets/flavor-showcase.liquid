{% comment %}
  Flavor Showcase — Immersive animated flavor selector
  Renders only when product has more than 1 variant.
  Usage: {% render 'flavor-showcase', product: product %}
{% endcomment %}

{% if product.variants.size > 1 %}

<style>
  /* ── SECTION ── */
  #apn-flavor-showcase {
    position: relative;
    overflow: hidden;
    background: #080808;
    padding: 6rem 1.5rem 7rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* ── BACKGROUND LAYERS ── */
  .apn-fs-bg-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #apn-fs-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.038;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
    z-index: 1;
  }

  /* ── PRODUCT VISUAL ── */
  #apn-fs-visual {
    position: relative;
    width: 400px;
    height: 400px;
    flex-shrink: 0;
    margin: 0 auto;
  }

  #apn-fs-ring-outer {
    position: absolute;
    inset: -10%;
    border-radius: 50%;
    border: 1px dashed rgba(255,255,255,0.08);
    animation: apn-fs-spin 30s linear infinite;
    transition: border-color 0.6s ease;
  }

  #apn-fs-ring-dot {
    position: absolute;
    top: 6%;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #06A5C5;
    box-shadow: 0 0 10px 3px rgba(6,165,197,0.6);
    transition: background 0.6s ease, box-shadow 0.6s ease;
  }

  #apn-fs-ring-inner {
    position: absolute;
    inset: 5%;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.04);
    animation: apn-fs-spin 50s linear infinite reverse;
  }

  #apn-fs-glow {
    position: absolute;
    inset: -5%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6,165,197,0.28) 0%, transparent 70%);
    animation: apn-fs-pulse 5s ease-in-out infinite;
    transition: background 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  #apn-fs-img-wrap {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.018);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: apn-fs-float 7s ease-in-out infinite;
    overflow: hidden;
  }

  #apn-fs-img {
    width: 84%;
    height: 84%;
    object-fit: contain;
    filter: drop-shadow(0 24px 40px rgba(0,0,0,0.65));
    transition: opacity 0.28s ease;
  }

  #apn-fs-img.fading { opacity: 0; }

  @keyframes apn-fs-spin  { to { transform: rotate(360deg); } }
  @keyframes apn-fs-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
  @keyframes apn-fs-pulse { 0%, 100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.06); } }

  /* ── INFO PANEL ── */
  #apn-fs-info { max-width: 460px; }

  #apn-fs-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #06A5C5;
    margin-bottom: 0.6rem;
    transition: color 0.6s ease;
  }

  #apn-fs-swatch-bar {
    width: 52px;
    height: 3px;
    border-radius: 999px;
    background: #06A5C5;
    margin-bottom: 1.5rem;
    transition: background 0.6s ease, width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #apn-fs-name {
    font-family: Georgia, serif;
    font-size: clamp(2.25rem, 4vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #F8FAFB;
    margin-bottom: 0.625rem;
    transition: opacity 0.22s ease, transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #apn-fs-descriptor {
    font-family: 'Barlow', sans-serif;
    font-size: 1.0625rem;
    color: #9ca3af;
    line-height: 1.65;
    margin-bottom: 2.25rem;
    transition: opacity 0.22s ease;
  }

  /* ── STAT CARDS ── */
  .apn-fs-stat {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1.125rem;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    margin-bottom: 0.5rem;
    transition: border-color 0.5s ease;
  }

  .apn-fs-stat:hover { border-color: rgba(255,255,255,0.14); }

  .apn-fs-stat-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(6,165,197,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.6s ease;
  }

  .apn-fs-stat-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F8FAFB;
    line-height: 1.2;
  }

  .apn-fs-stat-sub {
    font-size: 0.78rem;
    color: #6b7280;
    margin-top: 0.15rem;
  }

  /* ── ISLAND SWITCHER ── */
  #apn-fs-switcher {
    display: flex;
    justify-content: center;
    margin-top: 4.5rem;
    position: relative;
    z-index: 2;
  }

  .apn-fs-island {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.35rem;
    background: rgba(14,14,14,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 999px;
    box-shadow:
      0 28px 64px rgba(0,0,0,0.55),
      0 4px 12px rgba(0,0,0,0.35),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .apn-fs-btn {
    position: relative;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.65rem 1.375rem;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: #4b5563;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.25s ease;
    outline: none;
  }

  .apn-fs-btn:hover { color: #9ca3af; }
  .apn-fs-btn:focus-visible { outline: 2px solid rgba(6,165,197,0.5); outline-offset: 2px; }

  .apn-fs-btn.active { color: #F8FAFB; }

  .apn-fs-btn-pill {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: rgba(255,255,255,0.07);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .apn-fs-btn.active .apn-fs-btn-pill { opacity: 1; }

  .apn-fs-btn-underline {
    position: absolute;
    bottom: 5px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .apn-fs-btn.active .apn-fs-btn-underline { opacity: 1; }

  /* ── RESPONSIVE ── */
  @media (max-width: 820px) {
    #apn-fs-main { flex-direction: column !important; gap: 3rem !important; }
    #apn-fs-visual { width: 280px; height: 280px; }
    #apn-fs-info { max-width: 100%; text-align: center; }
    #apn-fs-swatch-bar { margin-left: auto; margin-right: auto; }
    .apn-fs-island { flex-wrap: wrap; justify-content: center; max-width: 320px; }
  }
</style>

<section id="apn-flavor-showcase" aria-label="Flavor explorer">

  <!-- Crossfade background layers -->
  <div id="apn-fs-layer-a" class="apn-fs-bg-layer" style="opacity:1;"></div>
  <div id="apn-fs-layer-b" class="apn-fs-bg-layer" style="opacity:0;"></div>
  <div id="apn-fs-grain"></div>

  <div style="max-width:1200px;margin:0 auto;position:relative;z-index:2;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:#06A5C5;margin-bottom:0.75rem;" id="apn-fs-section-eyebrow">Choose Your Flavor</p>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.875rem,3vw,2.625rem);font-weight:700;letter-spacing:-0.03em;color:#F8FAFB;margin:0;">Find Your Perfect Match</h2>
    </div>

    <!-- Main: Visual + Info -->
    <div id="apn-fs-main" style="display:flex;align-items:center;justify-content:center;gap:5rem;">

      <!-- LEFT: Product visual -->
      <div id="apn-fs-visual">
        <div id="apn-fs-ring-outer">
          <span id="apn-fs-ring-dot"></span>
        </div>
        <div id="apn-fs-ring-inner"></div>
        <div id="apn-fs-glow"></div>
        <div id="apn-fs-img-wrap">
          {% assign first_variant = product.selected_or_first_available_variant %}
          {% if first_variant.featured_image %}
            <img id="apn-fs-img" src="{{ first_variant.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="eager" />
          {% elsif product.featured_image %}
            <img id="apn-fs-img" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="eager" />
          {% else %}
            <img id="apn-fs-img" src="" alt="{{ product.title | escape }}" style="display:none;" />
          {% endif %}
        </div>
      </div>

      <!-- RIGHT: Flavor info -->
      <div id="apn-fs-info">
        <p id="apn-fs-eyebrow">Flavor</p>
        <div id="apn-fs-swatch-bar"></div>
        <h3 id="apn-fs-name">{{ first_variant.title }}</h3>
        <p id="apn-fs-descriptor"></p>

        <!-- Stat cards -->
        <div id="apn-fs-stats">
          <div class="apn-fs-stat">
            <div class="apn-fs-stat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F8FAFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <div class="apn-fs-stat-label">Third-Party Tested</div>
              <div class="apn-fs-stat-sub">Certified purity and potency</div>
            </div>
          </div>
          <div class="apn-fs-stat">
            <div class="apn-fs-stat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F8FAFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
            <div>
              <div class="apn-fs-stat-label">No Artificial Dyes</div>
              <div class="apn-fs-stat-sub">Clean formula, real flavor</div>
            </div>
          </div>
          <div class="apn-fs-stat">
            <div class="apn-fs-stat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F8FAFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <div class="apn-fs-stat-label">30-Day Guarantee</div>
              <div class="apn-fs-stat-sub">Love it or your money back</div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Island Switcher -->
    <div id="apn-fs-switcher">
      <div class="apn-fs-island" role="radiogroup" aria-label="Select flavor">
        {% for variant in product.variants %}
          <button
            class="apn-fs-btn{% if forloop.first %} active{% endif %}"
            role="radio"
            aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
            data-variant-id="{{ variant.id }}"
            data-flavor="{{ variant.title | escape }}"
            data-price="{{ variant.price }}"
            data-available="{{ variant.available }}"
            {% if variant.featured_image %}
              data-img="{{ variant.featured_image | image_url: width: 800 }}"
            {% elsif product.featured_image %}
              data-img="{{ product.featured_image | image_url: width: 800 }}"
            {% else %}
              data-img=""
            {% endif %}
            onclick="APNFlavor.select(this)">
            <span class="apn-fs-btn-pill" aria-hidden="true"></span>
            {{ variant.title }}
            <span class="apn-fs-btn-underline" aria-hidden="true"></span>
          </button>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var FLAVOR_MAP = {
    'lychee':           { primary: '#C8254C', glow: 'rgba(200,37,76,0.32)',   bg: 'rgba(200,37,76,0.10)',   descriptor: 'Delicate. Exotic. Light on the palate with a floral sweetness.' },
    'peach mango':      { primary: '#F07030', glow: 'rgba(240,112,48,0.32)',  bg: 'rgba(240,112,48,0.10)',  descriptor: 'Sun-ripened tropical sweetness. Bright peach meets bold mango.' },
    'passion fruit':    { primary: '#7C22BD', glow: 'rgba(124,34,189,0.32)',  bg: 'rgba(124,34,189,0.10)',  descriptor: 'Bold. Tangy. An intensely vibrant hit of tropical flavor.' },
    'lemonade':         { primary: '#C9A200', glow: 'rgba(201,162,0,0.32)',   bg: 'rgba(201,162,0,0.10)',   descriptor: 'Crisp. Bright. Like fresh-squeezed on a perfect summer day.' },
    'melon creamsicle': { primary: '#F07850', glow: 'rgba(240,120,80,0.32)',  bg: 'rgba(240,120,80,0.10)',  descriptor: 'Smooth and creamy with a burst of fresh honeydew.' },
    'guava berry':      { primary: '#D03060', glow: 'rgba(208,48,96,0.32)',   bg: 'rgba(208,48,96,0.10)',   descriptor: 'Bright tropical guava fused with ripe berry sweetness.' },
    'cotton candy':     { primary: '#B070D8', glow: 'rgba(176,112,216,0.32)', bg: 'rgba(176,112,216,0.10)', descriptor: 'Playful and sweet. Pure nostalgia in every scoop.' },
    'chocolate':        { primary: '#8B4020', glow: 'rgba(139,64,32,0.32)',   bg: 'rgba(139,64,32,0.10)',   descriptor: 'Rich dark chocolate. Decadent, indulgent, deeply satisfying.' },
    'vanilla':          { primary: '#C49030', glow: 'rgba(196,144,48,0.32)',  bg: 'rgba(196,144,48,0.10)',  descriptor: 'Smooth, creamy vanilla. A timeless classic done perfectly.' },
  };

  var DEFAULT = { primary: '#06A5C5', glow: 'rgba(6,165,197,0.32)', bg: 'rgba(6,165,197,0.10)', descriptor: 'Clean, effective, and delicious in every serving.' };

  function getColor(name) {
    var n = (name || '').toLowerCase().trim();
    for (var k in FLAVOR_MAP) {
      if (n.indexOf(k) !== -1) return FLAVOR_MAP[k];
    }
    return DEFAULT;
  }

  var section   = document.getElementById('apn-flavor-showcase');
  if (!section) return;

  var layerA    = document.getElementById('apn-fs-layer-a');
  var layerB    = document.getElementById('apn-fs-layer-b');
  var imgEl     = document.getElementById('apn-fs-img');
  var nameEl    = document.getElementById('apn-fs-name');
  var descEl    = document.getElementById('apn-fs-descriptor');
  var swatchEl  = document.getElementById('apn-fs-swatch-bar');
  var eyebrowEl = document.getElementById('apn-fs-eyebrow');
  var glowEl    = document.getElementById('apn-fs-glow');
  var ringDot   = document.getElementById('apn-fs-ring-dot');
  var statIcons = section.querySelectorAll('.apn-fs-stat-icon');

  var activeLayer   = layerA;
  var inactiveLayer = layerB;

  function buildGradient(color) {
    return (
      'radial-gradient(ellipse 75% 65% at 25% 50%, ' + color.glow + ', transparent 65%),' +
      'radial-gradient(ellipse 45% 50% at 78% 82%, ' + color.bg  + ', transparent 55%)'
    );
  }

  function applyColors(color) {
    // Crossfade background layers
    inactiveLayer.style.background = buildGradient(color);
    inactiveLayer.style.opacity = '1';
    activeLayer.style.opacity   = '0';
    var tmp    = activeLayer;
    activeLayer   = inactiveLayer;
    inactiveLayer = tmp;

    // Glow
    if (glowEl) glowEl.style.background = 'radial-gradient(circle, ' + color.glow + ' 0%, transparent 70%)';

    // Ring dot
    if (ringDot) {
      ringDot.style.background  = color.primary;
      ringDot.style.boxShadow   = '0 0 10px 3px ' + color.glow;
    }

    // Swatch bar
    if (swatchEl) swatchEl.style.background = color.primary;

    // Eyebrow label color
    if (eyebrowEl) eyebrowEl.style.color = color.primary;

    // Stat icon backgrounds
    statIcons.forEach(function (el) { el.style.background = color.bg; });
  }

  function switchFlavor(name, imgSrc) {
    var color = getColor(name);
    applyColors(color);

    // Animate name out, update, animate in
    if (nameEl) {
      nameEl.style.opacity   = '0';
      nameEl.style.transform = 'translateY(10px)';
      setTimeout(function () {
        nameEl.textContent     = name;
        nameEl.style.opacity   = '1';
        nameEl.style.transform = 'translateY(0)';
      }, 200);
    }

    // Fade descriptor
    if (descEl) {
      descEl.style.opacity = '0';
      setTimeout(function () {
        descEl.textContent = color.descriptor;
        descEl.style.opacity = '1';
      }, 240);
    }

    // Crossfade image
    if (imgEl && imgSrc) {
      imgEl.classList.add('fading');
      setTimeout(function () {
        imgEl.src = imgSrc;
        imgEl.style.display = 'block';
        imgEl.classList.remove('fading');
      }, 290);
    }
  }

  window.APNFlavor = {
    select: function (btn) {
      if (!btn) return;

      var flavor    = btn.getAttribute('data-flavor');
      var imgSrc    = btn.getAttribute('data-img');
      var variantId = btn.getAttribute('data-variant-id');
      var price     = parseInt(btn.getAttribute('data-price'), 10) || 0;
      var available = btn.getAttribute('data-available') !== 'false';

      // Update island active state
      section.querySelectorAll('.apn-fs-btn').forEach(function (b) {
        var isActive = b === btn;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });

      // Switch visuals
      switchFlavor(flavor, imgSrc);

      // Sync with product hero flavor buttons
      var heroBtns = document.querySelectorAll('.flavor-btn');
      heroBtns.forEach(function (b) {
        var match = b.textContent.trim() === flavor;
        b.classList.toggle('active', match);
      });

      // Update shared variant state
      var varInput = document.getElementById('selected-variant-id');
      if (varInput) varInput.value = variantId;

      var fmt = '$' + (price / 100).toFixed(2);
      var priceEl = document.getElementById('price-display');
      if (priceEl) priceEl.textContent = fmt;

      var cartBtn = document.getElementById('add-to-cart-btn');
      if (cartBtn) {
        cartBtn.disabled    = !available;
        cartBtn.textContent = available ? 'Add to Cart \u2014 ' + fmt : 'Sold Out';
      }

      var labelEl = document.getElementById('flavor-label');
      if (labelEl) labelEl.textContent = flavor;
    }
  };

  // Initialize with first active button
  var firstBtn = section.querySelector('.apn-fs-btn.active') || section.querySelector('.apn-fs-btn');
  if (firstBtn) {
    var initColor = getColor(firstBtn.getAttribute('data-flavor') || '');
    applyColors(initColor);
    if (descEl) descEl.textContent = initColor.descriptor;
  }

  // Sync showcase when product hero flavor buttons are clicked
  document.addEventListener('DOMContentLoaded', function () {
    var heroBtns = document.querySelectorAll('.flavor-btn');
    heroBtns.forEach(function (heroBtn) {
      heroBtn.addEventListener('click', function () {
        var title = heroBtn.textContent.trim();
        section.querySelectorAll('.apn-fs-btn').forEach(function (b) {
          if (b.getAttribute('data-flavor') === title) APNFlavor.select(b);
        });
      });
    });

    // Also extend window.selectVariant to keep showcase in sync
    var origSelectVariant = window.selectVariant;
    window.selectVariant = function (variantId, variantTitle, variantPriceCents, btn) {
      if (origSelectVariant) origSelectVariant(variantId, variantTitle, variantPriceCents, btn);
      section.querySelectorAll('.apn-fs-btn').forEach(function (b) {
        if (b.getAttribute('data-variant-id') == variantId) APNFlavor.select(b);
      });
    };
  });

})();
</script>

{% endif %}
