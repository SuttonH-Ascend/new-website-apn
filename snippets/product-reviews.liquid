    {%- assign review_rows = apn_reviews | split: "
" -%}
    {%- for row in review_rows -%}
      {%- unless row == blank -%}
        {%- assign cols = row | split: "|" -%}
        {%- assign r_author = cols[0] | strip -%}
        {%- assign r_role = cols[1] | strip -%}
        {%- assign r_stars = cols[2] | strip | plus: 0 -%}
        {%- assign r_title = cols[3] | strip -%}
        {%- assign r_body = cols[4] | strip -%}
        {%- assign r_idx = forloop.index | minus: 1 -%}
        <div class="apn-review-card{% if r_idx >= 6 %} apn-rev-hidden{% endif %}" style="background:#131313;border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:1.75rem;{% if r_idx >= 6 %}display:none;{% endif %}">
          <div style="display:flex;gap:2px;color:#F59E0B;margin-bottom:0.875rem;">
            {%- for i in (1..5) -%}
              {%- if i <= r_stars -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- else -%}
