    <div id="apn-load-more-wrap" style="text-align:center;margin-top:2.5rem;">
      <button onclick="apnLoadMore()" style="font-family:'Barlow Condensed',sans-serif;font-size:0.8125rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(248,250,251,0.65);padding:0.875rem 2.5rem;border-radius:6px;cursor:pointer;transition:border-color 0.18s ease,color 0.18s ease;" onmouseover="this.style.borderColor='#06A5C5';this.style.color='#06A5C5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='rgba(248,250,251,0.65)'">Load More Reviews</button>
    </div>

  </div>

  <style>
    @media (max-width: 900px) { #review-grid { grid-template-columns: repeat(2,1fr) !important; } }
    @media (max-width: 600px) { #review-grid { grid-template-columns: 1fr !important; } }
  </style>

  <script>
    (function(){
      var wrap = document.getElementById('apn-load-more-wrap');
      var hidden = document.querySelectorAll('.apn-rev-hidden');
      if (!hidden || hidden.length === 0) { if (wrap) wrap.style.display = 'none'; }
      window.apnLoadMore = function() {
        var cards = document.querySelectorAll('.apn-review-card.apn-rev-hidden');
        var shown = 0;
        for (var i = 0; i < cards.length && shown < 6; i++) {
          cards[i].style.display = '';
          cards[i].classList.remove('apn-rev-hidden');
          shown++;
        }
        if (document.querySelectorAll('.apn-review-card.apn-rev-hidden').length === 0) {
          if (wrap) wrap.style.display = 'none';
        }
      };
    })();
  </script>
