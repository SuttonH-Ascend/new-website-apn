{%- comment -%}
  Product reviews - 20+ per product, product-specific via product.handle.
  First 6 visible, Load More reveals the rest.
{%- endcomment -%}

{%- liquid
  case product.handle
    when 'resilience'
      assign review_count = 24
    when 'replenish'
      assign review_count = 22
    when 'replenish-plus'
      assign review_count = 20
    when 'recharge'
      assign review_count = 23
    when 'ignite'
      assign review_count = 21
    when 'fortify'
      assign review_count = 20
    when 'foundation'
      assign review_count = 20
    when 'adapt'
      assign review_count = 20
    when 'balance'
      assign review_count = 20
    when 'clarity'
      assign review_count = 20
    when 'function'
      assign review_count = 20
    when 'nourish'
      assign review_count = 20
    when 'omega3'
      assign review_count = 20
    when 'recover'
      assign review_count = 20
    else
      assign review_count = 20
  endcase
-%}

<section id="product-reviews" style="background:#0a0a0a;padding:5rem 1.5rem;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:1280px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:3rem;">
      <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:0.875rem;">
        <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#06A5C5;">Reviews</span>
        <div style="height:1px;width:30px;background:#06A5C5;opacity:0.55;"></div>
      </div>
      <h2 style="font-family:Georgia,serif;font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;letter-spacing:-0.02em;color:#F8FAFB;margin:0 0 1.25rem;">What Athletes Are Saying</h2>
      <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;">
        <div style="display:flex;gap:3px;color:#F59E0B;">
          {%- for i in (1..5) -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>{%- endfor -%}
