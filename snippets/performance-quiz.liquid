  /* ── TIER LOGIC — Aligned with APN App Spec ─────────────── */
  function getTier(score) {
    if (score < 40) return { name:'Rookie',     color:'#22C55E', gradId:'dial-grad-red',      desc:'Every change you make creates instant results. Major gains across all pillars available now.' };
    if (score < 60) return { name:'Athlete',    color:'#06A5C5', gradId:'dial-grad-green',    desc:'Solid base with key gaps holding you back. Fix your top 3 and your performance jumps fast.' };
    if (score < 75) return { name:'Competitor', color:'#F59E0B', gradId:'dial-grad-yellow',   desc:'Strong foundation with clear next steps. The gap between you and Competitor is specific and closeable.' };
    if (score < 90) return { name:'Elite',      color:'#8B5CF6', gradId:'dial-grad-elite',    desc:'High performer ready to fine-tune. Precision beats volume at this tier.' };
    return             { name:'Champion',        color:'#EF4444', gradId:'dial-grad-champion', desc:'Operating at peak. Your job is to protect and refine — not rebuild.' };
  }

  function round(n) { return Math.round(n); }

  /* ── PUBLIC API ─────────────────────────────────────────── */
  window.APNQuiz = {

    start: function() {
      document.getElementById('apn-hero').style.cssText += 'display:none !important;';
      var body = document.getElementById('apn-quiz-body');
      body.style.cssText += 'display:block !important;';
      document.getElementById('apn-progress').classList.add('visible');
      this.showStep(1);
    },

    showStep: function(n) {
      document.querySelectorAll('#apn-quiz-section .apn-step').forEach(function(el) { el.classList.remove('active'); });
      document.getElementById('apn-results').classList.remove('active');
      if (n <= 10) {
        state.currentStep = n;
        document.getElementById('apn-step-' + n).classList.add('active');
        var pct = round(((n - 1) / 10) * 100);
        document.getElementById('apn-progress-fill').style.width = pct + '%';
        document.getElementById('apn-step-label').textContent = 'Question ' + n + ' of 10';
        document.getElementById('apn-step-pct').textContent = pct + '%';
        window.scrollTo({ top: document.getElementById('apn-quiz-section').offsetTop, behavior: 'smooth' });
      }
    },

    pick: function(qNum, points, el) {
      el.closest('.apn-options').querySelectorAll('.apn-option').forEach(function(o) { o.classList.remove('selected'); });
      el.classList.add('selected');
      state.scores[qNum - 1] = points;
      state.selectedValues[qNum - 1] = points;
      var insightEl = document.getElementById('apn-insight-' + qNum);
      var insightData = INSIGHTS[qNum][points];
      if (insightData) {
        insightEl.innerHTML = '<div class="apn-insight-label">Performance Insight</div><p><strong>' + insightData.headline + '</strong></p><p>' + insightData.body + '</p>';
        insightEl.classList.add('visible');
      }
      var nextBtn = document.getElementById('apn-next-' + qNum);
      if (nextBtn) nextBtn.classList.add('visible');
      setTimeout(function() { insightEl.scrollIntoView({ behavior:'smooth', block:'nearest' }); }, 150);
    },

    next: function(qNum) {
      if (state.selectedValues[qNum - 1] === null) return;
      this.showStep(qNum + 1);
    },

    showEmailCapture: function() {
      if (state.selectedValues[9] === null) return;
      document.querySelectorAll('#apn-quiz-section .apn-step').forEach(function(el) { el.classList.remove('active'); });
      document.getElementById('apn-step-email').classList.add('active');
      document.getElementById('apn-progress-fill').style.width = '100%';
      document.getElementById('apn-step-label').textContent = 'Almost There';
      document.getElementById('apn-step-pct').textContent = '100%';
      window.scrollTo({ top: document.getElementById('apn-quiz-section').offsetTop, behavior: 'smooth' });
    },

    submitGateEmail: function() {
      var email = document.getElementById('apn-gate-email').value.trim();
      var errEl = document.getElementById('apn-gate-error');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.style.display = 'block'; return; }
      errEl.style.display = 'none';
      state._capturedEmail = email;
      this.finish(true);
    },

    finish: function(emailCaptured) {
      if (state.selectedValues[9] === null) return;
      document.querySelectorAll('#apn-quiz-section .apn-step').forEach(function(el) { el.classList.remove('active'); });
      document.getElementById('apn-progress-fill').style.width = '100%';
      document.getElementById('apn-step-label').textContent = 'Results';
      document.getElementById('apn-step-pct').textContent = '100%';

      var raw = state.scores.reduce(function(a,b){ return a+b; }, 0);
      var score = Math.max(1, Math.min(100, round((raw / MAX_SCORE) * 100)));
      var tier = getTier(score);

      state._score = score;
      state._tier  = tier.name;

      document.getElementById('apn-results').classList.add('active');
      document.getElementById('apn-results-title').textContent = 'You Scored ' + score + ' / 100';
      document.getElementById('apn-results-sub').textContent = tier.desc;
      document.getElementById('apn-tier-name').textContent = tier.name + ' Tier';
      document.getElementById('apn-tier-dot').style.background = tier.color;

      this._animateDial(score, tier);
      this._buildBars();
      this._buildGaps();
      this._buildRecs();
      this._buildWorkoutPlan();

      if (emailCaptured && state._capturedEmail) {
        this._fireKlaviyo(state._capturedEmail);
        document.getElementById('apn-email-form-wrap').style.cssText += 'display:none !important;';
        document.getElementById('apn-success').classList.add('visible');
      }

      window.scrollTo({ top: document.getElementById('apn-quiz-section').offsetTop, behavior: 'smooth' });
    },

    _animateDial: function(score, tier) {
      var arc = document.getElementById('dial-fill-arc');
      var arcLen = Math.PI * 110;
      arc.style.strokeDasharray = arcLen;
      arc.style.strokeDashoffset = arcLen;
      arc.style.stroke = 'url(#' + tier.gradId + ')';
      var targetOffset = arcLen - (arcLen * score / 100);
      setTimeout(function() { arc.style.strokeDashoffset = targetOffset; }, 200);
      var numEl = document.getElementById('dial-score-num');
      var startTime = null;
      function step(ts) {
        if (!startTime) startTime = ts;
        var p = Math.min((ts - startTime) / 1800, 1);
        var e = 1 - Math.pow(1 - p, 3);
        numEl.textContent = round(e * score);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    },

    _buildBars: function() {
      var container = document.getElementById('apn-bars-container');
      container.innerHTML = '';
      CATEGORIES.forEach(function(cat, i) {
        var pct = round((state.scores[i] / cat.max) * 100);
        var item = document.createElement('div');
        item.className = 'apn-bar-item';
        item.innerHTML = '<div class="apn-bar-meta"><span>' + cat.label + '</span><span>' + pct + '%</span></div><div class="apn-mini-bar"><div class="apn-mini-fill" data-pct="' + pct + '"></div></div>';
        container.appendChild(item);
      });
      setTimeout(function() {
        document.querySelectorAll('#apn-quiz-section .apn-mini-fill').forEach(function(el) { el.style.width = el.getAttribute('data-pct') + '%'; });
      }, 300);
    },

    _buildGaps: function() {
      var ranked = CATEGORIES.map(function(cat, i) { return { cat:cat, score:state.scores[i], max:cat.max }; })
        .sort(function(a, b) { return (a.score / a.max) - (b.score / b.max); });
      var worst = ranked.slice(0, 3);
      var container = document.getElementById('apn-gaps-container');
      container.innerHTML = '';
      worst.forEach(function(w, idx) {
        var detail = GAP_DETAILS[w.cat.key];
        var item = document.createElement('div');
        item.className = 'apn-gap-item';
        item.innerHTML = '<div class="apn-gap-icon">' + detail.icon + '</div><div class="apn-gap-text"><strong>Priority ' + (idx+1) + ': ' + detail.gap + '</strong>' + detail.fix + '</div>';
        container.appendChild(item);
      });
      state._worstKeys = worst.map(function(w) { return w.cat.key; });
    },

    _buildRecs: function() {
      var container = document.getElementById('apn-recs-container');
      container.innerHTML = '';
      var seen = {};
      var recs = [];
      (state._worstKeys || []).forEach(function(key) {
        (PRODUCT_MAP[key] || []).forEach(function(p) {
          if (!seen[p.handle]) { seen[p.handle] = true; recs.push(p); }
        });
      });
      recs = recs.slice(0, 5);
      state._recHandles = recs.map(function(r) { return r.handle; });
      if (recs.length === 0) { document.getElementById('apn-recs-section').style.display = 'none'; return; }
      recs.forEach(function(rec) {
        var card = document.createElement('div');
        card.className = 'apn-rec-card';
        card.innerHTML =
          '<div class="apn-rec-icon">' + rec.icon + '</div>' +
          '<div class="apn-rec-info">' +
            '<div class="apn-rec-name">' + rec.name + '</div>' +
            '<div class="apn-rec-reason">' + rec.reason + '</div>' +
            '<div class="apn-rec-tag">' + rec.tag + '</div>' +
          '</div>' +
          '<button class="apn-rec-btn" data-handle="' + rec.handle + '" onclick="APNQuiz.addOne(this,\'' + rec.handle + '\')">+ Add</button>';
        container.appendChild(card);
      });
    },

    _buildWorkoutPlan: function() {
      var wrap = document.getElementById('apn-workout-plan');
      if (!wrap) return;

      var freqScore   = state.scores[4];
      var intScore    = state.scores[5];
      var expScore    = state.scores[9];
      var recScore    = state.scores[1];
      var stressScore = state.scores[8];

      var exp = expScore <= 1 ? 'beginner' : expScore <= 2 ? 'novice' : expScore <= 4 ? 'intermediate' : 'advanced';
      var days = freqScore <= 1 ? 2 : freqScore <= 3 ? 4 : 5;
      var il = intScore <= 1 ? 'light' : intScore <= 2 ? 'moderate' : intScore <= 4 ? 'hard' : 'elite';

      var SCHEMES = {
        beginner:     { P: { light:'3 × 12–15', moderate:'3 × 10–12', hard:'3 × 8–10',  elite:'3 × 8–10'  }, S: { light:'2 × 15', moderate:'3 × 12', hard:'3 × 10–12', elite:'3 × 10–12' }, C: { light:'3 × 20s', moderate:'3 × 30s', hard:'3 × 30s', elite:'3 × 45s' } },
        novice:       { P: { light:'3 × 10–12', moderate:'3 × 8–10',  hard:'4 × 6–8',   elite:'4 × 6–8'   }, S: { light:'3 × 12', moderate:'3 × 12', hard:'3 × 10',    elite:'3 × 10'   } },
        intermediate: { P: { light:'3 × 10–12', moderate:'4 × 8–10',  hard:'4 × 6–8',   elite:'5 × 5'     }, S: { light:'3 × 12', moderate:'3 × 12', hard:'3 × 10',    elite:'4 × 8'    } },
        advanced:     { P: { light:'4 × 8–10',  moderate:'4 × 6–8',   hard:'5 × 4–6',   elite:'5 × 3–5'   }, S: { light:'3 × 12', moderate:'4 × 10', hard:'4 × 8',     elite:'4 × 8'    } }
      };
      var sc = SCHEMES[exp] || SCHEMES.intermediate;
      var P = sc.P[il], S = sc.S[il], C = (sc.C && sc.C[il]) || '3 × 30s';
      var rpeNote  = il === 'light' ? 'RPE 5–6' : il === 'moderate' ? 'RPE 6–7' : il === 'hard' ? 'RPE 7–8' : 'RPE 8–9';
      var restNote = il === 'light' ? '60–90 sec rest' : il === 'moderate' ? '60–90 sec rest' : il === 'hard' ? '2–3 min compounds' : '3–5 min compounds';

      var EX = {
        fullA:  [ { name:'Goblet Squat',                        note:'Focus on depth and upright torso',                    scheme:P },
                  { name:'Push-up or Incline Dumbbell Press',   note:'Keep core tight throughout',                          scheme:P },
                  { name:'Dumbbell Row (each side)',             note:'Full ROM, control the eccentric',                     scheme:P },
                  { name:'Kettlebell or Dumbbell Deadlift',      note:'Drive hips back, flat back',                          scheme:P },
                  { name:'Plank Hold',                           note:'Brace core, breathe',                                 scheme:C } ],
        fullB:  [ { name:'Dumbbell Reverse Lunge',              note:'Alternate legs, controlled descent',                  scheme:P },
                  { name:'Dumbbell Shoulder Press',              note:'Full range of motion overhead',                       scheme:P },
                  { name:'Lat Pulldown or Band Pull-Apart',      note:'Retract scapula before pulling',                      scheme:P },
                  { name:'Romanian Deadlift',                    note:'Feel hamstring stretch at bottom',                    scheme:P },
                  { name:'Dead Bug',                             note:'Slow and controlled, exhale fully',                   scheme:C } ],
        fullC:  [ { name:'Trap Bar Deadlift or Back Squat',     note:'Primary hinge pattern',                               scheme:P },
                  { name:'Incline Dumbbell Press',               note:'45° incline, controlled eccentric',                   scheme:P },
                  { name:'Cable Row or Seated Row',              note:'Drive elbows back, hold 1 sec',                       scheme:P },
                  { name:'Bulgarian Split Squat',                note:'Each leg, glute emphasis',                            scheme:S },
                  { name:'Hollow Body Hold',                     note:'Lower back pressed to floor',                         scheme:C } ],
        upperA: [ { name:'Barbell Bench Press',                 note:'Primary horizontal push',                             scheme:P },
                  { name:'Barbell Row',                          note:'Control the eccentric, flat back',                    scheme:P },
                  { name:'Overhead Press',                       note:'Full lockout at top',                                 scheme:S },
                  { name:'Pull-ups',                             note:'Dead hang to full contraction',                       scheme:S },
                  { name:'Dumbbell Curl',                        note:'No swinging, supinate at top',                        scheme:S },
                  { name:'Tricep Pushdown',                      note:'Elbows pinned to sides',                              scheme:S } ],
        upperB: [ { name:'Incline Barbell Press',               note:'30–45° incline, elbows at 45°',                       scheme:P },
                  { name:'Pendlay Row or Cable Row',             note:'Full hip hinge each rep',                             scheme:P },
                  { name:'Dumbbell Shoulder Press',              note:'Neutral grip option for shoulder health',              scheme:S },
                  { name:'Lat Pulldown',                         note:'Chest-to-bar, full stretch at top',                   scheme:S },
                  { name:'Face Pulls',                           note:'Shoulder health, rotator cuff',                       scheme:'3 × 15–20' },
                  { name:'Hammer Curl',                          note:'Brachialis and brachioradialis',                      scheme:S } ],
        lowerA: [ { name:'Back Squat',                          note:'Primary compound, full depth',                        scheme:P },
                  { name:'Romanian Deadlift',                    note:'Hip hinge, not lower back flex',                      scheme:S },
                  { name:'Leg Press',                            note:'Full ROM, controlled descent',                        scheme:S },
                  { name:'Walking Lunge',                        note:'Each leg, upright torso',                             scheme:S },
                  { name:'Leg Curl',                             note:'Full ROM, eccentric control',                         scheme:S } ],
        lowerB: [ { name:'Deadlift (Conventional or Sumo)',     note:'Primary hip hinge pattern',                           scheme:P },
                  { name:'Bulgarian Split Squat',                note:'Each leg, rear foot elevated',                        scheme:S },
                  { name:'Hack Squat or Leg Press',              note:'High foot position = more glute',                     scheme:S },
                  { name:'Nordic Curl or Leg Curl',              note:'Eccentric emphasis',                                  scheme:S },
                  { name:'Standing Calf Raise',                  note:'4-second eccentric, full stretch',                    scheme:'4 × 15–20' } ],
        push:   [ { name:'Barbell Bench Press',                 note:'Horizontal push primary',                             scheme:P },
                  { name:'Overhead Press',                       note:'Vertical push primary',                               scheme:P },
                  { name:'Incline Dumbbell Press',               note:'Upper chest emphasis',                                scheme:S },
                  { name:'Cable Lateral Raise',                  note:'Long head delts, no momentum',                       scheme:'3 × 15–20' },
                  { name:'Tricep Overhead Extension',            note:'Long head stretch',                                   scheme:S },
                  { name:'Cable Pushdown',                       note:'Elbows pinned, full extension',                       scheme:S } ],
        pull:   [ { name:'Barbell Row',                         note:'Primary horizontal pull',                             scheme:P },
                  { name:'Pull-ups (weighted if available)',     note:'Full ROM, dead hang each rep',                        scheme:P },
                  { name:'Face Pulls',                           note:'Shoulder health, rotator cuff',                       scheme:'3 × 20–25' },
                  { name:'Incline Dumbbell Curl',                note:'Bicep stretch under load',                            scheme:S },
                  { name:'Hammer Curl',                          note:'Brachialis and brachioradialis',                      scheme:S } ],
        legs:   [ { name:'Back Squat',                          note:'Primary lower body compound',                         scheme:P },
                  { name:'Romanian Deadlift',                    note:'Hamstring and glute emphasis',                        scheme:S },
                  { name:'Leg Press',                            note:'High volume quads and glutes',                        scheme:S },
                  { name:'Walking Lunge',                        note:'Each leg, loaded carry optional',                     scheme:S },
                  { name:'Leg Curl',                             note:'Full ROM, eccentric control',                         scheme:S },
                  { name:'Standing Calf Raise',                  note:'4-second eccentric, pause at bottom',                 scheme:'4 × 15–20' } ],
        activeRecovery: [
                  { name:'Light Walking (20–30 min)',            note:'Zone 1, conversational pace — no HR spike',           scheme:'Easy pace' },
                  { name:'Hip Flexor Stretch',                   note:'Hold 60 seconds each side, breathe deeply',           scheme:'2 × 60s' },
                  { name:'Thoracic Extension',                   note:'Foam roller under mid-back, arms overhead',           scheme:'2 × 60s' },
                  { name:'Band Pull-Apart',                      note:'Scapular retraction, shoulder health',                scheme:'2 × 20' } ],
        prehab: [
                  { name:'Foam Roll (Full Body)',                note:'T-spine, lats, quads, calves — 60 sec each area',     scheme:'1 × 5 min' },
                  { name:'Band Pull-Apart',                      note:'Scapular retraction, external rotation emphasis',     scheme:'3 × 20' },
                  { name:'Hip 90/90 Stretch',                    note:'Hold each position, breathe into the stretch',        scheme:'2 × 60s' },
                  { name:'Dead Bug',                             note:'Slow and controlled, exhale fully each rep',           scheme:'3 × 10 each' },
                  { name:'Glute Bridge',                         note:'Activate glutes, protect lower back',                 scheme:'3 × 15' },
                  { name:'Light Walking (20–30 min)',            note:'Zone 1–2, keep HR below 130 bpm',                     scheme:'Easy pace' } ]
      };

      /* ── Generate split and map to fixed Mon/Tue/Thu/Fri ── */
      var planName, planDesc, split;

      if (exp === 'beginner' || exp === 'novice') {
        if (days <= 2) {
          planName = '2-Day Full Body'; planDesc = 'Two full-body sessions hit every major muscle group twice per week — the highest-ROI structure for your current training age.';
          split = [ { title:'Full Body — Session A', exKey:'fullA' }, { title:'Full Body — Session B', exKey:'fullB' } ];
        } else if (days <= 4) {
          planName = '3-Day Full Body'; planDesc = 'Three full-body sessions per week maximizes your adaptation frequency. Each session attacks the same movement patterns from a different angle.';
          split = [ { title:'Full Body — Session A', exKey:'fullA' }, { title:'Full Body — Session B', exKey:'fullB' }, { title:'Full Body — Session C', exKey:'fullC' } ];
        } else {
          planName = '4-Day Upper / Lower'; planDesc = 'Upper/Lower gives you 4 training days while allowing 48-hour recovery between each muscle group.';
          split = [ { title:'Upper Body A', exKey:'upperA' }, { title:'Lower Body A', exKey:'lowerA' }, { title:'Upper Body B', exKey:'upperB' }, { title:'Lower Body B', exKey:'lowerB' } ];
        }
      } else if (exp === 'intermediate') {
        if (days <= 3) {
          planName = '3-Day Push / Pull / Legs'; planDesc = 'PPL is the gold standard 3-day split for intermediate athletes — maximum volume per muscle group with full recovery between sessions.';
          split = [ { title:'Push — Chest, Shoulders, Triceps', exKey:'push' }, { title:'Pull — Back and Biceps', exKey:'pull' }, { title:'Legs — Quads, Hamstrings, Glutes', exKey:'legs' } ];
        } else {
          planName = '4-Day Upper / Lower'; planDesc = 'Upper/Lower 4-day gives each muscle group two high-quality sessions per week with A/B variation cycling strength and hypertrophy rep ranges.';
          split = [ { title:'Upper Body A — Strength', exKey:'upperA' }, { title:'Lower Body A — Strength', exKey:'lowerA' }, { title:'Upper Body B — Volume', exKey:'upperB' }, { title:'Lower Body B — Volume', exKey:'lowerB' } ];
        }
      } else {
        if (days <= 3) {
          planName = '3-Day Strength Block'; planDesc = 'Three heavy sessions focused on compound movements produce maximum stimulus with full CNS recovery at your experience level.';
          split = [ { title:'Upper Body — Strength Focus', exKey:'upperA' }, { title:'Lower Body — Strength Focus', exKey:'lowerA' }, { title:'Full Body — Power Focus', exKey:'fullC' } ];
        } else {
          planName = '4-Day Advanced Upper / Lower'; planDesc = 'Advanced Upper/Lower with A/B variation supports DUP (Daily Undulating Periodization) — cycling strength and hypertrophy within the same week.';
          split = [ { title:'Upper A — Heavy Strength', exKey:'upperA' }, { title:'Lower A — Heavy Strength', exKey:'lowerA' }, { title:'Upper B — Hypertrophy Volume', exKey:'upperB' }, { title:'Lower B — Hypertrophy Volume', exKey:'lowerB' } ];
        }
      }

      /* Map split days to Mon, Tue, Thu, Fri — fill extras with active recovery */
      var DAY_KEYS = ['mon', 'tue', 'thu', 'fri'];
      var weekPlan = {};
      DAY_KEYS.forEach(function(k, i) {
        weekPlan[k] = split[i] ? split[i] : { title:'Active Recovery', exKey:'activeRecovery' };
      });
      weekPlan['sat'] = { title:'Light Movement & Prehab', exKey:'prehab' };

      state._weekPlan = weekPlan;
      state._exPool   = EX;

      /* ── Build calendar ─────────────────────────────────── */
      var DAYS_CONFIG = [
        { key:'mon', abbr:'Mon', type:'train'  },
        { key:'tue', abbr:'Tue', type:'train'  },
        { key:'wed', abbr:'Wed', type:'rest'   },
        { key:'thu', abbr:'Thu', type:'train'  },
        { key:'fri', abbr:'Fri', type:'train'  },
        { key:'sat', abbr:'Sat', type:'prehab' },
        { key:'sun', abbr:'Sun', type:'rest'   }
      ];
      var calHTML = DAYS_CONFIG.map(function(d) {
        var isClickable = d.type !== 'rest';
        var focus = isClickable ? (weekPlan[d.key] ? weekPlan[d.key].title.split('—')[0].trim() : 'Rest') : 'Rest';
        var cls = 'apn-day-cell ' + d.type;
        var click = isClickable ? ' onclick="APNQuiz.selectDay(\'' + d.key + '\')"' : '';
        return '<div class="' + cls + '" id="apn-day-' + d.key + '"' + click + '>' +
          '<span class="apn-day-abbr">' + d.abbr + '</span>' +
          '<span class="apn-day-focus">' + (isClickable ? focus : 'Rest') + '</span>' +
        '</div>';
      }).join('');

      var tags = [rpeNote, restNote, 'Deload Week 4', 'RAMP Warmup', exp.charAt(0).toUpperCase() + exp.slice(1)];
      var tagHTML = tags.map(function(t) { return '<span class="apn-plan-tag">' + t + '</span>'; }).join('');

      var deloadText = stressScore <= 2
        ? 'Your stress score suggests a deload every 3rd week — reduce volume 40% while maintaining intensity.'
        : 'Deload every 4th week: cut volume 40–60%, maintain intensity, and let supercompensation peak.';
      var recoveryText = recScore <= 1
        ? 'Your recovery is a limiting factor. Prioritize 0.3g/kg protein post-training (Resilience) + 5g creatine (Recharge). No CWI immediately post-session.'
        : 'Maintain 48-hour recovery between sessions targeting the same muscle groups. Saturday prehab is non-negotiable at your volume.';

      wrap.innerHTML =
        '<h3>&#128170; Your Custom Training Plan</h3>' +
        '<div class="apn-plan-headline">' + planName + '</div>' +
        '<div class="apn-plan-tags">' + tagHTML + '</div>' +
        '<div class="apn-plan-sub">' + planDesc + '</div>' +
        '<div class="apn-week-strip">' + calHTML + '</div>' +
        '<div id="apn-day-workout"></div>' +
        '<div class="apn-plan-notes">' +
          '<div class="apn-plan-note"><span class="apn-pn-icon">&#128293;</span><div class="apn-pn-text"><strong>RAMP Warm-Up (Every Session)</strong>Raise: 3 min light cardio. Activate: glutes, core, scapulae. Mobilize: dynamic stretching. Potentiate: ramp to working weight across 3 sets.</div></div>' +
          '<div class="apn-plan-note"><span class="apn-pn-icon">&#128197;</span><div class="apn-pn-text"><strong>Deload Protocol</strong>' + deloadText + '</div></div>' +
          '<div class="apn-plan-note"><span class="apn-pn-icon">&#9889;</span><div class="apn-pn-text"><strong>Progressive Overload</strong>Add load only when all reps are completed cleanly. Track every session. Overload via: less rest, more sets, or harder variation.</div></div>' +
          '<div class="apn-plan-note"><span class="apn-pn-icon">&#128300;</span><div class="apn-pn-text"><strong>Recovery Protocol</strong>' + recoveryText + '</div></div>' +
        '</div>';

      // Show Monday by default (use setTimeout so DOM is ready)
      var self = this;
      setTimeout(function() { self.selectDay('mon'); }, 50);

      wrap.style.cssText = wrap.style.cssText.replace('display:none !important;', 'display:block !important;');
    },

    selectDay: function(dayKey) {
      /* Update selected state */
      var allCells = document.querySelectorAll('#apn-quiz-section .apn-day-cell');
      allCells.forEach(function(el) { el.classList.remove('sel'); });
      var dayEl = document.getElementById('apn-day-' + dayKey);
      if (dayEl) dayEl.classList.add('sel');

      var container = document.getElementById('apn-day-workout');
      if (!container) return;

      var plan = state._weekPlan && state._weekPlan[dayKey];
      var EX   = state._exPool;
      if (!plan || !EX || !EX[plan.exKey]) {
        container.innerHTML = '';
        return;
      }

      var exercises = EX[plan.exKey];
      var exHTML = exercises.map(function(ex) {
        return '<div class="apn-ex-row">' +
          '<div class="apn-ex-info">' +
            '<span class="apn-ex-name">' + ex.name + '</span>' +
            (ex.note ? '<span class="apn-ex-note">' + ex.note + '</span>' : '') +
          '</div>' +
          '<span class="apn-ex-sets">' + ex.scheme + '</span>' +
        '</div>';
      }).join('');

      var dayAbbr = { mon:'Monday', tue:'Tuesday', thu:'Thursday', fri:'Friday', sat:'Saturday' };
      container.innerHTML =
        '<div class="apn-wd-card" style="margin-top:16px;">' +
          '<div class="apn-wd-header">' +
            '<span class="apn-wd-label">' + (dayAbbr[dayKey] || dayKey) + '</span>' +
            '<span class="apn-wd-title">' + plan.title + '</span>' +
          '</div>' +
          '<div class="apn-ex-list">' + exHTML + '</div>' +
        '</div>';

      /* Re-trigger fade animation */
      container.style.animation = 'none';
      container.offsetHeight; /* reflow */
      container.style.animation = 'apnFadeUp 0.3s ease both';
    },

    addOne: function(btn, handle) {
      var orig = btn.textContent;
      btn.textContent = 'Adding...';
      btn.style.pointerEvents = 'none';
      fetch('/products/' + handle + '.js')
        .then(function(r) { if (!r.ok) throw new Error('not found'); return r.json(); })
        .then(function(product) {
          var variantId = product.variants[0].id;
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
          }).then(function(r) { return r.json(); });
        })
        .then(function(data) {
          if (data && data.status && data.status >= 400) throw new Error(data.description || 'Cart error');
          btn.textContent = '✓ Added';
          btn.classList.add('added');
          if (typeof APN !== 'undefined' && APN._refreshCart) APN._refreshCart();
        })
        .catch(function(err) {
          console.error('addOne error:', err);
          btn.textContent = orig;
          btn.style.pointerEvents = '';
        });
    },

    addAllToCart: function() {
      var btn = document.getElementById('apn-add-all');
      if (!btn) return;
      btn.textContent = 'Adding...';
      btn.style.pointerEvents = 'none';
      var handles = state._recHandles || [];
      if (!handles.length) {
        btn.textContent = 'Add Entire Stack to Cart \u2192';
        btn.style.pointerEvents = '';
        return;
      }
      Promise.all(handles.map(function(h) {
        return fetch('/products/' + h + '.js')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(p) { return p && p.variants && p.variants[0] ? p.variants[0].id : null; })
          .catch(function() { return null; });
      })).then(function(ids) {
        var items = ids.filter(Boolean).map(function(id) { return { id: id, quantity: 1 }; });
        if (!items.length) {
          btn.textContent = 'Add Entire Stack to Cart \u2192';
          btn.style.pointerEvents = '';
          return Promise.reject({ _empty: true });
        }
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        }).then(function(r) { return r.json(); });
      }).then(function(data) {
        if (data && data.status && data.status >= 400) throw new Error(data.description || 'Cart error');
        btn.textContent = '✓ Stack Added to Cart!';
        btn.style.background = '#27ae60';
        document.querySelectorAll('#apn-quiz-section .apn-rec-btn').forEach(function(b) { b.textContent = '✓ Added'; b.classList.add('added'); });
        if (typeof APN !== 'undefined' && APN.openCart) APN.openCart();
      }).catch(function(err) {
        if (err && err._empty) return;
        console.error('addAllToCart error:', err);
        btn.textContent = 'Add Entire Stack to Cart \u2192';
        btn.style.pointerEvents = '';
      });
    },

    _fireKlaviyo: function(email) {
      var klaviyoKey = 'R5eNpH';
      var listId = 'VwiG2Z';

      var catPcts = {};
      var catTiers = {};
      var catRanked = [];
      CATEGORIES.forEach(function(cat, i) {
        var pct = Math.round((state.scores[i] / cat.max) * 100);
        catPcts[cat.key] = pct;
        var label;
        if (pct <= 25) label = 'Critical';
        else if (pct <= 50) label = 'Developing';
        else if (pct <= 75) label = 'Established';
        else label = 'Elite';
        catTiers[cat.key] = label;
        catRanked.push({ key: cat.key, pct: pct });
      });

      catRanked.sort(function(a, b) { return a.pct - b.pct; });
      var gap1 = catRanked[0] ? catRanked[0].key : '';
      var gap2 = catRanked[1] ? catRanked[1].key : '';
      var gap3 = catRanked[2] ? catRanked[2].key : '';
      var catBest = catRanked.slice().sort(function(a, b) { return b.pct - a.pct; });
      var strength1 = catBest[0] ? catBest[0].key : '';
      var strength2 = catBest[1] ? catBest[1].key : '';

      var score = state._score || 0;
      var tierName = state._tier || '';
      var scoreBand;
      if (score < 40) scoreBand = 'Rookie (0-39)';
      else if (score < 60) scoreBand = 'Athlete (40-59)';
      else if (score < 75) scoreBand = 'Competitor (60-74)';
      else if (score < 90) scoreBand = 'Elite (75-89)';
      else scoreBand = 'Champion (90-100)';

      var criticalCount = catRanked.filter(function(c) { return catTiers[c.key] === 'Critical'; }).length;
      var eliteCount = catRanked.filter(function(c) { return catTiers[c.key] === 'Elite'; }).length;

      var archetypeMap = {
        sleep:'Under-Recovered', recovery:'Overtrained', hydration:'Dehydrated Performer',
        nutrition:'Under-Fueled', frequency:'Inconsistent Trainer', intensity:'Under-Stimulated',
        supps:'Unsupplemented', focus:'Scattered', stress:'Cortisol-Driven', consistency:'Early Stage'
      };
      var archetype = tierName + ' - ' + (archetypeMap[gap1] || 'General');

      var properties = {
        performance_score: score,
        performance_tier: tierName,
        subs_score_band: scoreBand,
        profile_archetype: archetype,
        critical_gap_count: criticalCount,
        elite_area_count: eliteCount,

        quiz_sleep: state.scores[0],
        quiz_recovery: state.scores[1],
        quiz_hydration: state.scores[2],
        quiz_nutrition: state.scores[3],
        quiz_frequency: state.scores[4],
        quiz_intensity: state.scores[5],
        quiz_supplements: state.scores[6],
        quiz_focus: state.scores[7],
        quiz_stress: state.scores[8],
        quiz_consistency: state.scores[9],

        pct_sleep: catPcts.sleep,
        pct_recovery: catPcts.recovery,
        pct_hydration: catPcts.hydration,
        pct_nutrition: catPcts.nutrition,
        pct_frequency: catPcts.frequency,
        pct_intensity: catPcts.intensity,
        pct_supplements: catPcts.supps,
        pct_focus: catPcts.focus,
        pct_stress: catPcts.stress,
        pct_consistency: catPcts.consistency,

        tier_sleep: catTiers.sleep,
        tier_recovery: catTiers.recovery,
        tier_hydration: catTiers.hydration,
        tier_nutrition: catTiers.nutrition,
        tier_frequency: catTiers.frequency,
        tier_intensity: catTiers.intensity,
        tier_supplements: catTiers.supps,
        tier_focus: catTiers.focus,
        tier_stress: catTiers.stress,
        tier_consistency: catTiers.consistency,

        gap_1: gap1,
        gap_2: gap2,
        gap_3: gap3,
        source_strength_one: strength1,
        strength_two: strength2,
        top_gaps: [gap1, gap2, gap3].join(', '),
        recommended_products: (state._recHandles || []).join(', '),
        source: 'Performance Quiz - Ascend',
        quiz_completed_at: new Date().toISOString()
      };

      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + klaviyoKey, {
        method: 'POST',
        headers: { 'Content-Type': 'application/vnd.api+json', 'revision': '2024-10-15' },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: {
              profile: { data: { type: 'profile', attributes: { email: email, properties: properties } } }
            },
            relationships: { list: { data: { type: 'list', id: listId } } }
          }
        })
      }).catch(function(err) { console.warn('Klaviyo subscribe error:', err); });

      fetch('https://a.klaviyo.com/client/events/?company_id=' + klaviyoKey, {
        method: 'POST',
        headers: { 'Content-Type': 'application/vnd.api+json', 'revision': '2024-10-15' },
        body: JSON.stringify({
          data: {
            type: 'event',
            attributes: {
              metric: { data: { type: 'metric', attributes: { name: 'Performance Quiz Completed' } } },
              profile: { data: { type: 'profile', attributes: { email: email } } },
              properties: properties
            }
          }
        })
      }).catch(function(err) { console.warn('Klaviyo event error:', err); });
    },

    submitEmail: function() {
      var email = document.getElementById('apn-email-input').value.trim();
      var errEl = document.getElementById('apn-email-error');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.style.display = 'block'; return; }
      errEl.style.display = 'none';
      this._fireKlaviyo(email);
      this._showSuccess();
    },

    _showSuccess: function() {
      document.getElementById('apn-email-form-wrap').style.cssText += 'display:none !important;';
      document.getElementById('apn-success').classList.add('visible');
    },

    copyCode: function() {
      var code = document.getElementById('apn-discount-code').textContent;
      if (navigator.clipboard) { navigator.clipboard.writeText(code); }
      var copyMsg = document.querySelector('#apn-quiz-section .apn-discount-copy');
      if (copyMsg) copyMsg.textContent = 'Copied! ✓';
    }

  };

})();
</script>

