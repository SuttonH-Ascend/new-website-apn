<section id="about" style="background:#0D0D0D;padding:5rem 1.5rem;position:relative;overflow:hidden;">

  <!-- Background texture -->
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 0% 50%,rgba(6,165,197,0.08) 0%,transparent 60%);pointer-events:none;"></div>

  <div style="max-width:1280px;margin:0 auto;position:relative;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;">

    <!-- Left: image -->
    <div style="position:relative;" class="apn-fade-up">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image_alt | default: 'Ascend founder' }}" style="width:100%;border-radius:8px;object-fit:cover;aspect-ratio:4/5;" />
      {%- else -%}
        <div style="width:100%;aspect-ratio:4/5;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.2);">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
      {%- endif -%}
      <!-- Accent block -->
      <div style="position:absolute;bottom:-1.5rem;right:-1.5rem;background:#06A5C5;padding:1.5rem;border-radius:4px;max-width:200px;">
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#fff;line-height:1;">{{ section.settings.stat_number | default: '4' }}</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.8);margin-top:0.25rem;">{{ section.settings.stat_label | default: 'Core Pillars' }}</div>
      </div>
    </div>

    <!-- Right: copy -->
    <div class="apn-fade-up">
      <div class="apn-section-label" style="color:#06A5C5;">{{ section.settings.eyebrow | default: 'Our Mission' }}</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#fff;margin:0 0 1.25rem;">{{ section.settings.heading | default: 'Performance That Means Something' }}</h2>
      <p style="font-size:1.0625rem;line-height:1.8;color:rgba(255,255,255,0.55);margin:0 0 2rem;">{{ section.settings.body | default: "Sutton Huggins founded Ascend after years of training and competing with no supplement brand that shared his values. Faith. Family. Country. Fitness. That gap is why Ascend exists — to give athletes a stack they can stand behind, inside and outside the gym." }}</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:2.5rem;">
        {%- assign pillars = 'Faith,Family,America,Fitness' | split: ',' -%}
        {%- for pillar in pillars -%}
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <div style="width:8px;height:8px;background:#06A5C5;border-radius:50%;flex-shrink:0;"></div>
            <span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.875rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.7);">{{ pillar }}</span>
          </div>
        {%- endfor -%}
      </div>

      <a href="/pages/about" class="apn-btn apn-btn-outline-light">{{ section.settings.cta_label | default: 'Read Our Story' }}</a>
    </div>

  </div>

  <style>
    @media (max-width: 900px) {
      #about > div { grid-template-columns: 1fr !important; gap: 3rem !important; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Home — About",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Founder image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Ascend founder" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Mission" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Performance That Means Something" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Sutton Huggins founded Ascend after years of training and competing with no supplement brand that shared his values." },
    { "type": "text", "id": "stat_number", "label": "Stat number", "default": "4" },
    { "type": "text", "id": "stat_label", "label": "Stat label", "default": "Core Pillars" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read Our Story" }
  ],
  "presets": [{ "name": "Home — About" }]
}
{% endschema %}
