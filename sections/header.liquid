<style>
  /* ── Nav base ── */
  #main-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(8,8,8,0);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  #main-nav.scrolled {
    background: rgba(8,8,8,0.96);
    box-shadow: 0 1px 0 rgba(255,255,255,0.06), 0 8px 32px rgba(0,0,0,0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* ── Desktop nav links ── */
  .apn-nav-link {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .apn-nav-link:hover,
  .apn-nav-link:focus-visible {
    color: #fff;
    border-bottom-color: #06A5C5;
    outline: none;
  }
  .apn-nav-link:active { color: #06A5C5; }

  /* ── CTA button ── */
  .apn-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #06A5C5 0%, #0487a3 100%);
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: opacity 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    box-shadow: 0 2px 12px rgba(6,165,197,0.35);
  }
  .apn-nav-cta:hover,
  .apn-nav-cta:focus-visible {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(6,165,197,0.5);
    outline: none;
  }
  .apn-nav-cta:active { transform: translateY(0); opacity: 1; }

  /* ── Shop dropdown wrapper ── */
  .apn-shop-dropdown-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .apn-shop-trigger {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    outline: none;
  }
  .apn-shop-trigger:hover,
  .apn-shop-dropdown-wrap:hover .apn-shop-trigger {
    color: #fff;
    border-bottom-color: #06A5C5;
  }
  .apn-shop-trigger svg { transition: transform 0.18s ease; }
  .apn-shop-dropdown-wrap:hover .apn-shop-trigger svg { transform: rotate(180deg); }

  /* ── Dropdown panel ── */
  .apn-shop-dropdown-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0;
    width: 640px;
    background: rgba(13,13,13,0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.07);
    border-top: 2px solid #06A5C5;
    border-radius: 0 0 8px 8px;
    padding: 1.75rem 2rem 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateX(-50%) translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.7), 0 4px 16px rgba(0,0,0,0.4);
  }
  .apn-shop-dropdown-wrap:hover .apn-shop-dropdown-panel,
  .apn-shop-dropdown-wrap:focus-within .apn-shop-dropdown-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .apn-dropdown-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 2rem;
  }
  .apn-dropdown-col-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #06A5C5;
    margin-bottom: 0.625rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(6,165,197,0.25);
  }
  .apn-dropdown-link {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    padding: 0.3rem 0;
    transition: color 0.15s ease, padding-left 0.15s ease;
    line-height: 1.4;
  }
  .apn-dropdown-link:hover,
  .apn-dropdown-link:focus-visible {
    color: #fff;
    padding-left: 0.4rem;
    outline: none;
  }
  .apn-dropdown-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .apn-dropdown-view-all {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #06A5C5;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: gap 0.15s ease, color 0.15s ease;
  }
  .apn-dropdown-view-all:hover,
  .apn-dropdown-view-all:focus-visible {
    color: #fff;
    gap: 0.55rem;
    outline: none;
  }

  /* ── Mobile helpers ── */
  .apn-desktop-only { display: flex; }
  .apn-mobile-only  { display: none; }

  @media (max-width: 900px) {
    .apn-desktop-only { display: none !important; }
    .apn-mobile-only  { display: flex !important; }
    .apn-shop-dropdown-panel { display: none !important; }
  }

  /* ── Mobile menu overlay ── */
  #apn-mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(8,8,8,0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 999;
    padding: 5.5rem 1.5rem 2rem;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  #apn-mobile-menu.open { transform: translateX(0); }

  /* ── Mobile nav links ── */
  .apn-mobile-link {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: color 0.18s ease, padding-left 0.18s ease;
  }
  .apn-mobile-link:hover,
  .apn-mobile-link:focus-visible {
    color: #fff;
    padding-left: 0.5rem;
    outline: none;
  }
  .apn-mobile-sub-category {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #06A5C5;
    padding: 0.75rem 0 0.25rem 1rem;
  }
  .apn-mobile-sub-link {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.58);
    text-decoration: none;
    padding: 0.5rem 0 0.5rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.15s ease;
  }
  .apn-mobile-sub-link:hover,
  .apn-mobile-sub-link:focus-visible {
    color: #06A5C5;
    outline: none;
  }

  /* ── Cart icon ── */
  .apn-cart-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    padding: 0.4rem;
    border-radius: 4px;
    transition: color 0.18s ease;
  }
  .apn-cart-link:hover,
  .apn-cart-link:focus-visible {
    color: #fff;
    outline: none;
  }
  .apn-cart-badge-el {
    position: absolute;
    top: -6px;
    right: -6px;
    background: #06A5C5;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-family: 'Barlow Condensed', sans-serif;
  }
</style>

<nav id="main-nav" class="apn-nav" role="navigation" aria-label="Main navigation">
