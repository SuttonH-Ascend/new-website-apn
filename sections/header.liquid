      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: height: 96 }}" alt="{{ shop.name }}" style="height:48px;width:auto;" />
      {%- else -%}
        <img src="{{ 'ascend real 1_2 trans.png' | asset_url }}" alt="{{ shop.name }}" style="height:48px;width:auto;" />
      {%- endif -%}
      <div style="display:flex;flex-direction:column;line-height:1;gap:2px;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:0.75rem;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.9);">PERFORMANCE</span>
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.22em;text-transform:uppercase;color:#06A5C5;">NUTRITION</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <div class="apn-desktop-only" style="align-items:center;gap:2.5rem;flex:1;justify-content:center;">

      <!-- Shop with dropdown -->
      <div class="apn-shop-dropdown-wrap">
        <button class="apn-shop-trigger" aria-haspopup="true" aria-expanded="false">
          Shop Now
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="2 4 6 8 10 4"/>
          </svg>
        </button>

        <div class="apn-shop-dropdown-panel" role="region" aria-label="Shop categories">
          <div class="apn-dropdown-grid">

            <!-- Protein -->
            <div>
              <div class="apn-dropdown-col-label">Protein</div>
              <a href="{{ routes.collections_url }}/protein" class="apn-dropdown-link">All Protein</a>
            </div>

            <!-- Hydration -->
            <div>
              <div class="apn-dropdown-col-label">Hydration</div>
              <a href="{{ routes.collections_url }}/hydration" class="apn-dropdown-link">All Hydration</a>
            </div>

            <!-- Energy -->
            <div>
              <div class="apn-dropdown-col-label">Energy</div>
              <a href="{{ routes.collections_url }}/energy" class="apn-dropdown-link">All Energy</a>
            </div>

            <!-- Recovery -->
            <div>
              <div class="apn-dropdown-col-label">Recovery</div>
              <a href="{{ routes.collections_url }}/recovery" class="apn-dropdown-link">All Recovery</a>
            </div>

            <!-- Wellness -->
            <div>
              <div class="apn-dropdown-col-label">Wellness</div>
              <a href="{{ routes.collections_url }}/wellness" class="apn-dropdown-link">All Wellness</a>
            </div>

          </div>

          <div class="apn-dropdown-footer">
            <a href="{{ routes.collections_url }}/all" class="apn-dropdown-view-all">
              View All Products &rarr;
            </a>
          </div>
        </div>
      </div>

      <a href="/pages/framework" class="apn-nav-link">Ascend Framework</a>
      <a href="/pages/about" class="apn-nav-link">About Us</a>
      <a href="/pages/resources" class="apn-nav-link">Resources</a>
    </div>

    <!-- Desktop right actions -->
    <div class="apn-desktop-only" style="align-items:center;gap:1rem;flex-shrink:0;">
      <!-- Cart button -->
      <a href="/cart" class="apn-cart-link" aria-label="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        {% if cart.item_count > 0 %}
        <span class="apn-cart-badge-el">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <!-- Quiz CTA -->
      <a href="/pages/quiz" class="apn-nav-cta">Take the Quiz</a>
    </div>

    <!-- Hamburger (mobile) -->
    <button id="apn-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="apn-mobile-menu" class="apn-mobile-only" style="background:none;border:none;cursor:pointer;padding:0.375rem;color:rgba(255,255,255,0.8);">
      <svg id="apn-hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="apn-close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="display:none;">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

  </div>
</nav>

<!-- Mobile menu -->
<div id="apn-mobile-menu" role="dialog" aria-modal="true" aria-label="Mobile navigation">

  <!-- Shop section with category links -->
  <div>
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.25rem;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.8);padding:0.85rem 0;border-bottom:1px solid rgba(255,255,255,0.07);">Shop Now</div>

    <div class="apn-mobile-sub-category">Protein</div>
    <a href="{{ routes.collections_url }}/protein" class="apn-mobile-sub-link" onclick="apnCloseMenu()">All Protein</a>

    <div class="apn-mobile-sub-category">Hydration</div>
    <a href="{{ routes.collections_url }}/hydration" class="apn-mobile-sub-link" onclick="apnCloseMenu()">All Hydration</a>

    <div class="apn-mobile-sub-category">Energy</div>
    <a href="{{ routes.collections_url }}/energy" class="apn-mobile-sub-link" onclick="apnCloseMenu()">All Energy</a>

    <div class="apn-mobile-sub-category">Recovery</div>
    <a href="{{ routes.collections_url }}/recovery" class="apn-mobile-sub-link" onclick="apnCloseMenu()">All Recovery</a>

    <div class="apn-mobile-sub-category">Wellness</div>
    <a href="{{ routes.collections_url }}/wellness" class="apn-mobile-sub-link" onclick="apnCloseMenu()">All Wellness</a>

    <a href="{{ routes.collections_url }}/all" class="apn-mobile-sub-link" style="color:#06A5C5;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-size:0.875rem;" onclick="apnCloseMenu()">View All Products &rarr;</a>
  </div>

  <a href="/pages/framework" class="apn-mobile-link" onclick="apnCloseMenu()">Ascend Framework</a>
  <a href="/pages/about" class="apn-mobile-link" onclick="apnCloseMenu()">About Us</a>
  <a href="/pages/resources" class="apn-mobile-link" onclick="apnCloseMenu()">Resources</a>

  <div style="margin-top:1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
    <a href="/cart" class="apn-mobile-link" style="display:flex;align-items:center;gap:0.6rem;" onclick="apnCloseMenu()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
    </a>
    <a href="/pages/quiz" class="apn-nav-cta" style="width:100%;justify-content:center;text-align:center;" onclick="apnCloseMenu()">Take the Quiz</a>
  </div>
</div>

<script>
  /* ── Scroll effect ── */
  (function(){
    var nav = document.getElementById('main-nav');
    if(!nav) return;
    function onScroll(){ nav.classList.toggle('scrolled', window.scrollY > 40); }
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  })();

  /* ── Mobile menu ── */
  (function(){
    var btn   = document.getElementById('apn-hamburger');
    var menu  = document.getElementById('apn-mobile-menu');
    var ico   = document.getElementById('apn-hamburger-icon');
    var closeIco = document.getElementById('apn-close-icon');
    if(!btn || !menu) return;

    function openMenu(){
      menu.classList.add('open');
      btn.setAttribute('aria-expanded','true');
      ico.style.display  = 'none';
      closeIco.style.display = 'block';
      document.body.style.overflow = 'hidden';
    }

    window.apnCloseMenu = function(){
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded','false');
      ico.style.display  = 'block';
      closeIco.style.display = 'none';
      document.body.style.overflow = '';
    };

    btn.addEventListener('click', function(){
      if(menu.classList.contains('open')){ apnCloseMenu(); }
      else { openMenu(); }
    });

    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && menu.classList.contains('open')){ apnCloseMenu(); }
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
