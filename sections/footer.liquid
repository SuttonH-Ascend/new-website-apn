  <!-- Animated ASCEND text hover effect (desktop only) -->
  <div class="apn-hover-text-wrap" style="position:relative;z-index:2;display:flex;height:18rem;margin-top:-9rem;margin-bottom:-5rem;overflow:hidden;pointer-events:none;">
    <svg id="apn-hover-svg" width="100%" height="100%" viewBox="0 0 300 100" xmlns="http://www.w3.org/2000/svg" style="cursor:default;user-select:none;" aria-hidden="true">
      <defs>
        <linearGradient id="apn-text-gradient" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="300" y2="0">
          <stop offset="0%"   stop-color="#06A5C5" />
          <stop offset="33%"  stop-color="#048FAB" />
          <stop offset="66%"  stop-color="#06d6c7" />
          <stop offset="100%" stop-color="#0ea5e9" />
        </linearGradient>
        <radialGradient id="apn-reveal-mask" gradientUnits="userSpaceOnUse" r="22%" cx="50%" cy="50%">
          <stop offset="0%"   stop-color="white" />
          <stop offset="100%" stop-color="black" />
        </radialGradient>
        <mask id="apn-text-mask">
          <rect x="0" y="0" width="100%" height="100%" fill="url(#apn-reveal-mask)" />
        </mask>
      </defs>
      <text id="apn-ghost-text" x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke-width="0.3" style="fill:transparent;stroke:rgba(255,255,255,0.12);font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;opacity:0;transition:opacity 0.3s;">ASCEND</text>
      <text id="apn-draw-text" x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke-width="0.3" style="fill:transparent;stroke:#06A5C5;stroke-opacity:0.6;font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;stroke-dasharray:1000;stroke-dashoffset:1000;">ASCEND</text>
      <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke="url(#apn-text-gradient)" stroke-width="0.3" mask="url(#apn-text-mask)" style="fill:transparent;font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;">ASCEND</text>
    </svg>
  </div>

  <!-- Mobile responsive styles -->
  <style>
