            </div>
            <div class="apn-ws-check-item">
              <input type="checkbox" id="apn-ws-prod-10" value="Adapt (Ashwagandha)" />
              <label class="apn-ws-check-label" for="apn-ws-prod-10">Adapt (Ashwagandha)</label>
            </div>
            <div class="apn-ws-check-item">
              <input type="checkbox" id="apn-ws-prod-11" value="Clarity (Methylene Blue)" />
              <label class="apn-ws-check-label" for="apn-ws-prod-11">Clarity (Methylene Blue)</label>
            </div>
            <div class="apn-ws-check-item">
              <input type="checkbox" id="apn-ws-prod-12" value="Function (Magnesium)" />
              <label class="apn-ws-check-label" for="apn-ws-prod-12">Function (Magnesium)</label>
            </div>
            <div class="apn-ws-check-item">
              <input type="checkbox" id="apn-ws-prod-13" value="Balance (Turmeric)" />
              <label class="apn-ws-check-label" for="apn-ws-prod-13">Balance (Turmeric)</label>
            </div>
            <div class="apn-ws-check-item">
              <input type="checkbox" id="apn-ws-prod-14" value="Full Product Line" />
              <label class="apn-ws-check-label" for="apn-ws-prod-14">Full Product Line</label>
            </div>
          </div>
          <span class="apn-ws-error" id="apn-ws-err-products">Please select at least one product.</span>

          <hr class="apn-ws-divider" />

          <div class="apn-ws-toggle-row">
            <span class="apn-ws-toggle-label">Currently carry supplements?</span>
            <div class="apn-ws-toggle-wrap">
              <button type="button" class="apn-ws-toggle-btn apn-ws-toggle-active" id="apn-ws-carries-yes" onclick="APNWholesale._setCarries('yes')">Yes</button>
              <button type="button" class="apn-ws-toggle-btn" id="apn-ws-carries-no" onclick="APNWholesale._setCarries('no')">No</button>
            </div>
          </div>

          <div class="apn-ws-actions">
            <button type="button" class="apn-ws-btn-back" onclick="APNWholesale.goTo(2)">
              &larr; Back
            </button>
            <div style="display:flex;align-items:center;gap:1rem;">
              <span class="apn-ws-step-counter">Step 3 of 4</span>
              <button type="button" class="apn-ws-btn-next" onclick="APNWholesale.next()">
                <span class="apn-ws-btn-text">Continue &rarr;</span>
                <span class="apn-ws-spinner"></span>
              </button>
            </div>
          </div>
        </div>

        <!-- ============================================================
             STEP 4 - Final Details
             ============================================================ -->
        <div class="apn-ws-step" id="apn-ws-step-4">
          <p class="apn-ws-step-heading">Final Details</p>
          <p class="apn-ws-step-sub">Just a few more questions and we'll submit your application.</p>

          <div class="apn-ws-field" id="apn-ws-field-how-heard">
            <label class="apn-ws-label" for="apn-ws-how-heard">How did you hear about APN? <span style="color:#f87171;">*</span></label>
            <select id="apn-ws-how-heard" class="apn-ws-select">
              <option value="" disabled selected>Select one...</option>
              <option value="Instagram">Instagram</option>
              <option value="TikTok">TikTok</option>
              <option value="Referral">Referral</option>
              <option value="Google">Google</option>
              <option value="Trade Show">Trade Show</option>
              <option value="Athlete">Athlete</option>
              <option value="Other">Other</option>
            </select>
            <span class="apn-ws-error" id="apn-ws-err-how-heard">Please select how you heard about us.</span>
          </div>

          <div class="apn-ws-field" id="apn-ws-field-why-apn">
            <label class="apn-ws-label" for="apn-ws-why-apn">Why APN? <span style="color:#f87171;">*</span></label>
            <textarea id="apn-ws-why-apn" class="apn-ws-textarea" rows="3" placeholder="Tell us why you want to carry Ascend Performance Nutrition in your business..."></textarea>
            <span class="apn-ws-error" id="apn-ws-err-why-apn">Please share why you're interested in APN.</span>
          </div>

          <div class="apn-ws-field" id="apn-ws-field-instagram-handle">
            <label class="apn-ws-label" for="apn-ws-instagram-handle">Instagram Handle <span style="color:rgba(255,255,255,0.2);">(optional)</span></label>
            <input type="text" id="apn-ws-instagram-handle" class="apn-ws-input" placeholder="@apexfitness" />
          </div>

          <div id="apn-ws-submit-error" class="apn-ws-error" style="margin-bottom:0.5rem;">Something went wrong. Please try again.</div>

          <div class="apn-ws-actions">
            <button type="button" class="apn-ws-btn-back" onclick="APNWholesale.goTo(3)">
              &larr; Back
            </button>
            <div style="display:flex;align-items:center;gap:1rem;">
              <span class="apn-ws-step-counter">Step 4 of 4</span>
              <button type="button" class="apn-ws-btn-next" id="apn-ws-submit-btn" onclick="APNWholesale.submit()">
                <span class="apn-ws-btn-text">Submit Application</span>
                <span class="apn-ws-spinner"></span>
              </button>
            </div>
          </div>
        </div>

        <!-- ============================================================
             STEP 5 - Success
             ============================================================ -->
        <div class="apn-ws-step" id="apn-ws-step-5">
          <div style="text-align:center;padding:0.5rem 0 1rem;">
            <div class="apn-ws-success-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#06A5C5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 14l7 7L24 7"/>
              </svg>
            </div>
            <h3 class="apn-ws-success-heading">Application Received</h3>
            <p class="apn-ws-success-body">Our wholesale team will contact you within 48 hours to discuss pricing, minimums, and your onboarding timeline.</p>
            <div id="apn-ws-tier-badge" class="apn-ws-tier-badge">
              <span id="apn-ws-tier-icon"></span>
              <span id="apn-ws-tier-label"></span>
            </div>
            <br/>
            <button type="button" class="apn-ws-btn-close-success" onclick="APNWholesale.close()">Close</button>
          </div>
        </div>

      </div><!-- /apn-ws-body -->
    </div><!-- /apn-ws-modal -->
  </div><!-- /apn-ws-overlay -->

  <script>
    (function() {
      var KLAVIYO_KEY = 'R5eNpH';
      var KLAVIYO_LIST_ID = 'RSeqfi';

      var state = {
        currentStep: 1,
        businessType: '',
        carriesSupplements: 'yes'
      };

      var typeIcons = {
        'Gym / Fitness Center': '🏋️',
        'Supplement / Health Store': '🏪',
        'Online Retailer': '💻',
        'Healthcare / Chiro / PT': '🏥',
        'CrossFit / Sports Facility': '🥊',
        'Personal Trainer / Coach': '🎯'
      };

      function getEl(id) { return document.getElementById(id); }

      function showError(id, show) {
        var el = getEl(id);
        if (!el) return;
        if (show) { el.classList.add('apn-ws-error-visible'); }
        else { el.classList.remove('apn-ws-error-visible'); }
      }

      function fieldError(fieldId, show) {
        var field = getEl(fieldId);
        if (!field) return;
        if (show) { field.classList.add('apn-ws-field-error'); }
        else { field.classList.remove('apn-ws-field-error'); }
      }

      function isValidEmail(email) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      }

      function updateProgress(step) {
        var segs = document.querySelectorAll('.apn-ws-prog-seg');
        segs.forEach(function(seg) {
          var segNum = parseInt(seg.getAttribute('data-seg'), 10);
          if (step >= 5) {
            seg.classList.add('active');
          } else {
            if (segNum <= step) { seg.classList.add('active'); }
            else { seg.classList.remove('active'); }
          }
        });
        var pb = getEl('apn-ws-progress');
        if (pb) pb.setAttribute('aria-valuenow', step);
      }

      function showStep(n) {
        for (var i = 1; i <= 5; i++) {
          var panel = getEl('apn-ws-step-' + i);
          if (panel) {
            if (i === n) { panel.classList.add('apn-ws-step-active'); }
            else { panel.classList.remove('apn-ws-step-active'); }
          }
        }
        state.currentStep = n;
        updateProgress(n);
        var modal = getEl('apn-ws-modal');
        if (modal) modal.scrollTop = 0;
      }

      function validateStep(stepNum) {
        if (stepNum === 1) {
          if (!state.businessType) {
            showError('apn-ws-type-error', true);
            return false;
          }
          showError('apn-ws-type-error', false);
          return true;
        }

        if (stepNum === 2) {
          var valid = true;
          var businessName = getEl('apn-ws-business-name').value.trim();
          var contactName  = getEl('apn-ws-contact-name').value.trim();
          var email        = getEl('apn-ws-email').value.trim();
          var phone        = getEl('apn-ws-phone').value.trim();
          var cityState    = getEl('apn-ws-city-state').value.trim();

          if (!businessName) { showError('apn-ws-err-business-name', true); fieldError('apn-ws-field-business-name', true); valid = false; }
          else { showError('apn-ws-err-business-name', false); fieldError('apn-ws-field-business-name', false); }

          if (!contactName) { showError('apn-ws-err-contact-name', true); fieldError('apn-ws-field-contact-name', true); valid = false; }
          else { showError('apn-ws-err-contact-name', false); fieldError('apn-ws-field-contact-name', false); }

          if (!email || !isValidEmail(email)) { showError('apn-ws-err-email', true); fieldError('apn-ws-field-email', true); valid = false; }
          else { showError('apn-ws-err-email', false); fieldError('apn-ws-field-email', false); }

          if (!phone) { showError('apn-ws-err-phone', true); fieldError('apn-ws-field-phone', true); valid = false; }
          else { showError('apn-ws-err-phone', false); fieldError('apn-ws-field-phone', false); }

          if (!cityState) { showError('apn-ws-err-city-state', true); fieldError('apn-ws-field-city-state', true); valid = false; }
          else { showError('apn-ws-err-city-state', false); fieldError('apn-ws-field-city-state', false); }

          return valid;
        }

        if (stepNum === 3) {
          var checked = document.querySelectorAll('#apn-ws-step-3 input[type="checkbox"]:checked');
          if (checked.length === 0) {
            showError('apn-ws-err-products', true);
            return false;
          }
          showError('apn-ws-err-products', false);
          return true;
        }

        if (stepNum === 4) {
          var valid2 = true;
          var howHeard = getEl('apn-ws-how-heard').value;
          var whyApn   = getEl('apn-ws-why-apn').value.trim();

          if (!howHeard) { showError('apn-ws-err-how-heard', true); fieldError('apn-ws-field-how-heard', true); valid2 = false; }
          else { showError('apn-ws-err-how-heard', false); fieldError('apn-ws-field-how-heard', false); }

          if (!whyApn) { showError('apn-ws-err-why-apn', true); fieldError('apn-ws-field-why-apn', true); valid2 = false; }
          else { showError('apn-ws-err-why-apn', false); fieldError('apn-ws-field-why-apn', false); }

          return valid2;
        }

        return true;
      }

      function getFormData() {
        var volumeEl = document.querySelector('input[name="apn-ws-volume"]:checked');
        var productsChecked = document.querySelectorAll('#apn-ws-step-3 input[type="checkbox"]:checked');
        var products = [];
        productsChecked.forEach(function(cb) { products.push(cb.value); });

        var igHandleEl = getEl('apn-ws-instagram-handle');

        return {
          business_type:        state.businessType,
          business_name:        (getEl('apn-ws-business-name') ? getEl('apn-ws-business-name').value.trim() : ''),
          contact_name:         (getEl('apn-ws-contact-name')  ? getEl('apn-ws-contact-name').value.trim()  : ''),
          email:                (getEl('apn-ws-email')         ? getEl('apn-ws-email').value.trim()         : ''),
          phone:                (getEl('apn-ws-phone')         ? getEl('apn-ws-phone').value.trim()         : ''),
          city_state:           (getEl('apn-ws-city-state')    ? getEl('apn-ws-city-state').value.trim()    : ''),
          website:              (getEl('apn-ws-website')       ? getEl('apn-ws-website').value.trim()       : ''),
          monthly_volume:       (volumeEl ? volumeEl.value : ''),
          products_interested:  products,
          carries_supplements:  state.carriesSupplements,
          how_heard:            (getEl('apn-ws-how-heard')     ? getEl('apn-ws-how-heard').value            : ''),
          why_apn:              (getEl('apn-ws-why-apn')       ? getEl('apn-ws-why-apn').value.trim()       : ''),
          instagram_handle:     (igHandleEl ? igHandleEl.value.trim() : ''),
          submitted_at:         new Date().toISOString()
        };
      }

      function klaviyoEvent(data) {
        return fetch('https://a.klaviyo.com/client/events/?company_id=' + KLAVIYO_KEY, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/vnd.api+json',
            'revision': '2024-10-15'
          },
          body: JSON.stringify({
            data: {
              type: 'event',
              attributes: {
                metric: {
                  data: {
                    type: 'metric',
                    attributes: { name: 'Wholesale Application Submitted' }
                  }
                },
                properties: {
                  business_type:       data.business_type,
                  business_name:       data.business_name,
                  contact_name:        data.contact_name,
                  email:               data.email,
                  phone:               data.phone,
                  city_state:          data.city_state,
                  website:             data.website,
                  monthly_volume:      data.monthly_volume,
                  products_interested: data.products_interested.join(', '),
                  carries_supplements: data.carries_supplements,
                  how_heard:           data.how_heard,
                  why_apn:             data.why_apn,
                  instagram_handle:    data.instagram_handle,
                  submitted_at:        data.submitted_at
                },
                profile: {
                  data: {
                    type: 'profile',
                    attributes: { email: data.email }
                  }
                }
              }
            }
          })
        });
      }

      function klaviyoSubscribe(data) {
        var nameParts = data.contact_name.split(' ');
        return fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_KEY, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/vnd.api+json',
            'revision': '2024-10-15'
          },
          body: JSON.stringify({
            data: {
              type: 'subscription',
              attributes: {
                list_id: KLAVIYO_LIST_ID,
                email: data.email,
                custom_source: 'Wholesale Application',
                profiles: {
                  data: [
                    {
                      type: 'profile',
                      attributes: {
                        email:        data.email,
                        first_name:   (nameParts[0] || ''),
                        last_name:    (nameParts.slice(1).join(' ') || ''),
                        phone_number: data.phone,
                        properties: {
                          business_type:       data.business_type,
                          business_name:       data.business_name,
                          contact_name:        data.contact_name,
                          phone:               data.phone,
                          city_state:          data.city_state,
                          website:             data.website,
                          monthly_volume:      data.monthly_volume,
                          products_interested: data.products_interested.join(', '),
                          carries_supplements: data.carries_supplements,
                          how_heard:           data.how_heard,
                          why_apn:             data.why_apn,
                          instagram_handle:    data.instagram_handle,
                          submitted_at:        data.submitted_at
                        }
                      }
                    }
                  ]
                }
              }
            }
          })
        });
      }

      window.APNWholesale = {
        open: function() {
          var overlay = getEl('apn-ws-overlay');
          if (overlay) {
            overlay.classList.add('apn-ws-visible');
            document.body.style.overflow = 'hidden';
            showStep(1);
          }
        },

        close: function() {
          var overlay = getEl('apn-ws-overlay');
          if (overlay) {
            overlay.classList.remove('apn-ws-visible');
            document.body.style.overflow = '';
          }
        },

        goTo: function(n) {
          showStep(n);
        },

        next: function() {
          if (!validateStep(state.currentStep)) return;
          if (state.currentStep < 4) {
            showStep(state.currentStep + 1);
          }
        },

        submit: function() {
          if (!validateStep(4)) return;

          var submitBtn = getEl('apn-ws-submit-btn');
          if (submitBtn) { submitBtn.classList.add('loading'); submitBtn.disabled = true; }
          showError('apn-ws-submit-error', false);

          var data = getFormData();

          Promise.all([
            klaviyoEvent(data).catch(function() {}),
            klaviyoSubscribe(data).catch(function() {})
          ]).then(function() {
            if (submitBtn) { submitBtn.classList.remove('loading'); submitBtn.disabled = false; }

            var badgeIcon  = getEl('apn-ws-tier-icon');
            var badgeLabel = getEl('apn-ws-tier-label');
            if (badgeIcon)  badgeIcon.textContent  = typeIcons[data.business_type] || '';
            if (badgeLabel) badgeLabel.textContent = data.business_type;

            showStep(5);
          }).catch(function() {
            if (submitBtn) { submitBtn.classList.remove('loading'); submitBtn.disabled = false; }
            showError('apn-ws-submit-error', true);
          });
        },

        _validate: function(stepNum) {
          return validateStep(stepNum);
        },

        _selectType: function(el) {
          var cards = document.querySelectorAll('.apn-ws-type-card');
          cards.forEach(function(c) { c.classList.remove('selected'); });
          el.classList.add('selected');
          state.businessType = el.getAttribute('data-type');
          showError('apn-ws-type-error', false);
        },

        _setCarries: function(val) {
          state.carriesSupplements = val;
          var yesBtn = getEl('apn-ws-carries-yes');
          var noBtn  = getEl('apn-ws-carries-no');
          if (val === 'yes') {
            if (yesBtn) yesBtn.classList.add('apn-ws-toggle-active');
            if (noBtn)  noBtn.classList.remove('apn-ws-toggle-active');
          } else {
            if (noBtn)  noBtn.classList.add('apn-ws-toggle-active');
            if (yesBtn) yesBtn.classList.remove('apn-ws-toggle-active');
          }
        }
      };

      // Close on overlay backdrop click
      var overlay = getEl('apn-ws-overlay');
      if (overlay) {
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) { APNWholesale.close(); }
        });
      }

      // Close on Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          var ov = getEl('apn-ws-overlay');
          if (ov && ov.classList.contains('apn-ws-visible')) { APNWholesale.close(); }
        }
      });

    })();
  </script>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "tagline", "label": "Brand tagline", "default": "Clean-label supplements built for athletes who refuse to settle. Equip. Empower. Elevate." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" }
  ]
}
{% endschema %}
