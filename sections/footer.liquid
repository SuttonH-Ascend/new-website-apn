<footer class="apn-footer" aria-label="Site footer" style="position:relative;background:#0D0D0D;overflow:hidden;width:100%;">

  <!-- Radial background gradient layer -->
  <div style="position:absolute;inset:0;z-index:0;background:radial-gradient(125% 125% at 50% 10%, rgba(13,13,17,0.4) 50%, rgba(6,165,197,0.18) 100%);pointer-events:none;"></div>

  <!-- Grain texture overlay -->
  <svg style="position:absolute;inset:0;width:100%;height:100%;opacity:0.03;pointer-events:none;z-index:1;" aria-hidden="true">
    <filter id="apn-grain"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter>
    <rect width="100%" height="100%" filter="url(#apn-grain)"/>
  </svg>

  <!-- Main grid -->
  <div style="position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:4rem 1.5rem 2rem;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;" class="apn-footer-grid">

    <!-- Brand column -->
    <div>
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: height: 72 }}" alt="{{ shop.name }}" style="height:36px;width:auto;" />
        {%- else -%}
          <img src="{{ 'ascend real 1_2 trans.png' | asset_url }}" alt="{{ shop.name }}" style="height:36px;width:auto;" />
        {%- endif -%}
        <div style="display:flex;flex-direction:column;line-height:1;gap:1px;">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:0.625rem;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.8);">PERFORMANCE</span>
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.625rem;letter-spacing:0.22em;text-transform:uppercase;color:#06A5C5;">NUTRITION</span>
        </div>
      </div>
      <p style="font-size:0.875rem;line-height:1.75;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;max-width:280px;">
        {{ section.settings.tagline | default: 'Clean-label supplements built for athletes who refuse to settle. Equip. Empower. Elevate.' }}
      </p>
      <!-- Social icons -->
      <div style="display:flex;gap:0.5rem;">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" class="apn-social-btn" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" class="apn-social-btn" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok != blank -%}
          <a href="{{ section.settings.tiktok }}" class="apn-social-btn" aria-label="TikTok" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.72a8.18 8.18 0 0 0 4.78 1.52V6.82a4.85 4.85 0 0 1-1.01-.13z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.youtube != blank -%}
          <a href="{{ section.settings.youtube }}" class="apn-social-btn" aria-label="YouTube" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Products column -->
    <div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.9);margin:0 0 1.25rem;">Products</h3>
      <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.625rem;">
        <li><a href="{{ routes.collections_url }}/protein" class="apn-footer-link">Resilience Whey Protein</a></li>
        <li><a href="{{ routes.collections_url }}/hydration" class="apn-footer-link">Replenish Hydration</a></li>
        <li><a href="{{ routes.collections_url }}/recovery" class="apn-footer-link">Recharge Creatine</a></li>
        <li><a href="{{ routes.collections_url }}/energy" class="apn-footer-link">Ignite Energy</a></li>
        <li><a href="{{ routes.collections_url }}/wellness" class="apn-footer-link">Fortify Colostrum</a></li>
        <li><a href="{{ routes.collections_url }}/all" class="apn-footer-link" style="color:#06A5C5;">View All Products &rarr;</a></li>
      </ul>
    </div>

    <!-- Company column -->
    <div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.9);margin:0 0 1.25rem;">Company</h3>
      <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.625rem;">
        <li><a href="/pages/about" class="apn-footer-link">About Us</a></li>
        <li><a href="/pages/framework" class="apn-footer-link">The Ascend Framework</a></li>
        <li><a href="{{ routes.root_url }}blogs/news" class="apn-footer-link">Resources / Blog</a></li>
        <li><a href="/pages/athletes" class="apn-footer-link">Athlete Profiles</a></li>
      </ul>
    </div>

    <!-- Support column -->
    <div>
      <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.9);margin:0 0 1.25rem;">Support</h3>
      <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.625rem;">
        <li><a href="/pages/quiz" class="apn-footer-link">Performance Quiz</a></li>
        <li><a href="{{ routes.root_url }}policies/shipping-policy" class="apn-footer-link">Shipping Policy</a></li>
        <li><a href="{{ routes.root_url }}policies/refund-policy" class="apn-footer-link">Returns &amp; Refunds</a></li>
        <li><a href="/pages/contact" class="apn-footer-link">Contact Us</a></li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div style="position:relative;z-index:2;border-top:1px solid rgba(255,255,255,0.06);padding:1.5rem;max-width:1280px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
    <p style="font-size:0.8125rem;color:rgba(255,255,255,0.3);margin:0;">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div style="display:flex;gap:1.5rem;">
      <a href="{{ routes.root_url }}policies/privacy-policy" class="apn-footer-link" style="font-size:0.8125rem;">Privacy Policy</a>
      <a href="{{ routes.root_url }}policies/terms-of-service" class="apn-footer-link" style="font-size:0.8125rem;">Terms of Service</a>
    </div>
  </div>

  <!-- Animated ASCEND text hover effect (desktop only) -->
  <div class="apn-hover-text-wrap" style="position:relative;z-index:2;display:flex;height:18rem;margin-top:-9rem;margin-bottom:-5rem;overflow:hidden;">
    <svg
      id="apn-hover-svg"
      width="100%"
      height="100%"
      viewBox="0 0 300 100"
      xmlns="http://www.w3.org/2000/svg"
      style="cursor:default;user-select:none;"
      aria-hidden="true"
    >
      <defs>
        <!-- Gradient revealed under cursor -->
        <linearGradient id="apn-text-gradient" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="300" y2="0">
          <stop offset="0%"   stop-color="#06A5C5" />
          <stop offset="33%"  stop-color="#048FAB" />
          <stop offset="66%"  stop-color="#06d6c7" />
          <stop offset="100%" stop-color="#0ea5e9" />
        </linearGradient>

        <!-- Radial reveal mask that follows the cursor -->
        <radialGradient id="apn-reveal-mask" gradientUnits="userSpaceOnUse" r="22%" cx="50%" cy="50%">
          <stop offset="0%"   stop-color="white" />
          <stop offset="100%" stop-color="black" />
        </radialGradient>
        <mask id="apn-text-mask">
          <rect x="0" y="0" width="100%" height="100%" fill="url(#apn-reveal-mask)" />
        </mask>
      </defs>

      <!-- Ghost outline - visible on hover -->
      <text
        id="apn-ghost-text"
        x="50%" y="50%"
        text-anchor="middle"
        dominant-baseline="middle"
        stroke-width="0.3"
        style="fill:transparent;stroke:rgba(255,255,255,0.12);font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;opacity:0;transition:opacity 0.3s;"
      >ASCEND</text>

      <!-- Animated draw-in outline (teal, plays once on load) -->
      <text
        id="apn-draw-text"
        x="50%" y="50%"
        text-anchor="middle"
        dominant-baseline="middle"
        stroke-width="0.3"
        style="fill:transparent;stroke:#06A5C5;stroke-opacity:0.6;font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;stroke-dasharray:1000;stroke-dashoffset:1000;"
      >ASCEND</text>

      <!-- Gradient fill revealed by cursor mask -->
      <text
        x="50%" y="50%"
        text-anchor="middle"
        dominant-baseline="middle"
        stroke="url(#apn-text-gradient)"
        stroke-width="0.3"
        mask="url(#apn-text-mask)"
        style="fill:transparent;font-family:'Barlow Condensed','Helvetica Neue',sans-serif;font-size:30px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;"
      >ASCEND</text>
    </svg>
  </div>

  <!-- Mobile responsive styles -->
  <style>
    .apn-footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
    @media (max-width: 900px) {
      .apn-footer-grid {
        grid-template-columns: 1fr 1fr !important;
        gap: 2rem !important;
      }
    }
    @media (max-width: 560px) {
      .apn-footer-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
    }
    @media (max-width: 720px) {
      .apn-hover-text-wrap { display: none !important; }
    }

    .apn-footer-link {
      font-family: 'Barlow', sans-serif;
      font-size: 0.875rem;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      transition: color 0.18s;
    }
    .apn-footer-link:hover,
    .apn-footer-link:focus-visible {
      color: #06A5C5;
    }
    .apn-footer-link:focus-visible {
      outline: 2px solid #06A5C5;
      outline-offset: 2px;
      border-radius: 2px;
    }

    .apn-social-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      transition: color 0.18s, border-color 0.18s, background 0.18s;
    }
    .apn-social-btn:hover,
    .apn-social-btn:focus-visible {
      color: #06A5C5;
      border-color: #06A5C5;
      background: rgba(6,165,197,0.08);
    }
    .apn-social-btn:focus-visible {
      outline: 2px solid #06A5C5;
      outline-offset: 2px;
    }
    .apn-social-btn:active {
      background: rgba(6,165,197,0.18);
    }
  </style>

  <!-- Hover effect JS -->
  <script>
    (function() {
      var svg = document.getElementById('apn-hover-svg');
      if (!svg) return;

      var ghostText = document.getElementById('apn-ghost-text');
      var drawText  = document.getElementById('apn-draw-text');
      var revealGrad = document.getElementById('apn-reveal-mask');
      var isHovered = false;

      // Animate the draw-in stroke on page load
      var startTime = null;
      var drawDuration = 4000;
      function animateDraw(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / drawDuration, 1);
        // ease in-out
        var eased = progress < 0.5
          ? 2 * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 2) / 2;
        drawText.style.strokeDashoffset = (1000 * (1 - eased)).toString();
        if (progress < 1) {
          requestAnimationFrame(animateDraw);
        }
      }
      requestAnimationFrame(animateDraw);

      // Mouse tracking
      svg.addEventListener('mouseenter', function() {
        isHovered = true;
        if (ghostText) ghostText.style.opacity = '0.7';
      });

      svg.addEventListener('mouseleave', function() {
        isHovered = false;
        if (ghostText) ghostText.style.opacity = '0';
        // Reset mask to center on leave
        revealGrad.setAttribute('cx', '50%');
        revealGrad.setAttribute('cy', '50%');
      });

      svg.addEventListener('mousemove', function(e) {
        if (!isHovered) return;
        var rect = svg.getBoundingClientRect();
        var cx = ((e.clientX - rect.left) / rect.width * 100).toFixed(2) + '%';
        var cy = ((e.clientY - rect.top)  / rect.height * 100).toFixed(2) + '%';
        revealGrad.setAttribute('cx', cx);
        revealGrad.setAttribute('cy', cy);
      });
    })();
  </script>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Clean-label supplements built for athletes who refuse to settle. Equip. Empower. Elevate."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    }
  ]
}
{% endschema %}
