<section id="about-values" style="background:#F8FAFB;padding:5rem 1.5rem;">
  <div style="max-width:1280px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:3.5rem;" class="apn-fade-up">
      <div class="apn-section-label" style="justify-content:center;">{{ section.settings.eyebrow | default: 'Core Values' }}</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#0D0D0D;margin:0;">{{ section.settings.heading | default: 'What We Stand For' }}</h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;" class="apn-fade-up">
      {%- for block in section.blocks -%}
        <div style="background:#fff;border:1px solid #E2E8F0;border-radius:8px;padding:2rem;text-align:center;" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div style="width:72px;height:72px;margin:0 auto 1.25rem;border-radius:50%;overflow:hidden;background:#F8FAFB;">
              <img src="{{ block.settings.image | image_url: width: 144 }}" alt="{{ block.settings.title }}" style="width:100%;height:100%;object-fit:cover;" />
            </div>
          {%- else -%}
            <div style="width:72px;height:72px;margin:0 auto 1.25rem;background:#D6F0F6;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#06A5C5;">{{ block.settings.title | slice: 0 }}</div>
          {%- endif -%}
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.125rem;letter-spacing:0.06em;text-transform:uppercase;color:#0D0D0D;margin:0 0 0.75rem;">{{ block.settings.title }}</h3>
          <p style="font-size:0.875rem;line-height:1.7;color:#6B7280;margin:0;">{{ block.settings.body }}</p>
        </div>
      {%- else -%}
        {%- assign defaults = 'Faith|We compete for something greater than a trophy. Our faith grounds everything — the way we train, build, and serve.,Family|Supplements built for people, not just performances. Because the people who cheer you on matter as much as the podium.,America|Made with pride, sold with integrity. Supporting hardworking Americans who train with purpose and compete with honor.,Fitness|Performance is the vehicle. We build products that keep you on the field — physically, mentally, and spiritually.' | split: ',' -%}
        {%- for def in defaults -%}
          {%- assign parts = def | split: '|' -%}
          <div style="background:#fff;border:1px solid #E2E8F0;border-radius:8px;padding:2rem;text-align:center;">
            <div style="width:72px;height:72px;margin:0 auto 1.25rem;background:#D6F0F6;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#06A5C5;">{{ parts[0] | slice: 0 }}</div>
            <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.125rem;letter-spacing:0.06em;text-transform:uppercase;color:#0D0D0D;margin:0 0 0.75rem;">{{ parts[0] }}</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:#6B7280;margin:0;">{{ parts[1] }}</p>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>

  <style>
    @media (max-width: 900px) { #about-values div[style*="repeat(4"] { grid-template-columns: repeat(2,1fr) !important; } }
    @media (max-width: 480px) { #about-values div[style*="repeat(4"] { grid-template-columns: 1fr !important; } }
  </style>
</section>

{% schema %}
{
  "name": "About — Values",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Core Values" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What We Stand For" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon image (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Faith" },
        { "type": "textarea", "id": "body", "label": "Description", "default": "We compete for something greater than a trophy." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "About — Values" }]
}
{% endschema %}
