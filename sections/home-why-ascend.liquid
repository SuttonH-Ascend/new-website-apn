<section id="why-ascend" style="background:#F8FAFB;padding:5rem 1.5rem;">
  <div style="max-width:1280px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:3.5rem;" class="apn-fade-up">
      <div class="apn-section-label" style="justify-content:center;">{{ section.settings.eyebrow | default: 'Why Ascend' }}</div>
      <h2 class="apn-display" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#0D0D0D;margin:0;">{{ section.settings.heading | default: 'Why Athletes Choose Ascend' }}</h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
      {%- for block in section.blocks -%}
        <div style="background:#fff;border:1px solid #E2E8F0;border-radius:8px;padding:2rem;transition:box-shadow 0.2s ease;" class="apn-fade-up" {{ block.shopify_attributes }}>
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:2rem;color:#06A5C5;line-height:1;margin-bottom:0.75rem;">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;letter-spacing:0.06em;text-transform:uppercase;color:#0D0D0D;margin:0 0 0.5rem;">{{ block.settings.title | default: 'Clean Ingredients' }}</h3>
          <p style="font-size:0.875rem;line-height:1.7;color:#6B7280;margin:0;">{{ block.settings.body | default: 'No proprietary blends, no fillers. Every ingredient listed with exact dosages.' }}</p>
        </div>
      {%- else -%}
        {%- assign defaults = 'Clean Ingredients|No proprietary blends, no fillers. Every ingredient listed with exact dosages.,Athlete-Formulated|Created by a competing MMA fighter — tested in real training environments.,Faith-Grounded|Built on values that extend beyond performance into who you are.,Full Transparency|What you see is what you get. No hidden doses, no vague blends.,No Banned Substances|Third-party tested and safe for competitive athletes.,Performance-First|Protocols designed around real athletic goals, not marketing.' | split: ',' -%}
        {%- for def in defaults -%}
          {%- assign parts = def | split: '|' -%}
          <div style="background:#fff;border:1px solid #E2E8F0;border-radius:8px;padding:2rem;" class="apn-fade-up">
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:2rem;color:#06A5C5;line-height:1;margin-bottom:0.75rem;">0{{ forloop.index }}</div>
            <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;letter-spacing:0.06em;text-transform:uppercase;color:#0D0D0D;margin:0 0 0.5rem;">{{ parts[0] }}</h3>
            <p style="font-size:0.875rem;line-height:1.7;color:#6B7280;margin:0;">{{ parts[1] }}</p>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>

  <style>
    @media (max-width: 900px) {
      #why-ascend .grid-3 { grid-template-columns: 1fr 1fr !important; }
    }
    @media (max-width: 600px) {
      #why-ascend .grid-3 { grid-template-columns: 1fr !important; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Home — Why Ascend",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Ascend" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Athletes Choose Ascend" }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Clean Ingredients" },
        { "type": "textarea", "id": "body", "label": "Description", "default": "No proprietary blends, no fillers. Every ingredient listed with exact dosages." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Home — Why Ascend" }]
}
{% endschema %}
